@{
    ViewBag.Title = "Ministerios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" /> *@


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Información</a></li>
    <li class="breadcrumb-item active">Ministerios</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-sitemap me-1"></i> Lista de Ministerios
    </div>
    <div class="table-responsive">
        <div class="row mb-3">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModalMinisterios()">Añadir nuevo Ministerio</button>
            </div>
        </div>

        <table id="tablaMinisterios" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Nombre ministerio</th>
                    <th>Nombre del líder</th>
                    <th style="width: 100px;">Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalMinisterios" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h5 class="modal-title" id="exampleModalLabel">Datos del ministerio</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />
                <div class="row g-2">
                    <div class="col-sm-6">
                        <label class="form-label">Nombre Ministerio</label>
                        <input type="text" class="form-control" id="txtNombreMinisterio" placeholder="Nombre Ministerio" autocomplete="off" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Nombre del líder</label>
                        <input type="text" class="form-control" id="txtNombreLider" placeholder="Nombre Líder" autocomplete="off" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger d-none"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GuardarMinisterio()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>

    <script>
        let tabladata;
        let filaSeleccionada;

        // Función auxiliar para obtener datos de la fila (maneja DataTables responsive)
        function getFilaData(button) {
            var tr = $(button).closest("tr");
            var data = tabladata.row(tr).data();
            if (!data) {
                // Manejar el modo responsive de DataTables
                tr = tr.prev("tr");
                data = tabladata.row(tr).data();
            }
            return { tr: tr, data: data };
        }


        $(document).ready(function () {
            // Inicialización de DataTables
            tabladata = $("#tablaMinisterios").DataTable({
                responsive: true,
                ordering: false,
                ajax: {
                    url: '@Url.Action("ListarMinisterios", "Mantenedor")',
                    type: "GET",
                    dataType: "json",
                    dataSrc: "data"
                },
                columns: [
                    { data: "descripcion" },
                    { data: "lider" },
                    {
                        defaultContent: `
                            <div class="d-flex justify-content-center gap-2">
                                <button type="button" class="btn btn-primary btn-sm btn-editarMinisterio">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button" class="btn btn-danger btn-sm btn-eliminarMinisterio">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>`,
                        orderable: false,
                        searchable: false,
                        width: "100px"
                    }
                ],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json"
                }
            });

            // Evento para Editar
            $("#tablaMinisterios tbody").on("click", ".btn-editarMinisterio", function () {
                const fila = getFilaData(this);
                if (fila.data) {
                    filaSeleccionada = fila.tr;
                    abrirModalMinisterios(fila.data);
                }
            });

            // Evento para Eliminar
            $("#tablaMinisterios tbody").on("click", ".btn-eliminarMinisterio", function () {
                const fila = getFilaData(this);
                if (!fila.data) return;

                Swal.fire({
                    title: "¿Estás seguro?",
                    text: `¿Desea eliminar la Zona: ${fila.data.descripcion}?`,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Sí, eliminar",
                    cancelButtonText: "No"
                }).then(result => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("EliminarMinisterio", "Mantenedor")',
                            type: "POST",
                            // 🔑 CORRECCIÓN: Usamos la propiedad que viene en el JSON para el post.
                            data: { id: fila.data.id },
                            success: function (res) {
                                if (res.resultado) {
                                    tabladata.row(fila.tr).remove().draw(false);
                                    Swal.fire("Eliminada", "El ministerio fue eliminado correctamente.", "success");
                                } else {
                                    Swal.fire("Error", res.mensaje || "No se pudo eliminar el ministerio.", "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error", "Error en la solicitud de eliminación.", "error");
                            }
                        });
                    }
                });
            });
        });

        // Abrir modal
        function abrirModalMinisterios(json = null) {
            $("#mensajeError").addClass("d-none").text(""); // Limpia y oculta errores

            if (json) {
                // Modo Edición
                $("#txtid").val(json.id);
                $("#txtNombreMinisterio").val(json.descripcion);
                $("#txtNombreLider").val(json.lider);
                $("#exampleModalLabel").text("Editar ministerio");
            } else {
                // Modo Nuevo Registro
                $("#txtid").val(0);
                $("#txtNombreMinisterio").val("");
                $("#txtNombreLider").val("");
                $("#txtDescripcion").val("");
                $("#exampleModalLabel").text("Datos del nuevo ministerio");
            }

            const modal = new bootstrap.Modal(document.getElementById("FormModalMinisterios"));
            modal.show();
        }


        Guardar
        function GuardarMinisterio() {
            const Ministerio = {
                // 🔑 Usamos iD_zona para ser consistentes al enviar el objeto
                id: parseInt($("#txtid").val()) || 0,
                descripcion: $("#txtNombreMinisterio").val().trim(),
                lider: $("#txtNombreLider").val().trim(),
            };

            if (Ministerio.descripcion === "" || Ministerio.lider === "") {
                $("#mensajeError").removeClass("d-none").text("Nombre de ministerio y líder no pueden ser vacíos.");
                return;
            }

            $(".modal-body").LoadingOverlay("show", { text: "Guardando..." });

            const url = '@Url.Action("GuardarMinisterio", "Mantenedor")';

            $.ajax({
                url: url,
                type: "POST",
                data: Ministerio,
                dataType: "json",
                success: function (data) {
                    $(".modal-body").LoadingOverlay("hide");
                    $("#mensajeError").addClass("d-none");

                    if (data.resultado !== 0) {
                        // Edición
                        if (Ministerio.id > 0) {
                            tabladata.row(filaSeleccionada).data(Ministerio).draw(false);
                            filaSeleccionada = null;
                        } else {
                            // Creación (resultado es el nuevo ID)
                            Ministerio.id = data.resultado;
                            tabladata.row.add(Ministerio).draw(false);
                        }

                        // Oculta el modal y limpia el ID
                        bootstrap.Modal.getInstance(document.getElementById("FormModalMinisterios")).hide();
                        $("#txtid").val("0");
                    } else {
                        $("#mensajeError").removeClass("d-none").text(data.mensaje || "Error al guardar el ministerio.");
                    }
                },
                error: function () {
                    $(".modal-body").LoadingOverlay("hide");
                    $("#mensajeError").removeClass("d-none").text("Error en la solicitud AJAX al guardar.");
                }
            });
        }
    </script>
}