@{
    ViewBag.Title = "Grupos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" /> *@


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Información</a></li>
    <li class="breadcrumb-item active">Grupos</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista de Grupos
    </div>
    <div class="table-responsive">
        <div class="row mb-3">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModalGrupos()">Añadir nuevo grupo</button>
            </div>
        </div>

        <table id="tablaGrupos" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Descripción</th>
                    <th>Acciones</th> @* Nueva columna para los botones de Editar y Eliminar *@
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalGrupos" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="exampleModalLabel">Datos del nuevo grupo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />
                <div class="row g-2">
                    <div class="col-sm-12">
                        @* Ajustado a 12 para que ocupe todo el ancho, ya que solo hay un campo *@
                        <label class="form-label">Descripcion</label>
                        <input type="text" class="form-control" id="txtDescripcion" placeholder="Descripcion" autocomplete="off" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger d-none"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GuardarGrupo()">Guardar</button>
            </div>
        </div>
    </div>
</div>
