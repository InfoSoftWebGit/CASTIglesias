@{
    ViewBag.Title = "Grupos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Información</a></li>
    <li class="breadcrumb-item active">Grupos</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista de Grupos
    </div>
    <div class="table-responsive">
        <div class="row mb-3">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModalGrupos()">Añadir nuevo grupo</button>
            </div>
        </div>

        <table id="tablaGrupos" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Zona</th>
                    <th>Descripción</th>
                    <th>Encargados</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalGrupos" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h5 class="modal-title" id="exampleModalLabel">Datos del nuevo grupo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />
                <div class="row g-2">
                    <div class="col-sm-12">
                        <label class="form-label">Zona</label>
                        <select id="cboZona" class="form-select">
                            <option value="0" disabled selected>Selecciona una zona</option>
                        </select>
                    </div>
                    <div class="col-sm-12">
                        <label class="form-label">Descripción</label>
                        <input type="text" class="form-control" id="txtDescripcion" placeholder="Descripción del grupo" autocomplete="off" />
                    </div>
                    <div class="col-sm-12">
                        <label class="form-label">Encargados</label>
                        <input type="text" class="form-control" id="txtEncargados" placeholder="Nombres de los encargados" autocomplete="off" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger d-none"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GuardarGrupo()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>

    <script>
        let tabladata;
        let filaSeleccionada;

        $(document).ready(function () {
            if ($.fn.DataTable.isDataTable("#tablaGrupos")) {
                $("#tablaGrupos").DataTable().clear().destroy();
            }

            tabladata = $("#tablaGrupos").DataTable({
                dom: 'Bfrtip',
                responsive: true,
                order: [[0, 'asc']],
                ajax: {
                    url: '@Url.Action("ListarGrupos", "Mantenedor")',
                    type: "GET",
                    dataType: "json",
                    dataSrc: "data"
                },
                columns: [
                    { data: "nombre_zona", defaultContent: "Sin zona" },
                    { data: "descripcion", defaultContent: "" },
                    { data: "encargados", defaultContent: "" },
                    {
                        defaultContent: `
                            <div class="d-flex justify-content-center gap-2">
                                <button type="button" class="btn btn-primary btn-sm btn-editarGrupo">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button" class="btn btn-danger btn-sm btn-eliminarGrupo">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        `,
                        orderable: false,
                        searchable: false,
                        width: "100px"
                    }
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var rows = api.rows({ page: 'current' }).nodes();
                    var lastZona = null;

                    api.column(0, { page: 'current' }).data().each(function (zona, i) {
                        if (lastZona !== zona) {
                            $(rows).eq(i).before(
                                '<tr style="background-color:#EEF2FB;">' +
                                '<td colspan="4" style="color:#1E3A8A; font-weight:700; padding:8px 12px; border-bottom:2px solid #1E3A8A;">' +
                                '<i class="fas fa-map-marker-alt me-2"></i>' + (zona || 'Sin zona') +
                                '</td></tr>'
                            );
                            lastZona = zona;
                        }
                    });
                },
                language: {
                    url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json"
                },
                initComplete: function () {
                    $('#tablaGrupos thead').css({
                        'background-color': '#1E3A8A',
                        'color': 'white',
                        'text-align': 'center'
                    });
                }
            });

            $("#tablaGrupos tbody").on("click", ".btn-editarGrupo", function () {
                filaSeleccionada = $(this).closest("tr");
                const data = tabladata.row(filaSeleccionada).data();
                abrirModalGrupos(data);
            });

            $("#tablaGrupos tbody").on("click", ".btn-eliminarGrupo", function () {
                const fila = $(this).closest("tr");
                const data = tabladata.row(fila).data();

                Swal.fire({
                    title: "¿Estás seguro?",
                    text: "¿Desea eliminar este grupo?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Sí",
                    cancelButtonText: "No"
                }).then(result => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("EliminarGrupo", "Mantenedor")',
                            type: "POST",
                            data: { id: data.iD_grupo },
                            success: function (res) {
                                if (res.resultado) {
                                    tabladata.row(fila).remove().draw();
                                } else {
                                    Swal.fire("Error", res.mensaje, "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error", "No se pudo eliminar", "error");
                            }
                        });
                    }
                });
            });
        });

        function cargarZonas(idZonaSeleccionada) {
            $.ajax({
                url: '@Url.Action("ListarZonas", "Mantenedor")',
                type: "GET",
                success: function (res) {
                    const cbo = $("#cboZona");
                    cbo.empty().append('<option value="0" disabled selected>Selecciona una zona</option>');
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function (z) {
                            cbo.append($("<option>").val(z.iD_zona).text(z.nombre_zona));
                        });
                    }
                    if (idZonaSeleccionada && idZonaSeleccionada !== 0) {
                        cbo.val(idZonaSeleccionada);
                    }
                }
            });
        }

        function abrirModalGrupos(json = null) {
            $("#txtid").val(json?.iD_grupo || 0);
            $("#txtDescripcion").val(json?.descripcion || "");
            $("#txtEncargados").val(json?.encargados || "");
            $("#mensajeError").addClass("d-none").text("");

            cargarZonas(json?.iD_zona || null);

            const modal = new bootstrap.Modal(document.getElementById("FormModalGrupos"));
            modal.show();
        }

        function GuardarGrupo() {
            const descripcion = $("#txtDescripcion").val().trim();

            if (descripcion === "") {
                $("#mensajeError").removeClass("d-none").text("La descripción del grupo no puede estar vacía.");
                return;
            }

            const idZona = parseInt($("#cboZona").val()) || 0;
            const nombreZona = idZona > 0 ? $("#cboZona option:selected").text() : "Sin zona";

            const Grupo = {
                iD_grupo: parseInt($("#txtid").val()) || 0,
                descripcion: descripcion,
                encargados: $("#txtEncargados").val().trim(),
                iD_zona: idZona
            };

            $(".modal-body").LoadingOverlay("show", { text: "Cargando..." });

            $.ajax({
                url: '@Url.Action("GuardarGrupos", "Mantenedor")',
                type: "POST",
                data: Grupo,
                success: function (data) {
                    $(".modal-body").LoadingOverlay("hide");

                    const grupoDisplay = { ...Grupo, nombre_zona: nombreZona };

                    if (Grupo.iD_grupo === 0) {
                        if (data.resultado !== 0) {
                            grupoDisplay.iD_grupo = data.resultado;
                            tabladata.row.add(grupoDisplay).draw(false);
                            bootstrap.Modal.getInstance(document.getElementById("FormModalGrupos")).hide();
                        } else {
                            $("#mensajeError").removeClass("d-none").text(data.mensaje);
                        }
                    } else {
                        if (data.resultado) {
                            tabladata.row(filaSeleccionada).data(grupoDisplay).draw(false);
                            filaSeleccionada = null;
                            bootstrap.Modal.getInstance(document.getElementById("FormModalGrupos")).hide();
                        } else {
                            $("#mensajeError").removeClass("d-none").text(data.mensaje);
                        }
                    }
                },
                error: function () {
                    $(".modal-body").LoadingOverlay("hide");
                    $("#mensajeError").removeClass("d-none").text("Error en la solicitud AJAX.");
                }
            });
        }
    </script>
}
