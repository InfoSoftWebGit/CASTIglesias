@{
    ViewBag.Title = "Servicios - " + (ViewBag.NombreMinisterio as string);
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as string[] ?? new string[0];
    bool esAlabanza = ViewBag.EsAlabanza == true;
}
<link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" />
<style>.ui-autocomplete { z-index: 9999 !important; }</style>

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Mantenedor" asp-action="Ministerios">Ministerios</a></li>
    <li class="breadcrumb-item active">Servicios · @ViewBag.NombreMinisterio</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="@ViewBag.Icono me-1"></i> Miembros del ministerio: <strong>@ViewBag.NombreMinisterio</strong>
    </div>
    <div class="table-responsive p-3">
        <div class="mb-3">
            <button type="button" class="btn btn-success" onclick="abrirModalNuevo()">
                <i class="fas fa-plus me-1"></i> Añadir miembro
            </button>
        </div>

        <table id="tablaServicios" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Apellidos</th>
                    <th>Rol</th>
                    @if (esAlabanza)
                    {
                        <th>Ministra</th>
                    }
                    <th style="width: 100px;">Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal añadir / editar -->
<div class="modal fade" id="FormModalServicio" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h5 class="modal-title" id="tituloModalServicio">Asignar miembro al ministerio</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input id="hdnIdAsignacion" type="hidden" value="0" />
                <input id="txtIdMiembro"   type="hidden" value="0" />

                <div class="row g-2">
                    <div class="col-12">
                        <label class="form-label">Miembro</label>
                        <input type="text" class="form-control" id="txtNombreMiembro"
                               placeholder="Busca por nombre o apellidos…" autocomplete="off" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Rol</label>
                        <select class="form-select" id="cmbRol">
                            <option value="">-- Selecciona un rol --</option>
                            @foreach (var rol in roles)
                            {
                                <option value="@rol">@rol</option>
                            }
                        </select>
                    </div>
                    @if (esAlabanza)
                    {
                        <div class="col-12">
                            <label class="form-label">
                                ¿Puede ministrar?
                                <small class="text-muted ms-1">
                                    (Sí = puede dirigir el servicio de alabanza)
                                </small>
                            </label>
                            <select class="form-select" id="cmbEsMinistra">
                                <option value="No">No</option>
                                <option value="Si">Sí</option>
                            </select>
                        </div>
                    }
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger d-none"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GuardarServicio()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>
    <script src="https://code.jquery.com/ui/1.14.0/jquery-ui.min.js"></script>

    <script>
        const idMinisterio   = @ViewBag.IdMinisterio;
        const esAlabanza     = @(esAlabanza ? "true" : "false");
        const urlBuscarMiembros = '@Url.Action("BuscarMiembros", "Economia")';
        let tabladata;

        function getFilaData(button) {
            const tr = $(button).closest("tr");
            const data = tabladata.row(tr).data()
                      || tabladata.row(tr.prev("tr")).data();
            return { tr, data };
        }

        $(document).ready(function () {
            // Autocomplete búsqueda de miembros
            $("#txtNombreMiembro").autocomplete({
                source: (req, resp) => {
                    $.get(urlBuscarMiembros, { busqueda: req.term, tipoBusqueda: 'nombre' }, res => {
                        resp((res.data || []).map(m => ({
                            label: (m.nombre_miembro || '') + ' ' + (m.apellidos_miembro || ''),
                            value: (m.nombre_miembro || '') + ' ' + (m.apellidos_miembro || ''),
                            id: m.id_miembro
                        })));
                    });
                },
                minLength: 2,
                select: (e, ui) => $("#txtIdMiembro").val(ui.item.id)
            });
            $("#txtNombreMiembro").on("input", () => $("#txtIdMiembro").val(0));

            // Columnas DataTable
            const columns = [
                { data: "nombre_miembro" },
                { data: "apellidos_miembro" },
                { data: "rol_servicio", defaultContent: "" }
            ];
            if (esAlabanza) {
                columns.push({
                    data: "es_ministra",
                    defaultContent: "No",
                    render: v => v === "Si"
                        ? '<span class="badge bg-success">Sí</span>'
                        : '<span class="badge bg-secondary">No</span>'
                });
            }
            columns.push({
                data: null,
                render: (d) =>
                    `<div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-primary btn-sm btn-editarServicio" title="Editar rol">
                            <i class="fas fa-pen"></i>
                        </button>
                        <button class="btn btn-danger btn-sm btn-eliminarServicio" title="Eliminar">
                            <i class="fas fa-trash"></i>
                        </button>
                     </div>`,
                orderable: false,
                searchable: false,
                width: "100px"
            });

            tabladata = $("#tablaServicios").DataTable({
                responsive: true,
                ordering: true,
                ajax: {
                    url: '@Url.Action("ListarMiembrosServicio", "Mantenedor")',
                    type: "GET",
                    data: { idMinisterio },
                    dataType: "json",
                    dataSrc: "data"
                },
                columns,
                language: { url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json" },
                initComplete: function () {
                    $('#tablaServicios thead').css({
                        'background-color': '#1E3A8A',
                        'color': 'white',
                        'text-align': 'center'
                    });
                }
            });

            // Editar
            $("#tablaServicios tbody").on("click", ".btn-editarServicio", function () {
                const { data } = getFilaData(this);
                if (data) abrirModalEdicion(data);
            });

            // Eliminar
            $("#tablaServicios tbody").on("click", ".btn-eliminarServicio", function () {
                const { tr, data } = getFilaData(this);
                if (!data) return;

                Swal.fire({
                    title: "¿Estás seguro?",
                    text: `¿Quitar a ${data.nombre_miembro} ${data.apellidos_miembro} (${data.rol_servicio || 'sin rol'})?`,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Sí, quitar",
                    cancelButtonText: "No"
                }).then(res => {
                    if (!res.isConfirmed) return;
                    $.post('@Url.Action("EliminarMiembroServicio", "Mantenedor")',
                        { idAsignacion: data.id_asignacion },
                        r => {
                            if (r.resultado) {
                                tabladata.row(tr).remove().draw(false);
                                Swal.fire("Hecho", "Rol eliminado.", "success");
                            } else {
                                Swal.fire("Error", r.mensaje || "No se pudo eliminar.", "error");
                            }
                        }
                    );
                });
            });
        });

        function abrirModalNuevo() {
            resetModal();
            $("#tituloModalServicio").text("Añadir miembro al ministerio");
            $("#txtNombreMiembro").prop("disabled", false);
            new bootstrap.Modal(document.getElementById("FormModalServicio")).show();
        }

        function abrirModalEdicion(data) {
            resetModal();
            $("#hdnIdAsignacion").val(data.id_asignacion);
            $("#txtIdMiembro").val(data.id_miembro);
            $("#txtNombreMiembro")
                .val((data.nombre_miembro || '') + ' ' + (data.apellidos_miembro || ''))
                .prop("disabled", true);
            $("#cmbRol").val(data.rol_servicio || "");
            if (esAlabanza) $("#cmbEsMinistra").val(data.es_ministra === "Si" ? "Si" : "No");
            $("#tituloModalServicio").text("Editar rol del miembro");
            new bootstrap.Modal(document.getElementById("FormModalServicio")).show();
        }

        function resetModal() {
            $("#hdnIdAsignacion").val(0);
            $("#txtIdMiembro").val(0);
            $("#txtNombreMiembro").val("").prop("disabled", false);
            $("#cmbRol").val("");
            if (esAlabanza) $("#cmbEsMinistra").val("No");
            $("#mensajeError").addClass("d-none").text("");
        }

        function GuardarServicio() {
            const idAsignacion = parseInt($("#hdnIdAsignacion").val()) || 0;
            const idMiembro    = parseInt($("#txtIdMiembro").val()) || 0;
            const rol          = $("#cmbRol").val();
            const esMinistra   = esAlabanza ? ($("#cmbEsMinistra").val() || "No") : "No";

            if (idAsignacion === 0 && idMiembro <= 0) {
                $("#mensajeError").removeClass("d-none").text("Selecciona un miembro de la lista de búsqueda.");
                return;
            }
            if (!rol) {
                $("#mensajeError").removeClass("d-none").text("Debes seleccionar un rol.");
                return;
            }

            $(".modal-body").LoadingOverlay("show", { text: "Guardando..." });

            $.ajax({
                url: '@Url.Action("GuardarMiembroServicio", "Mantenedor")',
                type: "POST",
                data: { idMiembro, idMinisterio, rol, esMinistra, idAsignacion },
                dataType: "json",
                success: data => {
                    $(".modal-body").LoadingOverlay("hide");
                    if (data.resultado) {
                        bootstrap.Modal.getInstance(document.getElementById("FormModalServicio")).hide();
                        tabladata.ajax.reload(null, false);
                    } else {
                        $("#mensajeError").removeClass("d-none").text(data.mensaje || "Error al guardar.");
                    }
                },
                error: () => {
                    $(".modal-body").LoadingOverlay("hide");
                    $("#mensajeError").removeClass("d-none").text("Error de conexión.");
                }
            });
        }
    </script>
}
