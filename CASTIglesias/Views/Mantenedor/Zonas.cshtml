@{
    ViewBag.Title = "Zonas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" /> *@


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Información</a></li>
    <li class="breadcrumb-item active">Zonas</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-sitemap me-1"></i> Lista de Zonas
    </div>
    <div class="table-responsive">
        <div class="row mb-3">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModalZonas()">Añadir nueva Zona</button>
            </div>
        </div>

        <table id="tablaZonas" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Nombre Zona</th>
                    <th>Nombre del líder</th>
                    <th>Descripción</th>
                    <th style="width: 100px;">Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalZonas" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h5 class="modal-title" id="exampleModalLabel">Datos de la Zona</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />
                <div class="row g-2">
                    <div class="col-sm-6">
                        <label class="form-label">Nombre Zona</label>
                        <input type="text" class="form-control" id="txtNombreZona" placeholder="Nombre Zona" autocomplete="off" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Nombre del líder</label>
                        <input type="text" class="form-control" id="txtNombreLider" placeholder="Nombre Líder" autocomplete="off" />
                    </div>
                    <div class="col-sm-12">
                        <label class="form-label">Descripción</label>
                        <input type="text" class="form-control" id="txtDescripcion" placeholder="Descripción" autocomplete="off" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger d-none"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GuardarZona()">Guardar</button>
            </div>
        </div>
    </div>
</div>

