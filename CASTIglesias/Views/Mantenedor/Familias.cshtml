---
@section scripts {
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>

    <script>
        let tabladata;
        let filaSeleccionada;

        $(document).ready(function () {
            // Destruir instancia previa si existe
            if ($.fn.DataTable.isDataTable("#tablaFamilias")) {
                $("#tablaFamilias").DataTable().clear().destroy();
            }

            tabladata = $("#tablaFamilias").DataTable({
                dom: 'Bfrtip',
                responsive: true,
                ordering: false,
                ajax: {
                    url: '@Url.Action("ListarFamilias", "Mantenedor")',
                    type: "GET",
                    dataType: "json",
                    dataSrc: "data"
                },
                columns: [
                    { data: "nombre_familia" },
                    { data: "telefono_familia" },
                    { data: "direccion", defaultContent: "" },
                    { data: "municipio", defaultContent: "" },
                    {
                        defaultContent: `
                            <div class="d-flex justify-content-center gap-2">
                                <button type="button" class="btn btn-primary btn-sm btn-editarFamilia">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button" class="btn btn-danger btn-sm btn-eliminarFamilia">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        `,
                        orderable: false,
                        searchable: false,
                        width: "100px"
                    }
                ],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json"
                },
                initComplete: function () {
                    // Color cabecera azul tipo Facebook
                    $('#tablaFamilias thead').css({
                        'background-color': '#1877F2',
                        'color': 'white',
                        'text-align': 'center'
                    });
                }
            });

            // Botón editar
            $("#tablaFamilias tbody").on("click", ".btn-editarFamilia", function () {
                filaSeleccionada = $(this).closest("tr");
                const data = tabladata.row(filaSeleccionada).data();
                abrirModalFamilias(data);
            });

            // Botón eliminar
            $("#tablaFamilias tbody").on("click", ".btn-eliminarFamilia", function () {

                const fila = $(this).closest("tr");
                const data = tabladata.row(fila).data();

                Swal.fire({
                    title: "¿Estás seguro?",
                    text: "¿Desea eliminar a esta familia?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Sí",
                    cancelButtonText: "No"
                }).then(result => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("EliminarFamilia", "Mantenedor")',
                            type: "POST",
                            data: { id: data.iD_familia }, // <-- Se usa el ID correcto para la eliminación
                            success: function (res) {
                                if (res.resultado) {
                                    tabladata.row(fila).remove().draw();
                                } else {
                                    Swal.fire("Error", res.mensaje, "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error", "No se pudo eliminar", "error");
                            }
                        });

                    }
                });
            });
        });

        // Abrir modal
        function abrirModalFamilias(json = null) {
            $("#txtid").val(json?.iD_familia || 0);
            $("#txtNombres").val(json?.nombre_familia || "");
            $("#txtTelefono").val(json?.telefono_familia || "");
            $("#txtDireccion").val(json?.direccion || "");

            $("#txtCP").val(json?.cP || "");
            $("#txtIntegrantes").val(json?.integrantes ?? "");
            $("#mensajeError").addClass("d-none").text("");

            if (json) {
                var provId = encontrarProvinciaIdPorNombre(json.provincia || "");
                $("#cboProvincia").val(provId);
                cargarMunicipiosFamilia(provId, json.municipio || "");
            } else {
                resetearSelects();
            }

            const modal = new bootstrap.Modal(document.getElementById("FormModalFamilias"));
            modal.show();
        }



        // Guardar
        function GuardarFamilia() {
            const Familia = {
                iD_familia: parseInt($("#txtid").val()) || 0,
                nombre_familia: $("#txtNombres").val().trim(),
                telefono_familia: parseInt($("#txtTelefono").val()) || 0,
                direccion: $("#txtDireccion").val().trim(),

                cP: parseInt($("#txtCP").val()) || null,
                integrantes: parseInt($("#txtIntegrantes").val()) || null,
                provincia: ($("#cboProvincia").val() && $("#cboProvincia").val() !== "0")
                    ? $("#cboProvincia option:selected").text() : null,
                municipio: $("#cboMunicipio").val() || null
            };

            console.log("Objeto familia:", Familia);

            $(".modal-body").LoadingOverlay("show", { text: "Cargando..." });

            const url = '@Url.Action("GuardarFamilia", "Mantenedor")';


            $.ajax({
                url: url,
                type: "POST",
                data: JSON.stringify(Familia),
                contentType: "application/json",
                dataType: "json",
                success: function (data) {
                    $(".modal-body").LoadingOverlay("hide");

                    if (Familia.iD_familia === 0) {
                        if (data.resultado !== 0) {
                            Familia.iD_familia = data.resultado;
                            tabladata.row.add(Familia).draw(false);
                            bootstrap.Modal.getInstance(document.getElementById("FormModalFamilias")).hide();
                        } else {
                            $("#mensajeError").removeClass("d-none").text(data.mensaje);
                        }
                    } else {
                        if (data.resultado) {
                            tabladata.row(filaSeleccionada).data(Familia).draw(false);
                            filaSeleccionada = null;
                            bootstrap.Modal.getInstance(document.getElementById("FormModalFamilias")).hide();
                        } else {
                            $("#mensajeError").removeClass("d-none").text(data.mensaje);
                        }
                    }
                },
                error: function () {
                    $(".modal-body").LoadingOverlay("hide");
                    $("#mensajeError").removeClass("d-none").text("Error en la solicitud AJAX.");
                }
            })
        }
        // Cascado Provincia → Municipio
        $("#cboProvincia").on("change", function () {
            cargarMunicipiosFamilia($(this).val(), "");
        });

        function resetearSelects() {
            $("#cboProvincia").val("0");
            $("#cboMunicipio").empty()
                .append('<option disabled selected>Selecciona un municipio</option>')
                .prop("disabled", true);
        }

        function encontrarProvinciaIdPorNombre(nombre) {
            if (!nombre) return "0";
            var found = "0";
            $("#cboProvincia option").each(function () {
                if ($(this).text().trim() === nombre.trim()) {
                    found = $(this).val();
                }
            });
            return found;
        }

        function cargarMunicipiosFamilia(idProvincia, nombreMunicipio) {
            if (!idProvincia || idProvincia === "0") {
                resetearSelects();
                return;
            }
            $("#cboMunicipio").prop("disabled", true).html("<option>Cargando...</option>");
            $.ajax({
                url: '@Url.Action("ListarMunicipiosPorProvincia", "Mantenedor")',
                type: "GET",
                data: { idProvincia: idProvincia },
                success: function (res) {
                    $("#cboMunicipio").empty().prop("disabled", false)
                        .append('<option disabled selected>Selecciona un municipio</option>');
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function (m) {
                            $("#cboMunicipio").append(
                                $("<option>").val(m.nombre_municipio).text(m.nombre_municipio)
                            );
                        });
                    }
                    if (nombreMunicipio) {
                        $("#cboMunicipio").val(nombreMunicipio);
                    }
                }
            });
        }
    </script>
}