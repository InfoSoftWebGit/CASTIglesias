@{
    ViewBag.Title = "Familias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" /> *@


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Información</a></li>
    <li class="breadcrumb-item active">Familias</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista de Familias
    </div>
    <div class="table-responsive">
        <div class="row mb-3">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModalFamilias()">Añadir nueva familia</button>
            </div>
        </div>

        <table id="tablaFamilias" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Nombre Familia</th>
                    <th>Teléfono</th>
                    <th>Dirección</th>
                    <th>Municipio</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalFamilias" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h5 class="modal-title" id="exampleModalLabel">Datos de la nueva familia</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />
                <div class="row g-2">
                    <div class="col-sm-6">
                        <label class="form-label">Nombre familiar</label>
                        <input type="text" class="form-control" id="txtNombres" placeholder="Nombre Familia" autocomplete="off" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Teléfono</label>
                        <input type="text" class="form-control" id="txtTelefono" placeholder="999555444" autocomplete="off" />
                    </div>
                    <div class="col-sm-12">
                        <label class="form-label">Dirección</label>
                        <input type="text" class="form-control" id="txtDireccion" placeholder="Calle, número..." autocomplete="off" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Provincia</label>
                        <select id="cboProvincia" class="form-select">
                            <option value="0" disabled selected>Selecciona una provincia</option>
                            @if (ViewBag.ListaProvincias != null)
                            {
                                foreach (var p in ViewBag.ListaProvincias)
                                {
                                    <option value="@p.idProvincia">@p.nombre_provincia</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Municipio</label>
                        <select id="cboMunicipio" class="form-select" disabled>
                            <option disabled selected>Selecciona un municipio</option>
                        </select>
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">CP</label>
                        <input type="number" class="form-control" id="txtCP" placeholder="28001" autocomplete="off" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">Cantidad de integrantes</label>
                        <input type="number" class="form-control" id="txtIntegrantes" placeholder="0" min="0" autocomplete="off" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger d-none"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GuardarFamilia()">Guardar</button>
            </div>
        </div>
    </div>
</div>@* 
