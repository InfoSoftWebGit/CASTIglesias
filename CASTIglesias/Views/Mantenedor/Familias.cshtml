    #tablaFamilias thead {
        background-color: #1877F2 !important;
    }

    #tablaFamilias th {
        color: white !important;
        text-align: center !important;
        vertical-align: middle !important;
    }

    #tablaFamilias tbody td {
        color: black !important;
    }
