@{
    ViewBag.Title = "Cultos y Servicios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" />

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
    <li class="breadcrumb-item active">Cultos y Servicios</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-church me-1"></i> Lista de Cultos y Servicios
    </div>
    <div class="table-responsive">
        <div class="row mb-3">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModal(0)">
                    <i class="fas fa-plus me-1"></i> Añadir nuevo culto
                </button>
            </div>
        </div>
        <table id="tablaCultos" class="table table-bordered table-striped border-top" style="width:100%">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Día</th>
                    <th>Bloques horarios</th>
                    <th style="width:110px;">Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalCulto" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color:#1E3A8A;">
                <h5 class="modal-title" id="modalCultoTitulo">Datos del culto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hidId" value="0" />

                <div class="row g-3 mb-4">
                    <div class="col-sm-8">
                        <label class="form-label">Nombre del culto / servicio</label>
                        <input type="text" id="txtNombre" class="form-control" placeholder="Ej: Culto Dominical" autocomplete="off" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">Día de la semana</label>
                        <select id="cboDia" class="form-select">
                            <option value="1">Lunes</option>
                            <option value="2">Martes</option>
                            <option value="3">Miércoles</option>
                            <option value="4">Jueves</option>
                            <option value="5">Viernes</option>
                            <option value="6">Sábado</option>
                            <option value="7" selected>Domingo</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label mb-0 fw-semibold">Bloques horarios</label>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="agregarBloque()">
                        <i class="fas fa-plus me-1"></i> Añadir bloque
                    </button>
                </div>
                <div id="contenedorBloques">
                    <!-- filas de bloques se inyectan aquí -->
                </div>
                <div id="sinBloques" class="text-muted small text-center py-2">
                    Sin bloques horarios. Pulsa "Añadir bloque" para definir el horario.
                </div>

                <div id="mensajeError" class="alert alert-danger d-none mt-3"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="guardarCulto()">
                    <i class="fas fa-save me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script src="https://cdn.datatables.net/2.0.3/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/2.0.3/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const urlListar        = '@Url.Action("ListarCultos",       "Mantenedor")';
    const urlListarBloques = '@Url.Action("ListarBloquesCulto", "Mantenedor")';
    const urlGuardar       = '@Url.Action("GuardarCulto",       "Mantenedor")';
    const urlEliminar      = '@Url.Action("EliminarCulto",      "Mantenedor")';

    const dias = ['', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'];

    let tabla;
    // cache de bloques por culto para mostrarlos en la tabla
    let cacheBloques = {};

    $(document).ready(function () {
        tabla = $('#tablaCultos').DataTable({
            ajax: {
                url: urlListar,
                dataSrc: 'data',
                complete: function () {
                    // cargar bloques para todos los cultos de la tabla
                    tabla.rows().data().each(function (row) {
                        cargarBloquesTabla(row.id_culto);
                    });
                }
            },
            columns: [
                { data: 'nombre' },
                { data: 'dia_semana', render: d => dias[d] || d },
                {
                    data: 'id_culto',
                    orderable: false,
                    render: function (id) {
                        return `<span id="bloques-${id}" class="text-muted small">—</span>`;
                    }
                },
                {
                    data: null,
                    orderable: false,
                    render: function (d, t, row) {
                        return `<button class="btn btn-sm btn-warning me-1" onclick="abrirModal(${row.id_culto})">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="eliminarCulto(${row.id_culto})">
                                    <i class="fas fa-trash"></i>
                                </button>`;
                    }
                }
            ],
            language: { url: 'https://cdn.datatables.net/plug-ins/2.0.3/i18n/es-ES.json' }
        });
    });

    function cargarBloquesTabla(idCulto) {
        $.get(urlListarBloques, { idCulto }, function (res) {
            const bloques = res.data || [];
            const texto = bloques.length === 0
                ? '—'
                : bloques.map((b, i) => `Bloque ${i+1}: ${b.hora_inicio}–${b.hora_fin}`).join(' | ');
            $(`#bloques-${idCulto}`).text(texto);
        });
    }

    // ─── Modal ───────────────────────────────────────────────────────────────
    let bloquesModal = []; // array de { id_bloque, hora_inicio, hora_fin }

    function abrirModal(id) {
        $('#hidId').val(id || 0);
        $('#txtNombre').val('');
        $('#cboDia').val(7);
        $('#mensajeError').addClass('d-none');
        bloquesModal = [];
        $('#contenedorBloques').empty();
        $('#sinBloques').removeClass('d-none');

        if (id) {
            // Cargar datos del culto desde la tabla
            const row = tabla.rows().data().toArray().find(r => r.id_culto === id);
            if (row) {
                $('#txtNombre').val(row.nombre);
                $('#cboDia').val(row.dia_semana);
            }
            // Cargar bloques existentes
            $.get(urlListarBloques, { idCulto: id }, function (res) {
                (res.data || []).forEach(function (b) {
                    bloquesModal.push({ id_bloque: b.id_bloque, hora_inicio: b.hora_inicio, hora_fin: b.hora_fin });
                    renderizarBloques();
                });
            });
        }

        $('#modalCultoTitulo').text(id ? 'Editar culto' : 'Nuevo culto');
        new bootstrap.Modal(document.getElementById('modalCulto')).show();
    }

    function agregarBloque() {
        bloquesModal.push({ id_bloque: 0, hora_inicio: '09:00', hora_fin: '11:00' });
        renderizarBloques();
    }

    function eliminarBloqueModal(idx) {
        bloquesModal.splice(idx, 1);
        renderizarBloques();
    }

    function renderizarBloques() {
        const cont = $('#contenedorBloques').empty();
        if (bloquesModal.length === 0) {
            $('#sinBloques').removeClass('d-none');
            return;
        }
        $('#sinBloques').addClass('d-none');
        bloquesModal.forEach(function (b, i) {
            cont.append(`
                <div class="row g-2 align-items-center mb-2" id="fila-bloque-${i}">
                    <div class="col-auto">
                        <span class="badge bg-secondary">Bloque ${i + 1}</span>
                    </div>
                    <div class="col">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Desde</span>
                            <input type="time" class="form-control bloque-inicio" data-idx="${i}" value="${b.hora_inicio || '09:00'}" />
                            <span class="input-group-text">Hasta</span>
                            <input type="time" class="form-control bloque-fin" data-idx="${i}" value="${b.hora_fin || '11:00'}" />
                        </div>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="eliminarBloqueModal(${i})">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>`);
        });

        // Sincronizar cambios de inputs con el array
        $('.bloque-inicio').off('change').on('change', function () {
            bloquesModal[$(this).data('idx')].hora_inicio = $(this).val();
        });
        $('.bloque-fin').off('change').on('change', function () {
            bloquesModal[$(this).data('idx')].hora_fin = $(this).val();
        });
    }

    function guardarCulto() {
        const nombre = $('#txtNombre').val().trim();
        if (!nombre) {
            $('#mensajeError').removeClass('d-none').text('El nombre es obligatorio.');
            return;
        }

        // Leer valores actuales de los inputs (por si no dispararon change)
        $('.bloque-inicio').each(function () { bloquesModal[$(this).data('idx')].hora_inicio = $(this).val(); });
        $('.bloque-fin').each(function ()    { bloquesModal[$(this).data('idx')].hora_fin    = $(this).val(); });

        $.ajax({
            url: urlGuardar,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                id_culto:   parseInt($('#hidId').val()),
                nombre:     nombre,
                dia_semana: parseInt($('#cboDia').val()),
                bloques:    bloquesModal
            }),
            success: function (res) {
                if (!res.resultado) {
                    $('#mensajeError').removeClass('d-none').text(res.mensaje);
                    return;
                }
                bootstrap.Modal.getInstance(document.getElementById('modalCulto')).hide();
                tabla.ajax.reload(null, false);
                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.mensaje, showConfirmButton: false, timer: 2500, timerProgressBar: true });
            }
        });
    }

    function eliminarCulto(id) {
        Swal.fire({
            title: '¿Eliminar este culto?',
            text: 'Se eliminarán también sus bloques y los roles configurados.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonText: 'Cancelar',
            confirmButtonText: 'Sí, eliminar'
        }).then(result => {
            if (!result.isConfirmed) return;
            $.post(urlEliminar, { id }, function (res) {
                if (res.resultado) {
                    tabla.ajax.reload(null, false);
                    Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.mensaje, showConfirmButton: false, timer: 2500, timerProgressBar: true });
                } else {
                    Swal.fire('Error', res.mensaje, 'error');
                }
            });
        });
    }
</script>
}
