@{
    ViewData["Title"] = "Calendarios de Servicio";
}

<div class="container-fluid px-4" id="paginaCalendario">
    <h1 class="mt-4">Calendarios de Servicio</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Inicio</a></li>
        <li class="breadcrumb-item">Control</li>
        <li class="breadcrumb-item active">Calendarios</li>
    </ol>

    <div class="row">
        <!-- Formulario de configuración -->
        <div class="col-lg-9">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-calendar-alt me-1"></i>
                    Configuración del calendario
                </div>
                <div class="card-body">
                    <div class="row g-4">

                        <!-- Tipo de calendario -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tipo de calendario</label>
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="tipoCalendario"
                                           id="tipoServidores" value="1" checked />
                                    <label class="form-check-label" for="tipoServidores">
                                        <i class="fas fa-users me-1 text-primary"></i>
                                        Servidores individuales
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="tipoCalendario"
                                           id="tipoAlabanza" value="2" />
                                    <label class="form-check-label" for="tipoAlabanza">
                                        <i class="fas fa-music me-1 text-success"></i>
                                        Alabanza
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Culto -->
                        <div class="col-md-6">
                            <label for="cboCulto" class="form-label fw-semibold">Culto / Servicio</label>
                            <select id="cboCulto" class="form-select">
                                <option value="">— Selecciona un culto —</option>
                            </select>
                        </div>

                        <!-- Periodicidad -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Periodicidad</label>
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="periodicidad"
                                           id="perSemanal" value="semanal" />
                                    <label class="form-check-label" for="perSemanal">
                                        Semanal <small class="text-muted">(4 semanas)</small>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="periodicidad"
                                           id="perMensual" value="mensual" checked />
                                    <label class="form-check-label" for="perMensual">
                                        Mensual <small class="text-muted">(1 mes)</small>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="periodicidad"
                                           id="perTrimestral" value="trimestral" />
                                    <label class="form-check-label" for="perTrimestral">
                                        Trimestral <small class="text-muted">(3 meses)</small>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Fecha de inicio -->
                        <div class="col-md-6">
                            <label for="txtFechaInicio" class="form-label fw-semibold">Fecha de inicio</label>
                            <input type="date" id="txtFechaInicio" class="form-control" />
                        </div>

                    </div>

                    <div class="mt-4">
                        <button class="btn btn-primary" id="btnGenerar" onclick="generarCalendario()">
                            <i class="fas fa-calendar-check me-1"></i>
                            Generar calendario
                        </button>
                    </div>
                </div>
            </div>

            <!-- Resultado del calendario -->
            <div id="panelCalendario" class="d-none">
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span>
                            <i class="fas fa-table me-1"></i>
                            <span id="lblTituloCalendario">Calendario</span>
                        </span>
                        <div class="d-flex gap-2 no-print">
                            <button class="btn btn-success btn-sm" onclick="exportarExcel()">
                                <i class="fas fa-file-excel me-1"></i> Excel
                            </button>
                            <button class="btn btn-danger btn-sm" onclick="exportarPdf()">
                                <i class="fas fa-file-pdf me-1"></i> PDF / Imprimir
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div id="subtituloCalendario" class="px-3 pt-3 pb-1 text-muted small fst-italic"></div>
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm table-striped mb-0" id="tablaCalendario">
                                <thead id="theadCalendario" class="table-dark"></thead>
                                <tbody id="tbodyCalendario"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sin resultados -->
            <div id="panelVacio" class="d-none">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <span id="msgVacio"></span>
                </div>
            </div>
        </div>

        <!-- Ayuda lateral -->
        <div class="col-lg-3 no-print">
            <div class="card mb-4 border-info">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-info-circle me-1"></i> Ayuda
                </div>
                <div class="card-body small text-muted">
                    <p><strong>Tipos de calendario:</strong></p>
                    <ul class="ps-3">
                        <li><strong>Servidores:</strong> muestra todos los roles configurados para el culto.</li>
                        <li><strong>Alabanza:</strong> igual pero orientado al equipo de música.</li>
                    </ul>
                    <p><strong>Rotación automática:</strong><br>
                       El sistema distribuye a las personas de forma equitativa. Si hay 2 pianistas y el culto necesita 1,
                       se alternarán domingo a domingo.</p>
                    <p><strong>Requisito previo:</strong><br>
                       Los roles del culto se configuran en <strong>Ajustes → Servicios</strong>.<br>
                       Los miembros deben tener asignado su <em>rol de servicio</em> en sus fichas de ministerio.</p>
                    <hr />
                    <p><strong>Exportar:</strong></p>
                    <ul class="ps-3">
                        <li><strong>Excel</strong>: descarga un archivo .xlsx.</li>
                        <li><strong>PDF</strong>: abre el diálogo de impresión; elige «Guardar como PDF».</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    @@media print {
        /* Ocultar todo excepto el calendario */
        body > *,
        .sb-nav-fixed .sb-topnav,
        .sb-nav-fixed #layoutSidenav #layoutSidenav_nav,
        .sb-nav-fixed #layoutSidenav #layoutSidenav_content > nav,
        .no-print,
        .breadcrumb,
        h1.mt-4,
        #paginaCalendario > .row > .col-lg-9 > .card:first-of-type,
        #panelVacio {
            display: none !important;
        }
        #panelCalendario {
            display: block !important;
        }
        .card {
            border: none !important;
            box-shadow: none !important;
        }
        .card-header {
            background-color: #1E3A8A !important;
            color: white !important;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }
        .table-dark th {
            background-color: #1E3A8A !important;
            color: white !important;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }
        .table-striped > tbody > tr:nth-of-type(odd) > * {
            background-color: #f8f9fa !important;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }
        @@page {
            margin: 1.5cm;
            size: landscape;
        }
    }
</style>

<script>
    const urlCultos          = '@Url.Action("ObtenerCultos",       "Calendario")';
    const urlGenerar         = '@Url.Action("GenerarCalendario",   "Calendario")';
    const urlExportarExcel   = '@Url.Action("ExportarExcel",       "Calendario")';
    const dias               = ['', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'];

    let requestActual = null;  // guarda el último request para exportar

    $(document).ready(function () {
        // Fecha de hoy por defecto
        const hoy = new Date();
        const yyyy = hoy.getFullYear();
        const mm   = String(hoy.getMonth() + 1).padStart(2, '0');
        const dd   = String(hoy.getDate()).padStart(2, '0');
        $('#txtFechaInicio').val(`${yyyy}-${mm}-${dd}`);

        // Cargar cultos
        $.get(urlCultos, function (res) {
            if (!res.success) return;
            const cbo = $('#cboCulto');
            (res.data || []).forEach(c => {
                cbo.append($('<option>').val(c.id_culto).text(`${c.nombre} — ${dias[c.dia_semana] || ''}`));
            });
        });
    });

    function obtenerRequest() {
        const idCulto = parseInt($('#cboCulto').val());
        if (!idCulto) {
            Swal.fire({ icon: 'warning', title: 'Falta seleccionar el culto', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
            return null;
        }
        return {
            idCulto:         idCulto,
            periodicidad:    $('input[name=periodicidad]:checked').val(),
            tipoCalendario:  parseInt($('input[name=tipoCalendario]:checked').val()),
            fechaInicio:     $('#txtFechaInicio').val()
        };
    }

    function generarCalendario() {
        const req = obtenerRequest();
        if (!req) return;
        requestActual = req;

        const btn = $('#btnGenerar');
        btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Generando…');

        $.ajax({
            url: urlGenerar,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(req),
            success: function (res) {
                btn.prop('disabled', false).html('<i class="fas fa-calendar-check me-1"></i> Generar calendario');
                if (!res.success) {
                    $('#panelCalendario').addClass('d-none');
                    $('#panelVacio').removeClass('d-none');
                    $('#msgVacio').text(res.mensaje);
                    return;
                }
                $('#panelVacio').addClass('d-none');
                renderCalendario(res.data);
                $('#panelCalendario').removeClass('d-none');
            },
            error: function () {
                btn.prop('disabled', false).html('<i class="fas fa-calendar-check me-1"></i> Generar calendario');
                Swal.fire('Error', 'No se pudo generar el calendario.', 'error');
            }
        });
    }

    function renderCalendario(cal) {
        const tipoLabel = cal.tipoCalendario === 2 ? 'Alabanza' : 'Servidores';
        const iconoCal  = cal.tipoCalendario === 2
            ? '<i class="fas fa-music me-2 text-success"></i>'
            : '<i class="fas fa-users me-2 text-primary"></i>';

        $('#lblTituloCalendario').html(`${iconoCal}Calendario de ${tipoLabel} — ${cal.nombreCulto}`);

        const fi = formatFecha(cal.fechaInicio);
        const ff = formatFecha(cal.fechaFin);
        const perLabel = { semanal: 'Semanal (4 semanas)', mensual: 'Mensual (1 mes)', trimestral: 'Trimestral (3 meses)' };
        $('#subtituloCalendario').html(`Período: <strong>${fi}</strong> – <strong>${ff}</strong> &nbsp;|&nbsp; ${perLabel[cal.periodicidad] || cal.periodicidad}`);

        // Cabecera
        const roles = cal.roles || [];
        let thHtml = '<tr><th>Fecha</th><th>Día</th>';
        roles.forEach(r => { thHtml += `<th>${escHtml(r)}</th>`; });
        thHtml += '</tr>';
        $('#theadCalendario').html(thHtml);

        // Filas
        let tbHtml = '';
        (cal.entradas || []).forEach(e => {
            tbHtml += `<tr><td class="text-nowrap">${formatFecha(e.fecha)}</td><td class="text-capitalize">${escHtml(e.diaSemana)}</td>`;
            roles.forEach(r => {
                const personas = (e.asignaciones && e.asignaciones[r]) ? e.asignaciones[r] : [];
                const celda = personas.length
                    ? personas.map(p => p === 'Sin asignar'
                        ? `<span class="badge bg-secondary">Sin asignar</span>`
                        : escHtml(p)).join('<br>')
                    : '<span class="badge bg-secondary">Sin asignar</span>';
                tbHtml += `<td>${celda}</td>`;
            });
            tbHtml += '</tr>';
        });
        $('#tbodyCalendario').html(tbHtml);
    }

    async function exportarExcel() {
        if (!requestActual) { Swal.fire({ icon: 'warning', title: 'Genera primero el calendario.', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 }); return; }

        try {
            const resp = await fetch(urlExportarExcel, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestActual)
            });
            if (!resp.ok) { Swal.fire('Error', 'No se pudo generar el Excel.', 'error'); return; }

            const blob = await resp.blob();
            const cd   = resp.headers.get('Content-Disposition') || '';
            const match = cd.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/);
            const nombre = match ? match[1].replace(/['"]/g, '') : 'Calendario.xlsx';

            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = nombre;
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
        } catch {
            Swal.fire('Error', 'No se pudo descargar el archivo.', 'error');
        }
    }

    function exportarPdf() {
        if (!requestActual) { Swal.fire({ icon: 'warning', title: 'Genera primero el calendario.', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 }); return; }
        window.print();
    }

    function formatFecha(iso) {
        if (!iso) return '';
        const d = new Date(iso);
        if (isNaN(d)) return iso;
        return d.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    function escHtml(str) {
        if (!str) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
</script>
}
