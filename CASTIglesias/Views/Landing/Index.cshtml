@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Congrega CRM — Software de Gestión para Iglesias</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary:      #1E3A8A;
            --primary-dark: #0D1B3D;
            --accent:       #3B82F6;
            --teal:         #00BFA5;
            --amber:        #F59E0B;
            --text:         #1F2937;
            --text-light:   #6B7280;
            --bg-light:     #F0F4FF;
        }
        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', sans-serif; color: var(--text); margin: 0; }

        /* ── NAVBAR ── */
        #mainNav {
            background: rgba(13, 27, 61, 0.96);
            backdrop-filter: blur(12px);
            transition: padding 0.3s ease, box-shadow 0.3s ease;
            padding: 14px 0;
        }
        #mainNav.scrolled {
            padding: 8px 0;
            box-shadow: 0 4px 24px rgba(0,0,0,0.35);
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.35rem;
            letter-spacing: -0.5px;
            color: white !important;
        }
        .navbar-brand span { color: var(--teal); }
        .nav-link {
            font-weight: 500;
            color: rgba(255,255,255,0.85) !important;
            transition: color 0.2s;
            padding: 6px 14px !important;
        }
        .nav-link:hover { color: var(--teal) !important; }
        .btn-nav-login {
            background: var(--teal);
            color: white !important;
            border-radius: 8px;
            padding: 8px 22px;
            font-weight: 600;
            font-size: 0.92rem;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-nav-login:hover { background: #009e89; transform: translateY(-1px); }

        /* ── HERO ── */
        .hero-section {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 55%, #1e50d8 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 100px 0 70px;
            position: relative;
            overflow: hidden;
        }
        .hero-section::before {
            content: '';
            position: absolute; top: -40%; right: -15%;
            width: 700px; height: 700px;
            background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);
            border-radius: 50%; pointer-events: none;
        }
        .hero-section::after {
            content: '';
            position: absolute; bottom: -30%; left: -10%;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(0,191,165,0.08) 0%, transparent 70%);
            border-radius: 50%; pointer-events: none;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(0,191,165,0.13);
            border: 1px solid rgba(0,191,165,0.35);
            color: var(--teal);
            border-radius: 20px;
            padding: 6px 16px;
            font-size: 0.83rem;
            font-weight: 600;
            margin-bottom: 1.4rem;
        }
        .hero-title {
            font-size: 3rem;
            font-weight: 800;
            color: white;
            line-height: 1.15;
            margin-bottom: 1.2rem;
        }
        .hero-title span { color: var(--teal); }
        .hero-subtitle {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.78);
            line-height: 1.65;
            margin-bottom: 2.2rem;
            max-width: 480px;
        }

        /* ── CAROUSEL MOCKUP ── */
        .carousel-mockup {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(0,0,0,0.45);
        }
        .mockup-topbar {
            background: rgba(0,0,0,0.32);
            padding: 10px 16px;
            display: flex;
            align-items: center;
            gap: 7px;
        }
        .mockup-dot { width: 11px; height: 11px; border-radius: 50%; }
        .mockup-topbar-title {
            color: rgba(255,255,255,0.55);
            font-size: 0.78rem;
            margin-left: 8px;
            font-weight: 500;
        }
        .carousel-inner.mockup-body {
            padding: 24px;
            min-height: 370px;
        }
        .carousel-item-inner { min-height: 320px; }
        .slide-icon-box {
            width: 58px; height: 58px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 14px;
        }
        .slide-title { color: white; font-size: 1.35rem; font-weight: 700; margin-bottom: 6px; }
        .slide-desc  { color: rgba(255,255,255,0.68); font-size: 0.92rem; margin-bottom: 14px; }
        .slide-feature {
            display: flex; align-items: center; gap: 10px;
            color: rgba(255,255,255,0.82); font-size: 0.86rem; margin-bottom: 7px;
        }
        .slide-feature i { color: var(--teal); flex-shrink: 0; }
        .mockup-kpi-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 16px;
        }
        .mockup-kpi {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px; padding: 12px 14px;
        }
        .mockup-kpi .kpi-label { color: rgba(255,255,255,0.45); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }
        .mockup-kpi .kpi-value { color: white; font-size: 1.3rem; font-weight: 700; line-height: 1.2; }
        .carousel-indicators button { width: 8px; height: 8px; border-radius: 50%; }
        .carousel-control-prev,
        .carousel-control-next {
            width: 38px; height: 38px; top: 50%; transform: translateY(-50%);
            background: rgba(255,255,255,0.14); border-radius: 50%;
        }

        /* ── STATS BAND ── */
        .stats-band { background: white; padding: 42px 0; border-bottom: 1px solid #E9ECF3; }
        .stat-number { font-size: 2.2rem; font-weight: 800; color: var(--primary); line-height: 1; }
        .stat-label  { color: var(--text-light); font-size: 0.88rem; margin-top: 4px; }

        /* ── SECTION HEADERS ── */
        .section-badge {
            display: inline-block;
            background: rgba(30,58,138,0.08);
            color: var(--primary);
            border-radius: 20px;
            padding: 4px 16px;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 12px;
        }
        .section-title { font-size: 2rem; font-weight: 800; color: var(--text); }
        .section-subtitle { color: var(--text-light); font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.65; }

        /* ── FEATURE CARDS ── */
        .feature-card {
            background: white;
            border-radius: 16px;
            padding: 28px 24px;
            border: 1.5px solid #E9ECF3;
            transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
            height: 100%;
        }
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 44px rgba(30,58,138,0.1);
            border-color: var(--accent);
        }
        .feature-icon {
            width: 54px; height: 54px; border-radius: 13px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; margin-bottom: 16px;
        }
        .feature-card h5 { font-weight: 700; font-size: 1.03rem; margin-bottom: 8px; }
        .feature-card p  { color: var(--text-light); font-size: 0.9rem; line-height: 1.6; margin: 0; }

        /* ── PRICING ── */
        .pricing-section { background: var(--bg-light); }
        .pricing-card {
            background: white;
            border-radius: 20px;
            padding: 36px 30px;
            border: 2px solid #E9ECF3;
            transition: border-color 0.25s ease, box-shadow 0.25s ease;
            position: relative;
            height: 100%;
        }
        .pricing-card.popular {
            border-color: var(--primary);
            transform: scale(1.03);
            box-shadow: 0 24px 60px rgba(30,58,138,0.18);
        }
        .pricing-card:not(.popular):hover {
            border-color: var(--accent);
            box-shadow: 0 10px 30px rgba(30,58,138,0.08);
        }
        .popular-badge {
            position: absolute; top: -15px; left: 50%; transform: translateX(-50%);
            background: var(--primary); color: white;
            border-radius: 20px; padding: 4px 20px;
            font-size: 0.78rem; font-weight: 700; white-space: nowrap;
        }
        .plan-name  { font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
        .plan-price { font-size: 2.8rem; font-weight: 800; color: var(--text); line-height: 1; }
        .plan-price sup    { font-size: 1.15rem; font-weight: 700; vertical-align: super; }
        .plan-price .period{ font-size: 0.88rem; font-weight: 400; color: var(--text-light); }
        .plan-desc  { color: var(--text-light); font-size: 0.87rem; margin: 12px 0 18px; line-height: 1.55; }
        .plan-feature {
            display: flex; align-items: flex-start; gap: 10px;
            font-size: 0.89rem; margin-bottom: 9px; color: var(--text);
        }
        .plan-feature i { color: var(--teal); margin-top: 2px; flex-shrink: 0; }
        .btn-plan {
            width: 100%; border-radius: 10px;
            padding: 12px; font-weight: 600; font-size: 0.94rem;
            margin-top: 22px; transition: all 0.2s; text-decoration: none;
            display: inline-block; text-align: center;
        }
        .btn-plan-primary { background: var(--primary); color: white; border: 2px solid var(--primary); }
        .btn-plan-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); color: white; }
        .btn-plan-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }
        .btn-plan-outline:hover { background: var(--primary); color: white; }

        /* ── CONTACT ── */
        .contact-info-icon {
            width: 46px; height: 46px;
            background: rgba(30,58,138,0.07);
            border-radius: 11px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .contact-card {
            background: white;
            border-radius: 20px; padding: 40px;
            box-shadow: 0 12px 44px rgba(0,0,0,0.07);
            border: 1.5px solid #E9ECF3;
        }
        .form-label { font-size: 0.88rem; font-weight: 600; }
        .form-control, .form-select {
            border-radius: 8px; border: 1.5px solid #DDE3EE;
            padding: 10px 14px; font-size: 0.91rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.14);
        }
        .btn-contact {
            background: var(--primary); color: white; border: none;
            border-radius: 10px; padding: 13px 34px;
            font-weight: 600; font-size: 0.96rem;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-contact:hover { background: var(--primary-dark); transform: translateY(-1px); }

        /* ── FOOTER ── */
        .site-footer {
            background: var(--primary-dark);
            color: rgba(255,255,255,0.65);
            padding: 50px 0 22px;
        }
        .footer-brand-text { color: white; font-weight: 800; font-size: 1.2rem; }
        .footer-brand-text span { color: var(--teal); }
        .site-footer a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
        .site-footer a:hover { color: var(--teal); }
        .footer-divider { border-color: rgba(255,255,255,0.1); margin: 28px 0 18px; }

        /* ── RESPONSIVE ── */
        @@media (max-width: 991px) {
            .hero-title { font-size: 2.2rem; }
            .pricing-card.popular { transform: none; }
            .hero-subtitle { max-width: 100%; }
        }
        @@media (max-width: 575px) {
            .hero-title { font-size: 1.85rem; }
            .contact-card { padding: 24px 18px; }
        }
    </style>
</head>
<body>

<!-- ═══════════════ NAVBAR ═══════════════ -->
<nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand" href="#inicio">
            <i class="fas fa-church me-2"></i>Congrega <span>CRM</span>
        </a>
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMenu">
            <ul class="navbar-nav mx-auto gap-1">
                <li class="nav-item"><a class="nav-link" href="#inicio">Inicio</a></li>
                <li class="nav-item"><a class="nav-link" href="#caracteristicas">Características</a></li>
                <li class="nav-item"><a class="nav-link" href="#precios">Precios</a></li>
                <li class="nav-item"><a class="nav-link" href="#contacto">Contacto</a></li>
            </ul>
            <a href="/Login" class="btn btn-nav-login ms-lg-3">
                <i class="fas fa-sign-in-alt me-2"></i>Iniciar sesión
            </a>
        </div>
    </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="inicio" class="hero-section">
    <div class="container" style="position:relative;z-index:1;">
        <div class="row align-items-center g-5">
            <!-- Texto -->
            <div class="col-lg-5" data-aos="fade-right">
                <div class="hero-badge">
                    <i class="fas fa-star-of-david"></i> Software diseñado para iglesias
                </div>
                <h1 class="hero-title">
                    Gestiona tu iglesia de forma <span>inteligente</span>
                </h1>
                <p class="hero-subtitle">
                    Congrega es el CRM pensado para comunidades de fe. Controla congregantes,
                    grupos, finanzas, asistencia y mucho más desde una sola plataforma.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Login" class="btn btn-lg px-4 py-3"
                       style="background:var(--teal);color:white;border-radius:10px;font-weight:700;">
                        <i class="fas fa-sign-in-alt me-2"></i>Acceder a la app
                    </a>
                    <a href="#caracteristicas" class="btn btn-outline-light btn-lg px-4 py-3"
                       style="border-radius:10px;font-weight:600;">
                        Ver características
                    </a>
                </div>
            </div>

            <!-- Carousel mockup -->
            <div class="col-lg-7">
                <div class="carousel-mockup">
                    <div class="mockup-topbar">
                        <div class="mockup-dot" style="background:#FF5F57;"></div>
                        <div class="mockup-dot" style="background:#FFBD2E;"></div>
                        <div class="mockup-dot" style="background:#28CA41;"></div>
                        <span class="mockup-topbar-title">Congrega CRM — Panel de administración</span>
                    </div>
                    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4500">
                        <div class="carousel-indicators" style="bottom:-2px;">
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="4"></button>
                        </div>
                        <div class="carousel-inner mockup-body">

                            <!-- Slide 1 — Dashboard -->
                            <div class="carousel-item active">
                                <div class="carousel-item-inner">
                                    <div class="slide-icon-box" style="background:rgba(59,130,246,0.18);">
                                        <i class="fas fa-chart-line" style="color:#3B82F6;"></i>
                                    </div>
                                    <div class="slide-title">Dashboard en tiempo real</div>
                                    <div class="slide-desc">Visualiza el estado de tu iglesia de un vistazo con gráficas y KPIs siempre actualizados.</div>
                                    <div class="mockup-kpi-grid">
                                        <div class="mockup-kpi">
                                            <div class="kpi-label">Miembros activos</div>
                                            <div class="kpi-value" style="color:#3B82F6;">248</div>
                                        </div>
                                        <div class="mockup-kpi">
                                            <div class="kpi-label">Visitantes</div>
                                            <div class="kpi-value" style="color:#00BFA5;">34</div>
                                        </div>
                                        <div class="mockup-kpi">
                                            <div class="kpi-label">Diezmos (mes)</div>
                                            <div class="kpi-value" style="color:#F59E0B;">3.240 €</div>
                                        </div>
                                        <div class="mockup-kpi">
                                            <div class="kpi-label">Asistencia (dom.)</div>
                                            <div class="kpi-value" style="color:#10B981;">192</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Slide 2 — Congregantes -->
                            <div class="carousel-item">
                                <div class="carousel-item-inner">
                                    <div class="slide-icon-box" style="background:rgba(0,191,165,0.18);">
                                        <i class="fas fa-users" style="color:#00BFA5;"></i>
                                    </div>
                                    <div class="slide-title">Gestión de congregantes</div>
                                    <div class="slide-desc">Registro completo de miembros, simpatizantes y visitantes con ficha detallada por persona.</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Datos personales, contacto y familia</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Estados: miembro, simpatizante, visitante, en proceso</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Búsqueda avanzada y filtros por sede</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Historial de cambios y observaciones</div>
                                </div>
                            </div>

                            <!-- Slide 3 — Grupos y Zonas -->
                            <div class="carousel-item">
                                <div class="carousel-item-inner">
                                    <div class="slide-icon-box" style="background:rgba(245,158,11,0.18);">
                                        <i class="fas fa-sitemap" style="color:#F59E0B;"></i>
                                    </div>
                                    <div class="slide-title">Grupos, Zonas y Ministerios</div>
                                    <div class="slide-desc">Organiza tu comunidad con total flexibilidad según la estructura de tu iglesia.</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Creación de grupos por zona o ministerio</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Asignación de líderes y encargados</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Listados de miembros por agrupación</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Vista de estructura jerárquica</div>
                                </div>
                            </div>

                            <!-- Slide 4 — Economía -->
                            <div class="carousel-item">
                                <div class="carousel-item-inner">
                                    <div class="slide-icon-box" style="background:rgba(16,185,129,0.18);">
                                        <i class="fas fa-hand-holding-usd" style="color:#10B981;"></i>
                                    </div>
                                    <div class="slide-title">Control económico</div>
                                    <div class="slide-desc">Registra y controla diezmos, ofrendas y conceptos financieros con gráficas detalladas.</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Diezmos y ofrendas por miembro y concepto</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Gráficas comparativas mensuales y anuales</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Exportación de informes a Excel</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Configuración de conceptos personalizados</div>
                                </div>
                            </div>

                            <!-- Slide 5 — Seguimiento -->
                            <div class="carousel-item">
                                <div class="carousel-item-inner">
                                    <div class="slide-icon-box" style="background:rgba(139,92,246,0.18);">
                                        <i class="fas fa-clipboard-list" style="color:#8B5CF6;"></i>
                                    </div>
                                    <div class="slide-title">Seguimiento pastoral</div>
                                    <div class="slide-desc">Acompañamiento integral con registro de visitas, llamadas y consejerías por congregante.</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Registro de visitas, llamadas y consejerías</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Persona a cargo de cada seguimiento</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Historial completo por congregante</div>
                                    <div class="slide-feature"><i class="fas fa-check-circle"></i> Notas y observaciones privadas</div>
                                </div>
                            </div>
                        </div>

                        <button class="carousel-control-prev" type="button"
                                data-bs-target="#heroCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button"
                                data-bs-target="#heroCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════ STATS BAND ═══════════════ -->
<div class="stats-band">
    <div class="container">
        <div class="row g-4 text-center justify-content-center">
            <div class="col-6 col-md-3">
                <div class="stat-number">6+</div>
                <div class="stat-label">Módulos integrados</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-number">Multi-sede</div>
                <div class="stat-label">Gestión centralizada</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-number">100%</div>
                <div class="stat-label">En la nube</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-number">24/7</div>
                <div class="stat-label">Disponibilidad</div>
            </div>
        </div>
    </div>
