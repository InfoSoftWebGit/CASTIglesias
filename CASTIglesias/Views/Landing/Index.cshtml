<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    // Navbar scroll effect
    window.addEventListener('scroll', function () {
        document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 60);
    });

    // Close mobile navbar on anchor link click
    document.querySelectorAll('#navbarMenu a[href^="#"]').forEach(function (link) {
        link.addEventListener('click', function () {
            var collapse = document.getElementById('navbarMenu');
            if (collapse.classList.contains('show')) {
                bootstrap.Collapse.getOrCreateInstance(collapse).hide();
            }
        });
    });

    // Contact form
    function enviarContacto(e) {
        e.preventDefault();

        var campos = ['cNombre','cApellidos','cEmail','cPais','cCiudad','cIglesia','cMensaje'];
        for (var i = 0; i < campos.length; i++) {
            if (!document.getElementById(campos[i]).value.trim()) {
                Swal.fire({ icon: 'warning', title: 'Campos requeridos', text: 'Por favor, completa todos los campos obligatorios.', confirmButtonColor: '#1E3A8A' });
                return;
            }
        }

        var payload = {
            nombre:    document.getElementById('cNombre').value.trim(),
            apellidos: document.getElementById('cApellidos').value.trim(),
            telefono:  document.getElementById('cTelefono').value.trim(),
            email:     document.getElementById('cEmail').value.trim(),
            pais:      document.getElementById('cPais').value.trim(),
            ciudad:    document.getElementById('cCiudad').value.trim(),
            iglesia:   document.getElementById('cIglesia').value.trim(),
            mensaje:   document.getElementById('cMensaje').value.trim()
        };

        $.ajax({
            url: '/Landing/EnviarContacto',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(payload),
            success: function (res) {
                if (res.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Mensaje enviado!',
                        text: 'Nos pondremos en contacto contigo en menos de 24 horas.',
                        confirmButtonColor: '#1E3A8A'
                    });
                    document.getElementById('frmContacto').reset();
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: res.mensaje || 'No se pudo enviar.', confirmButtonColor: '#1E3A8A' });
                }
            },
            error: function () {
                Swal.fire({ icon: 'error', title: 'Error de conexión', text: 'No se pudo enviar el mensaje. Inténtalo de nuevo.', confirmButtonColor: '#1E3A8A' });
            }
        });
    }
</script>
