                    <form id="frmContacto" onsubmit="enviarContacto(event)" novalidate>
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label">Nombre <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="cNombre" placeholder="Tu nombre" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Apellidos <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="cApellidos" placeholder="Tus apellidos" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Teléfono</label>
                                <input type="tel" class="form-control" id="cTelefono" placeholder="+34 600 000 000" />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Correo electrónico <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="cEmail" placeholder="correo@ejemplo.com" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">País <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="cPais" placeholder="España" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Ciudad <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="cCiudad" placeholder="Madrid" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Nombre de la iglesia <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="cIglesia" placeholder="Iglesia..." required />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Mensaje <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="cMensaje" rows="4"
                                          placeholder="Cuéntanos sobre tu iglesia y qué módulos te interesan..." required></textarea>
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="submit" class="btn btn-contact">
                                    <i class="fas fa-paper-plane me-2"></i>Enviar mensaje
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

