@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Congrega CRM — Software de Gestión para Iglesias</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary:      #1E3A8A;
            --primary-dark: #0D1B3D;
            --accent:       #3B82F6;
            --teal:         #00BFA5;
            --amber:        #F59E0B;
            --text:         #1F2937;
            --text-light:   #6B7280;
            --bg-light:     #F0F4FF;
        }
        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', sans-serif; color: var(--text); margin: 0; }

        /* ── NAVBAR ── */
        #mainNav {
            background: rgba(13, 27, 61, 0.96);
            backdrop-filter: blur(12px);
            transition: padding 0.3s ease, box-shadow 0.3s ease;
            padding: 14px 0;
        }
        #mainNav.scrolled {
            padding: 8px 0;
            box-shadow: 0 4px 24px rgba(0,0,0,0.35);
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.35rem;
            letter-spacing: -0.5px;
            color: white !important;
        }
        .navbar-brand span { color: var(--teal); }
        .nav-link {
            font-weight: 500;
            color: rgba(255,255,255,0.85) !important;
            transition: color 0.2s;
            padding: 6px 14px !important;
        }
        .nav-link:hover { color: var(--teal) !important; }
        .btn-nav-login {
            background: var(--teal);
            color: white !important;
            border-radius: 8px;
            padding: 8px 22px;
            font-weight: 600;
            font-size: 0.92rem;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-nav-login:hover { background: #009e89; transform: translateY(-1px); }

        /* ── HERO ── */
        .hero-section {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 55%, #1e50d8 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 100px 0 70px;
            position: relative;
            overflow: hidden;
        }

        /* Floating animations */
        @@keyframes floatA {
            0%, 100% { transform: translateY(0px); }
            50%       { transform: translateY(-14px); }
        }
        @@keyframes floatB {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50%       { transform: translateY(10px) rotate(1.5deg); }
        }
        @@keyframes floatC {
            0%, 100% { transform: translateY(0px) translateX(0px); }
            33%       { transform: translateY(-8px) translateX(5px); }
            66%       { transform: translateY(5px) translateX(-4px); }
        }
        @@keyframes spinSlow {
            from { transform: rotate(0deg); }
            to   { transform: rotate(360deg); }
        }

        /* Glassmorphism base */
        .glass {
            background: rgba(255,255,255,0.07);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255,255,255,0.13);
            box-shadow: 0 8px 32px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        /* Hero visual container */
        .hero-visual {
            position: relative;
            height: 500px;
        }

        /* Main dashboard glass card */
        .hero-main-card {
            position: absolute;
            top: 15px;
            left: 30px;
            width: 340px;
            border-radius: 20px;
            padding: 22px 24px;
            animation: floatB 7s ease-in-out infinite;
            z-index: 3;
        }
        .hmc-header {
            display: flex; align-items: center; gap: 10px; margin-bottom: 18px;
        }
        .hmc-icon {
            width: 36px; height: 36px; border-radius: 9px;
            background: rgba(59,130,246,0.22);
            display: flex; align-items: center; justify-content: center;
            color: #60A5FA; font-size: 0.88rem;
        }
        .hmc-title { color: white; font-weight: 700; font-size: 0.92rem; }
        .hmc-sub   { color: rgba(255,255,255,0.4); font-size: 0.7rem; margin-top: 1px; }

        /* KPI 2-col grid inside main card */
        .kpi-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px;
        }
        .kpi-tile {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 11px;
            padding: 10px 12px;
        }
        .kpi-tile .kt-lbl { color: rgba(255,255,255,0.38); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
        .kpi-tile .kt-val { color: white; font-size: 1.2rem; font-weight: 800; line-height: 1.25; }
        .kpi-tile .kt-badge {
            font-size: 0.63rem; font-weight: 700; padding: 2px 7px;
            border-radius: 10px; display: inline-block; margin-top: 4px;
        }
        .badge-green { background: rgba(16,185,129,0.2); color: #34D399; }
        .badge-blue  { background: rgba(59,130,246,0.2); color: #60A5FA; }
        .badge-amber { background: rgba(245,158,11,0.2); color: #FCD34D; }

        /* Mini bar chart */
        .mini-bars {
            display: flex; align-items: flex-end; gap: 4px; height: 48px;
        }
        .mini-bars .mb {
            flex: 1; border-radius: 3px 3px 0 0;
            background: rgba(59,130,246,0.28);
            transition: background 0.2s;
        }
        .mini-bars .mb.hi { background: rgba(96,165,250,0.8); }
        .mini-bars-label {
            color: rgba(255,255,255,0.35); font-size: 0.65rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; margin-top: 12px;
        }

        /* Floating small cards */
        .hero-float {
            position: absolute;
            border-radius: 14px;
            padding: 13px 16px;
            min-width: 158px;
            z-index: 4;
        }
        .hf-icon {
            width: 30px; height: 30px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.78rem; margin-bottom: 8px;
        }
        .hf-lbl   { color: rgba(255,255,255,0.42); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }
        .hf-val   { color: white; font-size: 1.08rem; font-weight: 800; line-height: 1.2; }
        .hf-trend { font-size: 0.67rem; font-weight: 600; margin-top: 3px; }

        /* Decorative rings & dots */
        .deco-ring {
            position: absolute; border-radius: 50%; pointer-events: none;
            border: 1px solid rgba(255,255,255,0.07);
        }
        .deco-dot {
            position: absolute; border-radius: 50%; pointer-events: none;
            background: rgba(255,255,255,0.14);
        }
        .dot-grid {
            position: absolute; pointer-events: none;
            display: grid; grid-template-columns: repeat(9,1fr); gap: 13px;
            opacity: 0.12;
        }
        .dot-grid span { width: 3px; height: 3px; background: white; border-radius: 50%; display: block; }

        /* Hero text elements */
        .hero-badge {
            display: inline-flex; align-items: center; gap: 7px;
            background: rgba(0,191,165,0.13); border: 1px solid rgba(0,191,165,0.35);
            color: var(--teal); border-radius: 20px; padding: 6px 16px;
            font-size: 0.83rem; font-weight: 600; margin-bottom: 1.4rem;
        }
        .hero-title {
            font-size: 3rem; font-weight: 800; color: white;
            line-height: 1.15; margin-bottom: 1.2rem;
        }
        .hero-title span { color: var(--teal); }
        .hero-subtitle {
            font-size: 1.05rem; color: rgba(255,255,255,0.75);
            line-height: 1.7; margin-bottom: 2.2rem; max-width: 460px;
        }

        /* ── STATS BAND ── */
        .stats-band { background: white; padding: 42px 0; border-bottom: 1px solid #E9ECF3; }
        .stat-number { font-size: 2.2rem; font-weight: 800; color: var(--primary); line-height: 1; }
        .stat-label  { color: var(--text-light); font-size: 0.88rem; margin-top: 4px; }

        /* ── SECTION HEADERS ── */
        .section-badge {
            display: inline-block;
            background: rgba(30,58,138,0.08); color: var(--primary);
            border-radius: 20px; padding: 4px 16px;
            font-size: 0.8rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 12px;
        }
        .section-title    { font-size: 2rem; font-weight: 800; color: var(--text); }
        .section-subtitle { color: var(--text-light); font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.65; }

        /* ── FEATURE CARDS (overview) ── */
        .feature-card {
            background: white; border-radius: 16px; padding: 28px 24px;
            border: 1.5px solid #E9ECF3;
            transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
            height: 100%;
        }
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 44px rgba(30,58,138,0.1);
            border-color: var(--accent);
        }
        .feature-icon {
            width: 54px; height: 54px; border-radius: 13px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; margin-bottom: 16px;
        }
        .feature-card h5 { font-weight: 700; font-size: 1.03rem; margin-bottom: 8px; }
        .feature-card p  { color: var(--text-light); font-size: 0.9rem; line-height: 1.6; margin: 0; }

        /* ── CÓMO FUNCIONA ── */
        .how-section { background: var(--bg-light); }
        .step-wrap { position: relative; }
        .step-connector {
            position: absolute; top: 26px;
            left: calc(50% + 30px); width: calc(100% - 60px);
            height: 2px;
            background: linear-gradient(to right, var(--primary), var(--accent));
            opacity: 0.2;
        }
        .step-num {
            width: 52px; height: 52px; border-radius: 50%;
            background: var(--primary); color: white;
            font-size: 1.2rem; font-weight: 800;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 18px; position: relative; z-index: 1;
            box-shadow: 0 6px 20px rgba(30,58,138,0.35);
        }
        .step-card { text-align: center; padding: 8px 16px 0; }
        .step-card h5 { font-weight: 700; font-size: 1.02rem; margin-bottom: 8px; color: var(--text); }
        .step-card p  { color: var(--text-light); font-size: 0.89rem; line-height: 1.6; margin: 0; }
        .step-icon-ring {
            width: 70px; height: 70px; border-radius: 50%;
            border: 2px dashed rgba(30,58,138,0.2);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px;
        }
        .step-icon-ring i { font-size: 1.5rem; color: var(--primary); }

        /* ── ALTERNATING SECTIONS ── */
        .alt-section { padding: 86px 0; }
        .alt-section.bg-alt { background: var(--bg-light); }

        /* Module badge in alt sections */
        .mod-badge {
            display: inline-flex; align-items: center; gap: 7px;
            border-radius: 20px; padding: 5px 15px;
            font-size: 0.79rem; font-weight: 700; margin-bottom: 14px;
        }
        .alt-title    { font-size: 1.75rem; font-weight: 800; color: var(--text); line-height: 1.25; margin-bottom: 12px; }
        .alt-desc     { color: var(--text-light); font-size: 0.96rem; line-height: 1.7; margin-bottom: 24px; }
        .alt-feature  {
            display: flex; align-items: flex-start; gap: 11px;
            margin-bottom: 13px; font-size: 0.92rem; color: var(--text);
        }
        .alt-feature-icon {
            width: 28px; height: 28px; border-radius: 7px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.75rem; margin-top: 1px;
        }
        .alt-feature strong { display: block; font-weight: 600; font-size: 0.9rem; }
        .alt-feature span   { color: var(--text-light); font-size: 0.85rem; line-height: 1.5; }

        /* App mockup panels in alt sections */
        .app-panel {
            border-radius: 18px; overflow: hidden;
            box-shadow: 0 28px 70px rgba(30,58,138,0.16);
            border: 1.5px solid #E2E8F4;
        }
        .ap-topbar {
            padding: 10px 16px;
            display: flex; align-items: center; gap: 6px;
        }
        .ap-dot { width: 10px; height: 10px; border-radius: 50%; opacity: 0.8; }
        .ap-title { font-size: 0.75rem; font-weight: 500; margin-left: 7px; opacity: 0.65; }
        .ap-body { background: #FAFBFF; padding: 20px; }

        /* Member list rows */
        .member-row {
            display: flex; align-items: center; gap: 12px;
            padding: 9px 12px; border-radius: 10px; background: white;
            border: 1px solid #EEF1F8; margin-bottom: 8px;
        }
        .member-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.82rem; font-weight: 700; color: white; flex-shrink: 0;
        }
        .member-name  { font-size: 0.88rem; font-weight: 600; color: var(--text); }
        .member-meta  { font-size: 0.76rem; color: var(--text-light); }
        .member-badge {
            margin-left: auto; font-size: 0.7rem; font-weight: 700;
            padding: 3px 9px; border-radius: 20px;
        }

        /* Finance rows */
        .fin-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 12px; border-radius: 9px; background: white;
            border: 1px solid #EEF1F8; margin-bottom: 7px;
        }
        .fin-icon { width: 30px; height: 30px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; flex-shrink: 0; }
        .fin-label { font-size: 0.85rem; font-weight: 600; color: var(--text); margin-left: 10px; }
        .fin-amount { font-size: 0.9rem; font-weight: 800; }
        .fin-bars {
            display: flex; align-items: flex-end; gap: 5px; height: 55px; margin-top: 14px; padding: 0 4px;
        }
        .fin-bar { flex: 1; border-radius: 4px 4px 0 0; }

        /* Timeline for seguimiento */
        .timeline-item {
            display: flex; gap: 12px; margin-bottom: 14px; align-items: flex-start;
        }
        .tl-line-wrap { display: flex; flex-direction: column; align-items: center; }
        .tl-dot {
            width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.75rem; color: white;
        }
        .tl-line { width: 2px; flex: 1; min-height: 20px; background: #E9ECF3; margin-top: 4px; }
        .tl-content { padding-top: 4px; }
        .tl-type   { font-size: 0.8rem; font-weight: 700; color: var(--text); }
        .tl-person { font-size: 0.75rem; color: var(--text-light); margin-top: 1px; }
        .tl-date   { font-size: 0.7rem; color: var(--text-light); margin-top: 2px; }

        /* ── TESTIMONIALS ── */
        .testimonial-section { background: var(--primary-dark); }
        .testimonial-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px; padding: 30px 26px; height: 100%;
            transition: background 0.25s ease, border-color 0.25s ease;
        }
        .testimonial-card:hover {
            background: rgba(255,255,255,0.09);
            border-color: rgba(255,255,255,0.18);
        }
        .t-stars { color: var(--amber); font-size: 0.88rem; margin-bottom: 14px; letter-spacing: 2px; }
        .t-quote {
            color: rgba(255,255,255,0.82); font-size: 0.95rem;
            line-height: 1.72; margin-bottom: 22px; font-style: italic;
        }
        .t-author { display: flex; align-items: center; gap: 12px; }
        .t-avatar {
            width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; font-weight: 800; color: white;
        }
        .t-name { color: white; font-weight: 700; font-size: 0.92rem; }
        .t-role { color: rgba(255,255,255,0.42); font-size: 0.78rem; margin-top: 2px; }

        /* ── PRICING ── */
        .pricing-section { background: var(--bg-light); }
        .pricing-card {
            background: white; border-radius: 20px; padding: 36px 30px;
            border: 2px solid #E9ECF3;
            transition: border-color 0.25s ease, box-shadow 0.25s ease;
            position: relative; height: 100%;
        }
        .pricing-card.popular {
            border-color: var(--primary);
            transform: scale(1.03);
            box-shadow: 0 24px 60px rgba(30,58,138,0.18);
        }
        .pricing-card:not(.popular):hover {
            border-color: var(--accent);
            box-shadow: 0 10px 30px rgba(30,58,138,0.08);
        }
        .popular-badge {
            position: absolute; top: -15px; left: 50%; transform: translateX(-50%);
            background: var(--primary); color: white;
            border-radius: 20px; padding: 4px 20px;
            font-size: 0.78rem; font-weight: 700; white-space: nowrap;
        }
        .plan-name  { font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
        .plan-price { font-size: 2.8rem; font-weight: 800; color: var(--text); line-height: 1; }
        .plan-price sup    { font-size: 1.15rem; font-weight: 700; vertical-align: super; }
        .plan-price .period{ font-size: 0.88rem; font-weight: 400; color: var(--text-light); }
        .plan-desc  { color: var(--text-light); font-size: 0.87rem; margin: 12px 0 18px; line-height: 1.55; }
        .plan-feature {
            display: flex; align-items: flex-start; gap: 10px;
            font-size: 0.89rem; margin-bottom: 9px; color: var(--text);
        }
        .plan-feature i { color: var(--teal); margin-top: 2px; flex-shrink: 0; }
        .btn-plan {
            width: 100%; border-radius: 10px; padding: 12px;
            font-weight: 600; font-size: 0.94rem;
            margin-top: 22px; transition: all 0.2s;
            text-decoration: none; display: inline-block; text-align: center;
        }
        .btn-plan-primary { background: var(--primary); color: white; border: 2px solid var(--primary); }
        .btn-plan-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); color: white; }
        .btn-plan-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }
        .btn-plan-outline:hover { background: var(--primary); color: white; }

        /* ── CONTACT ── */
        .contact-info-icon {
            width: 46px; height: 46px; background: rgba(30,58,138,0.07);
            border-radius: 11px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .contact-card {
            background: white; border-radius: 20px; padding: 40px;
            box-shadow: 0 12px 44px rgba(0,0,0,0.07); border: 1.5px solid #E9ECF3;
        }
        .form-label { font-size: 0.88rem; font-weight: 600; }
        .form-control, .form-select {
            border-radius: 8px; border: 1.5px solid #DDE3EE;
            padding: 10px 14px; font-size: 0.91rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.14);
        }
        .btn-contact {
            background: var(--primary); color: white; border: none;
            border-radius: 10px; padding: 13px 34px;
            font-weight: 600; font-size: 0.96rem;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-contact:hover { background: var(--primary-dark); transform: translateY(-1px); }

        /* ── FOOTER ── */
        .site-footer {
            background: var(--primary-dark);
            color: rgba(255,255,255,0.65); padding: 50px 0 22px;
        }
        .footer-brand-text { color: white; font-weight: 800; font-size: 1.2rem; }
        .footer-brand-text span { color: var(--teal); }
        .site-footer a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
        .site-footer a:hover { color: var(--teal); }
        .footer-divider { border-color: rgba(255,255,255,0.1); margin: 28px 0 18px; }

        /* ── CAROUSEL MOCKUP ── */
        .carousel-mockup {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(0,0,0,0.45);
        }
        .mockup-topbar {
            background: rgba(0,0,0,0.32);
            padding: 10px 16px;
            display: flex; align-items: center; gap: 7px;
        }
        .mockup-dot { width: 11px; height: 11px; border-radius: 50%; }
        .mockup-topbar-title {
            color: rgba(255,255,255,0.55); font-size: 0.78rem;
            margin-left: 8px; font-weight: 500;
        }
        .carousel-inner.mockup-body { padding: 24px; min-height: 370px; }
        .carousel-item-inner { min-height: 320px; }
        .slide-icon-box {
            width: 58px; height: 58px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; margin-bottom: 14px;
        }
        .slide-title { color: white; font-size: 1.35rem; font-weight: 700; margin-bottom: 6px; }
        .slide-desc  { color: rgba(255,255,255,0.68); font-size: 0.92rem; margin-bottom: 14px; }
        .slide-feature {
            display: flex; align-items: center; gap: 10px;
            color: rgba(255,255,255,0.82); font-size: 0.86rem; margin-bottom: 7px;
        }
        .slide-feature i { color: var(--teal); flex-shrink: 0; }
        .mockup-kpi-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 16px;
        }
        .mockup-kpi {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px; padding: 12px 14px;
        }
