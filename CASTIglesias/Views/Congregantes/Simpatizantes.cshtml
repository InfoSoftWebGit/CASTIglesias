@using System.Text.Json
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // 🔑 Uso de los ViewBag del controlador
    var loggedInSedeID = ViewBag.sedeID ?? 0;
    var loggedInSedeNombre = ViewBag.nombre_sede?.ToString() ?? "Sede Desconocida";
}
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="index.html">Resumen</a></li>
    <li class="breadcrumb-item active">Simpatizantes</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista de simpatizantes
    </div>

    <div class="table-responsive">
        <div class="row">
            @* <div class="col-12 mb-2">
                <button type="button" class="btn btn-success" onclick="abrirModalMiembros(null)">Añadir nuevo miembro</button>
            </div> *@
        </div>

        <hr />
        <table id="tablaMiembros" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Apellidos</th>
                    <th>Correo electrónico</th>
                    <th>Teléfono</th>
                    <th>Edad</th>
                    <th>Sexo</th>
                    <th>Sede</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalMiembros" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Datos del nuevo miembro</h1>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            @*--------------APARTADO DE INFORMACIÓN BÁSICA-------------------*@
            <div class="modal-body g-3">
                <input id="txtid" type="hidden" value="0" />
                <input id="txtID_sede" type="hidden" value="0" />

                <h5>Información principal</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtNombres" class="form-label">Nombres</label>
                        <input type="text" class="form-control" id="txtNombres" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtApellido" class="form-label">Apellido</label>
                        <input type="text" class="form-control" id="txtApellido" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtCorreo_electronico" class="form-label">Correo</label>
                        <input type="email" class="form-control" id="txtCorreo_electronico" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtTelefonoMovil" class="form-label">Teléfono móvil</label>
                        <input type="number" class="form-control" id="txtTelefonoMovil" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtTelefonoFijo" class="form-label">Teléfono fijo</label>
                        <input type="number" class="form-control" id="txtTelefonoFijo" autocomplete="off">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtEdad" class="form-label">Edad</label>
                        <input type="number" class="form-control" id="txtEdad" autocomplete="off">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboSexo" class="form-label">Sexo</label>
                        <select id="cboSexo" class="form-select">
                            <option value="" disabled selected>Selecciona un valor</option>
                            <option value="Hombre">Hombre</option>
                            <option value="Mujer">Mujer</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label"></label>
                        <input type="text" class="form-control" id="txtSede" hidden />
                    </div>
                </div>
                @*--------------FIN APARTADO DE INFORMACIÓN BÁSICA-------------------*@

                @*--------------APARTADO DE DIRECCIONES-------------------*@
                <hr />
                <h5>Dirección</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtDireccion" class="form-label">Dirección</label>
                        <input type="text" class="form-control" id="txtDireccion">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboProvincia" class="form-label">Provincia</label>
                        <select id="cboProvincia" class="form-select">
                            <option value="0" disabled selected>Selecciona una provincia</option>
                            @if (ViewBag.ListaProvincias != null)
                            {
                                foreach (var p in ViewBag.ListaProvincias)
                                {
                                    <option value="@p.idProvincia">@p.nombre_provincia</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboMunicipio" class="form-label">Municipio</label>
                        <select id="cboMunicipio" class="form-select">
                            <option value="" disabled selected>Selecciona un Municipio</option>
                            @* Las opciones se cargan dinámicamente por JS/AJAX *@
                        </select>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtCP" class="form-label">Código Postal</label>
                        <input type="number" class="form-control" id="txtCP">
                    </div>
                </div>
                <hr />
                @*--------------FIN APARTADO DE DIRECCIONES-------------------*@

                @*--------------APARTADO DE FECHAS-------------------*@

                <h5>Fechas Específicas</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtFechaLlegada" class="form-label">Fecha de Llegada a la Iglesia</label>
                        <input type="date" class="form-control" id="txtFechaLlegada">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtFechaCumpleanos" class="form-label">Fecha de Cumpleaños</label>
                        <input type="date" class="form-control" id="txtFechaCumpleanos">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtFechaBoda" class="form-label">Fecha de Boda</label>
                        <input type="date" class="form-control" id="txtFechaBoda">
                    </div>
                    <div class="col-12 mt-1">
                        <div class="form-check form-switch py-2 px-3 rounded" style="background:#e3f2fd;">
                            <input class="form-check-input" type="checkbox" role="switch" id="checkBautizado">
                            <label class="form-check-label fw-semibold text-primary" for="checkBautizado">Bautizado</label>
                        </div>
                    </div>
                    <div id="divBautismoFields" class="col-12" style="display:none;">
                        <div class="row mt-2">
                            <div class="col-sm-6 mb-3">
                                <label for="txtFechaBautismo" class="form-label">Fecha de Bautismo</label>
                                <input type="date" class="form-control" id="txtFechaBautismo">
                            </div>
                            <div class="col-sm-6 mb-3">
                                <label for="txtLugarBautismo" class="form-label">Lugar de bautismo</label>
                                <input type="text" class="form-control" id="txtLugarBautismo">
                            </div>
                        </div>
                    </div>
                </div>
                <hr />
                @*--------------FIN APARTADO DE FECHAS-------------------*@
                @*--------------APARTADO DE INFORMACIÓN ADICIONAL-------------------*@
                <h5>Información Adicional</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="cboPaisNacimiento" class="form-label">País de nacimiento</label>
                        <select id="cboPaisNacimiento" class="form-select">
                            <option value="">Selecciona un país</option>
                        </select>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="cboEstadoCivil" class="form-label">Estado civil</label>
                        <select id="cboEstadoCivil" class="form-select">
                            <option value="" disabled selected>Selecciona un valor</option>
                            <option value="Soltero/a">Soltero/a</option>
                            <option value="Casado/a">Casado/a</option>
                            <option value="Viudo/a">Viudo/a</option>
                            <option value="Divorciado/a">Divorciado/a</option>
                            <option value="Separado/a">Separado/a</option>
                            <option value="Unión de hecho/a">Unión de hecho/a</option>
                        </select>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="cboResponsable" class="form-label">Responsable</label>
                        <select class="form-select" id="cboResponsable">
                            <option value="">-- Sin responsable --</option>
                        </select>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtObservaciones" class="form-label">Observaciones</label>
                        <textarea class="form-control" id="txtObservaciones" rows="3" maxlength="200"></textarea>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtNumeroHijos" class="form-label">Número de hijos</label>
                        <input id="txtNumeroHijos" type="number" class="form-control" placeholder="Número de hijos" />
                    </div>
                </div>
                @*--------------FIN APARTADO DE INFORMACIÓN ADICIONAL-------------------*@

                @*--------------APARTADO DE FAMILIA-------------------*@
                <hr />
                <h5>Familia</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="cboGrupoFamiliar" class="form-label">Grupo familiar</label>
                        <select id="cboGrupoFamiliar" class="form-select">
                            <option value="">— Sin asignar —</option>
                        </select>
                    </div>
                    <div class="col-sm-6 mb-3" id="divInfoFamilia" style="display:none;">
                        <label class="form-label">Datos de la familia</label>
                        <div class="border rounded p-2 bg-light small">
                            <div><strong>Dirección:</strong> <span id="lblFamiliaDireccion">—</span></div>
                            <div><strong>Municipio:</strong> <span id="lblFamiliaMunicipio">—</span></div>
                            <div><strong>Provincia:</strong> <span id="lblFamiliaProvincia">—</span></div>
                            <div><strong>CP:</strong> <span id="lblFamiliaCP">—</span></div>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtRelacionCon" class="form-label">Relación con</label>
                        <div id="divRelacionCon" class="position-relative">
                            <input type="text" class="form-control" id="txtRelacionCon" autocomplete="off" placeholder="Escribe un nombre para buscar...">
                            <div id="dropdownRelacionCon" class="list-group position-absolute w-100 shadow" style="display:none; z-index:9999; max-height:200px; overflow-y:auto;"></div>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="cboTipoRelacionFamiliar" class="form-label">Rol en la familia</label>
                        <select id="cboTipoRelacionFamiliar" class="form-select">
                            <option value="">— Sin especificar —</option>
                            <optgroup label="1er grado">
                                <option value="Padre">Padre</option>
                                <option value="Madre">Madre</option>
                                <option value="Hijo">Hijo</option>
                                <option value="Hija">Hija</option>
                                <option value="Hermano">Hermano</option>
                                <option value="Hermana">Hermana</option>
                                <option value="Conyuge">Cónyuge</option>
                            </optgroup>
                            <optgroup label="2do grado">
                                <option value="Abuelo">Abuelo</option>
                                <option value="Abuela">Abuela</option>
                                <option value="Nieto">Nieto</option>
                                <option value="Nieta">Nieta</option>
                                <option value="Tio">Tío</option>
                                <option value="Tia">Tía</option>
                                <option value="Sobrino">Sobrino</option>
                                <option value="Sobrina">Sobrina</option>
                                <option value="Medio_hermano">Medio hermano</option>
                                <option value="Medio_hermana">Medio hermana</option>
                            </optgroup>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                </div>
                @*--------------FIN APARTADO DE FAMILIA-------------------*@
                @*--------------APARTADO DE PRIVACIDAD-------------------*@
                <hr />
                <h5><i class="fas fa-shield-alt me-1"></i> Privacidad</h5>
                <div class="p-3 rounded mb-3" style="background:#f3e5f5; border-left:4px solid #7b1fa2;">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="chkAceptaLOPD">
                        <label class="form-check-label fw-semibold" style="color:#6a1b9a;" for="chkAceptaLOPD">
                            <i class="fas fa-lock me-1"></i> Acepta la Ley Orgánica de Protección de Datos (LOPD)
                        </label>
                    </div>
                </div>
                @*--------------FIN APARTADO DE PRIVACIDAD-------------------*@
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    <div id="mensajeError" class="alert alert-danger" role="alert" style="display:none;"></div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between w-100">

                <div>
                    <button type="button" class="btn btn-warning" id="btnRetrocederEstado">
                        ⬅️ Retroceder Estado
                    </button>

                    <button type="button" class="btn btn-info text-white" id="btnAvanzarEstado">
                        ➡️ Avanzar Estado
                    </button>
                </div>

                <div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" onclick="GuardarMiembro()">Guardar</button>
                </div>

            </div>

        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>

    <script>
        var tabladata;
        var filaSeleccionada;

        const loggedInSedeNombre = "@ViewBag.nombre_sede";
        const loggedInSedeID = "@ViewBag.sedeID" ? parseInt("@ViewBag.sedeID") : 0;

        function formatearFecha(fechaString) {
            if (!fechaString) return "";
            try {
                let date;
                if (fechaString.indexOf("/Date(") === 0) {
                    const millis = parseInt(fechaString.replace(/\/Date\(([0-9]+)\)\//, "$1"));
                    date = new Date(millis);
                } else {
                    date = new Date(fechaString);
                }

                if (!isNaN(date.getTime())) {
                    const offset = date.getTimezoneOffset() * 60000;
                    const localDate = new Date(date.getTime() - offset);
                    return localDate.toISOString().substring(0, 10);
                }
                return "";
            } catch (e) {
                console.error("Error al formatear fecha:", e);
                return "";
            }
        }

        $(document).ready(function () {
            if (!$('link[href*="dataTables.bootstrap5.min.css"]').length) {
                $('head').append('<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />');
            }

            if ($.fn.DataTable.isDataTable("#tablaMiembros")) {
                $("#tablaMiembros").DataTable().destroy();
            }

            tabladata = $("#tablaMiembros").DataTable({
                responsive: true,
                ordering: false,
                ajax: {
                    url: '@Url.Action("ListarSimpatizantes", "Congregantes")',
                    type: "GET",
                    dataType: "json",
                    dataSrc: "data"
                },
                columns: [
                    { data: "nombre_miembro" },
                    { data: "apellidos_miembro" },
                    { data: "correo_electronico" },
                    { data: "telefono_movil" },
                    { data: "edad" },
                    {
                        data: "sexo",
                        render: function (valor) {
                            if (valor === "Hombre") return '<span class="badge bg-primary">Hombre</span>';
                            if (valor === "Mujer")  return '<span class="badge bg-warning text-dark">Mujer</span>';
                            return '<span class="badge bg-secondary">N/M</span>';
                        }
                    },
                    { data: "nombre_sede" },
                    {
                            defaultContent: `
                            <div class="d-flex justify-content-center gap-2">
                                <button type="button" class="btn btn-primary btn-sm btn-editarMiembro">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button" class="btn btn-danger btn-sm btn-eliminarMiembro">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>`,
                        orderable: false,
                        searchable: false,
                        width: "140px",
                        className: "text-center align-middle"
                    }
                ],
                language: { url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json" }
            });
            $("#tablaMiembros tbody").on("click", ".btn-editarMiembro", function () {
                filaSeleccionada = $(this).closest("tr");
                var data = tabladata.row(filaSeleccionada).data();
                abrirModalMiembros(data);
            });
            $("#tablaMiembros tbody").on("click", ".btn-eliminarMiembro", function () {
                const fila = $(this).closest("tr");
                const data = tabladata.row(fila).data();

                Swal.fire({
                    title: "¿Estás seguro?",
                    text: `Desea eliminar al miembro ${data.nombre_miembro} ${data.apellidos_miembro}?`,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Sí, eliminar",
                    cancelButtonText: "No"
                }).then(result => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("EliminarMiembro", "Congregantes")',
                            type: "POST",
                            data: { id: data.id_miembro },
                            success: function (res) {
                                if (res.resultado) {
                                    tabladata.row(fila).remove().draw();
                                    Swal.fire("Eliminado!", "El miembro ha sido eliminado.", "success");
                                } else {
                                    Swal.fire("Error", res.mensaje, "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error", "No se pudo eliminar al miembro", "error");
                            }
                        });
                    }
                });
            });

            cargarPaises();
            cargarLideresEnSelect();

            $("#cboProvincia").change(function() {
                var provinciaSeleccionadaId = $(this).val();
                if (provinciaSeleccionadaId !== "0" && provinciaSeleccionadaId !== null) {
                    cargarMunicipios(provinciaSeleccionadaId, 0);
                } else {
                    $("#cboMunicipio").empty().append('<option value="0" disabled selected>Selecciona un municipio</option>').prop('disabled', true);
                }
            });
        });

        // ✅ ABRIR MODAL MIEMBRO
        function abrirModalMiembros(data) {
            $("#mensajeError").hide().text("");

            if (!data) {
                //IDENTIFICADORES
                $("#txtid").val(0);
                //FIN IDENTIFICADORES
                //INFORMACIÓN BÁSICA
                $("#txtNombres").val("");
                $("#txtApellido").val("");
                $("#txtCorreo_electronico").val("");
                $("#txtTelefonoMovil").val("");
                $("#txtTelefonoFijo").val("");
                $("#txtEdad").val("");
                $("#cboSexo").val("");
                $("#txtID_sede").val(loggedInSedeID);
                $("#txtSede").val(loggedInSedeNombre);
                //FIN INFORMACIÓN BÁSICA
                //DIRECCIÓN
                $("#txtDireccion").val("");
                $("#cboProvincia").val("0").change();
                $("#cboMunicipio").val("0").change();
                $("#txtCP").val("");
                //FIN DIRECCIÓN
                //FECHAS
                $("#txtFechaLlegada").val("");
                $("#txtFechaCumpleanos").val("");
                $("#txtFechaBoda").val("");
                $("#txtFechaBautismo").val("");
                $("#txtLugarBautismo").val("");
                //FIN FECHAS
                //INFORMACIÓN ADICIONAL
                $("#cboEstadoCivil").val("");
                $("#cboPaisNacimiento").val("");
                $("#checkBautizado").prop("checked", false);
                toggleBautismoFields();
                $("#txtNumeroHijos").val(0);
                $("#chkAceptaLOPD").prop("checked", false);
                //FIN INFORMACIÓN ADICIONAL
                // FAMILIA
                $("#txtRelacionCon").val("");
                $("#cboTipoRelacionFamiliar").val("");
                cargarFamilias("");
                // FIN FAMILIA
            }
               else {
                // IDENTIFICADORES
                $("#txtid").val(data.id_miembro || 0);
                //FIN IDENTIFICADORES
                //DATOS BÁSICOS
                $("#txtNombres").val(data.nombre_miembro || "");
                $("#txtApellido").val(data.apellidos_miembro || "");
                $("#txtCorreo_electronico").val(data.correo_electronico || "");
                $("#txtTelefonoMovil").val(data.telefono_movil || "");
                $("#txtEdad").val(data.edad || "");
                $("#cboSexo").val(data.sexo || "");
                $("#txtID_sede").val(data.id_sede || loggedInSedeID);
                $("#txtSede").val(data.nombre_sede || loggedInSedeNombre);
                //FIN DATOS BÁSICOS

                // DIRECCIÓN
                $("#txtDireccion").val(data.direccion || "");
                $("#txtCP").val(data.codigo_Postal || "");

                var provinciaId = data.idProvincia || 0;
                var municipioId = data.idMunicipio || 0;
                $("#cboProvincia").val(provinciaId.toString() || "0");
                $("#cboProvincia").change();
                // FIN DIRECCIÓN
                // FECHAS
                $("#txtFechaLlegada").val(formatearFecha(data.fecha_llegada_iglesia) || "");
                $("#txtFechaCumpleanos").val(formatearFecha(data.fecha_cumpleanios) || "");
                $("#txtFechaBoda").val(formatearFecha(data.fecha_boda) || "");
                $("#txtFechaBautismo").val(formatearFecha(data.fecha_bautismo) || "");
                // FIN FECHAS
                // INFORMACIÓN ADICIONAL
                $("#txtLugarBautismo").val(data.lugar_bautismo || ""); // Corregido: tu IF usa pais_nacimiento, tu ELSE usa pais_origen
                $("#cboPaisNacimiento").val(data.pais_nacimiento || "");
                $("#cboEstadoCivil").val(data.estado_Civil || "");
                //CHECK BOXES
                $("#checkBautizado").prop("checked", data.bautizado === true);
                toggleBautismoFields();
                $("#chkAceptaLOPD").prop("checked", data.acepta_LOPD === true);
                // FIN CHECK BOXES
                $("#cboResponsable").val(data.id_responsable || "");
                $("#txtObservaciones").val(data.observaciones || "");
                $("#txtNumeroHijos").val(Math.max(0, parseInt(data.numero_hijos || 0)));
                // FIN INFORMACIÓN ADICIONAL
                // FAMILIA
                $("#txtRelacionCon").val(data.relacion_con || "");
                $("#cboTipoRelacionFamiliar").val(data.tipo_relacion_familiar || "");
                cargarFamilias(data.grupo_familiar || "");
                // FIN FAMILIA
                if (provinciaId > 0) {
                    cargarMunicipios(provinciaId, municipioId);
                }
        }

            const modal = new bootstrap.Modal(document.getElementById("FormModalMiembros"));
            modal.show();
        }

        // ✅ GUARDAR MIEMBRO
        function GuardarMiembro() {
            let miembroDTO = {
                iD_miembro: parseInt($("#txtid").val() || 0),
                numero_miembro: parseInt($("#txtNumeroMiembro").val() || 0),

                diezmo_individual: $("#txtDiezmoIndividual").val() || null,
                diezmo_familiar: $("#txtDiezmoFamiliar").val() || null,

                nombre_miembro: $("#txtNombres").val() || "",
                apellidos_miembro: $("#txtApellido").val() || "",
                correo_electronico: $("#txtCorreo_electronico").val() || "",

                edad: parseInt($("#txtEdad").val() || 0),

                iD_sede: parseInt($("#txtID_sede").val() || 0),

                telefono_movil: $("#txtTelefonoMovil").val() || "",
                telefono_fijo: $("#txtTelefonoFijo").val() || "",

                sexo: $("#cboSexo").val() || "",   // <--- STRING, NO BOOLEAN

                direccion: $("#txtDireccion").val() || "",

                codigo_Postal: $("#txtCP").val() || "",
                idProvincia: parseInt($("#cboProvincia").val() || 0),
                idMunicipio: parseInt($("#cboMunicipio").val() || 0),

                pais_nacimiento: $("#cboPaisNacimiento").val() || "",
                lugar_bautismo: $("#txtLugarBautismo").val() || "",

                estado_Civil: $("#cboEstadoCivil").val() || "",

                id_responsable: parseInt($("#cboResponsable").val()) || null,

                observaciones: $("#txtObservaciones").val() || "",

                numero_hijos: parseInt($("#txtNumeroHijos").val() || 0),

                alumno_VyF: $("#checkAlumno_vyf").prop("checked"),
                curso_acabado: $("#checkCurso_acabado").prop("checked"),
                acepta_LOPD: $("#chkAceptaLOPD").prop("checked"),
                fallecido: $("#checkFallecido").prop("checked"),
                excluir_directorio: $("#checkExcluir_directorio").prop("checked"),
                bautizado: $("#checkBautizado").prop("checked"),



                fecha_llegada_iglesia: $("#txtFechaLlegada").val() || null,
                fecha_bautismo: $("#txtFechaBautismo").val() || null,
                fecha_cumpleanios: $("#txtFechaCumpleanos").val() || null,
                fecha_boda: $("#txtFechaBoda").val() || null,
                fecha_baja: $("#txtFechaBaja").val() || null,
                fecha_fallecido: $("#txtFechaFallecimiento").val() || null,

                grupo_familiar: $("#cboGrupoFamiliar").val() || null,
                id_familia: parseInt($("#cboGrupoFamiliar option:selected").data("id-familia")) || null,
                relacion_con: $("#txtRelacionCon").val() || null,
                tipo_relacion_familiar: $("#cboTipoRelacionFamiliar").val() || null,
            };
            $.ajax({
                url: '@Url.Action("EditarMiembroSimpatizante", "Congregantes")',
                type: "POST",
                data: JSON.stringify(miembroDTO),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                beforeSend: function () {
                    $.LoadingOverlay("show");
                },
                success: function (res) {
                    $.LoadingOverlay("hide");
                    if (res.resultado) {
                        $("#FormModalMiembros").modal("hide");
                        tabladata.ajax.reload(null, false);
                        Swal.fire("Éxito", "Miembro guardado correctamente", "success");
                    } else {
                        $("#mensajeError").text(res.mensaje).show();
                    }
                },
                error: function (err) {
                    $.LoadingOverlay("hide");
                    console.error("Error en GuardarMiembro:", err);
                    Swal.fire("Error", "Ocurrió un problema al guardar el miembro.", "error");
                }
            });
            };
        function cargarLideresEnSelect() {
            $.get('@Url.Action("ListarLideres", "Congregantes")', function (res) {
                var select = $('#cboResponsable');
                select.find('option:not(:first)').remove();
                if (res.data) {
                    $.each(res.data, function (i, l) {
                        select.append($('<option>', { value: l.id, text: (l.nombre_miembro + ' ' + l.apellidos_miembro).trim() }));
                    });
                }
            });
        }

        // ✅ CARGAR PAÍSES
        function cargarPaises() {
            $.ajax({
                url: '@Url.Action("ListarPaises", "Mantenedor")',
                type: "GET",
                success: function (res) {
                    var select = $("#cboPaisNacimiento");
                    var valorActual = select.val();
                    select.empty().append('<option value="">Selecciona un país</option>');
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(p => {
                            select.append(`<option value="${p.nombre}">${p.nombre}</option>`);
                        });
                    }
                    if (valorActual) select.val(valorActual);
                }
            });
        }

        // ✅ CARGAR MUNICIPIOS
        function cargarMunicipios(idProvincia, idMunicipioSeleccionado) {
            $("#cboMunicipio").prop('disabled', true).html('<option>Cargando...</option>');

            $.ajax({
                url: '@Url.Action("ListarMunicipiosPorProvincia", "Mantenedor")',
                type: "GET",
                data: { idProvincia: idProvincia },
                success: function (res) {
                    $("#cboMunicipio").empty().prop('disabled', false);
                    $("#cboMunicipio").append('<option disabled selected>Selecciona un municipio</option>');

                    if (res.data && res.data.length > 0) {
                        res.data.forEach(m => {
                            $("#cboMunicipio").append(`<option value="${m.idMunicipio}">${m.nombre_municipio}</option>`);
                        });
                    }

                    if (idMunicipioSeleccionado > 0) {
                        $("#cboMunicipio").val(idMunicipioSeleccionado.toString());
                    }
                }
            });
        }

        // ======================
        // VISIBILIDAD CONDICIONAL
        // ======================
        function toggleBautismoFields() {
            $("#divBautismoFields").toggle($("#checkBautizado").prop("checked"));
        }
        $("#checkBautizado").on("change", toggleBautismoFields);

        function configurarAutocomplete({
            inputSelector,
            listaSelector,
            contenedorSeleccionadas,
            urlBackend,
            claseBadge,
            asignarFuncion
        }) {
            $(inputSelector).on("keyup", function () {
                let filtro = $(this).val().trim();

                if (filtro.length < 2) {
                    $(listaSelector).empty();
                    return;
                }

                $.ajax({
                    url: urlBackend,
                    type: "GET",
                    data: { nombre: filtro },
                    success: function (resp) {
                        if (resp.error) {
                            console.error(resp.mensaje);
                            return;
                        }

                        $(listaSelector).empty();

                        resp.forEach(item => {
                            const nombreSeguro = $('<div>').text(item.nombre).html();
                            $(listaSelector).append(`
                                <button class="list-group-item list-group-item-action"
                                    onclick="${asignarFuncion}(${item.id}, '${nombreSeguro}')">
                                    ${nombreSeguro}
                                </button>
                            `);
                        });

                    }
                });
            });
        }
                                   // ======================
        // BOTONES DE ESTADO
        // ======================
        $("#btnAvanzarEstado").click(function () {
            AvanzarEstadoMiembro();
        });

        $("#btnRetrocederEstado").click(function () {
            RetrocederEstadoMiembro();
        });

        // ======================
        // FUNCIONES
        // ======================
        function AvanzarEstadoMiembro() {
            const idMiembro = parseInt($("#txtid").val());

            if (!idMiembro || idMiembro === 0) {
                Swal.fire("Aviso", "Primero debes guardar el miembro antes de avanzar su estado.", "warning");
                return;
            }

            Swal.fire({
                title: "¿Avanzar estado?",
                text: "Esto cambiará el estado del miembro al siguiente.",
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Sí, avanzar",
                cancelButtonText: "Cancelar"
            }).then(result => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("AvanzarEstado", "Congregantes")',
                        type: "POST",
                        data: { idMiembro: idMiembro },
                        beforeSend: function () { $.LoadingOverlay("show"); },
                        success: function (res) {
                            $.LoadingOverlay("hide");
                            if (res.success) {
                                Swal.fire("Perfecto", "El estado fue avanzado.", "success");
                                tabladata.ajax.reload(null, false);
                            } else {
                                Swal.fire("Error", res.mensaje, "error");
                            }
                        },
                        error: function () {
                            $.LoadingOverlay("hide");
                            Swal.fire("Error", "No se pudo avanzar el estado.", "error");
                        }
                    });
                }
            });
        }

        function RetrocederEstadoMiembro() {
            const idMiembro = parseInt($("#txtid").val());

            if (!idMiembro || idMiembro === 0) {
                Swal.fire("Aviso", "Primero debes guardar el miembro antes de retroceder su estado.", "warning");
                return;
            }

            Swal.fire({
                title: "¿Retroceder estado?",
                text: "Esto cambiará el estado del miembro al anterior.",
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Sí, retroceder",
                cancelButtonText: "Cancelar"
            }).then(result => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("RetrocederEstado", "Congregantes")',
                        type: "POST",
                        data: { idMiembro: idMiembro },
                        beforeSend: function () { $.LoadingOverlay("show"); },
                        success: function (res) {
                            $.LoadingOverlay("hide");
                            if (res.success) {
                                Swal.fire("Perfecto", "El estado fue retrocedido.", "success");
                                tabladata.ajax.reload(null, false);
                            } else {
                                Swal.fire("Error", res.mensaje, "error");
                            }
                        },
                        error: function () {
                            $.LoadingOverlay("hide");
                            Swal.fire("Error", "No se pudo retroceder el estado.", "error");
                        }
                    });
                }
            });
        }

        // --- Familia ---
        function cargarFamilias(valorSeleccionado) {
            $.ajax({
                url: '@Url.Action("ListarFamiliasCongregantes", "Congregantes")',
                type: 'GET',
                success: function (res) {
                    var select = $('#cboGrupoFamiliar');
                    select.empty().append('<option value="" data-id-familia="">— Sin asignar —</option>');
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function (f) {
                            var opt = $('<option>')
                                .val(f.nombre_familia)
                                .text(f.nombre_familia)
                                .attr('data-id-familia', f.iD_familia || 0)
                                .attr('data-direccion', f.direccion || '')
                                .attr('data-municipio', f.municipio || '')
                                .attr('data-provincia', f.provincia || '')
                                .attr('data-cp', f.cP || f.cp || '');
                            select.append(opt);
                        });
                    }
                    if (valorSeleccionado) {
                        select.val(valorSeleccionado);
                        mostrarInfoFamiliaSeleccionada();
                    }
                }
            });
        }

        function mostrarInfoFamiliaSeleccionada() {
            var opt = $('#cboGrupoFamiliar option:selected');
            var nombre = opt.val();
            if (!nombre) { ocultarInfoFamilia(); return; }
            $('#lblFamiliaDireccion').text(opt.data('direccion') || '—');
            $('#lblFamiliaMunicipio').text(opt.data('municipio') || '—');
            $('#lblFamiliaProvincia').text(opt.data('provincia') || '—');
            $('#lblFamiliaCP').text(opt.data('cp') || '—');
            $('#divInfoFamilia').show();
        }

        function ocultarInfoFamilia() {
            $('#divInfoFamilia').hide();
            $('#lblFamiliaDireccion, #lblFamiliaMunicipio, #lblFamiliaProvincia, #lblFamiliaCP').text('—');
        }

        $('#cboGrupoFamiliar').on('change', function () {
            mostrarInfoFamiliaSeleccionada();
        });

        var timerRelacionCon;
        $('#txtRelacionCon').on('input', function () {
            var term = $(this).val().trim();
            clearTimeout(timerRelacionCon);
            if (term.length < 2) { $('#dropdownRelacionCon').hide().empty(); return; }
            timerRelacionCon = setTimeout(function () {
                $.ajax({
                    url: '@Url.Action("BuscarMiembros", "Congregantes")',
                    type: 'GET',
                    data: { term: term },
                    success: function (res) {
                        var dropdown = $('#dropdownRelacionCon');
                        dropdown.empty();
                        if (res.data && res.data.length > 0) {
                            res.data.forEach(function (m) {
                                var nombre = ((m.nombre_miembro || '') + ' ' + (m.apellidos_miembro || '')).trim();
                                $('<button type="button">')
                                    .addClass('list-group-item list-group-item-action')
                                    .text(nombre)
                                    .on('click', function () {
                                        $('#txtRelacionCon').val(nombre);
                                        dropdown.hide().empty();
                                    })
                                    .appendTo(dropdown);
                            });
                            dropdown.show();
                        } else {
                            dropdown.hide();
                        }
                    }
                });
            }, 300);
        });

        $(document).on('click', function (e) {
            if (!$(e.target).closest('#divRelacionCon').length) {
                $('#dropdownRelacionCon').hide();
            }
        });

        cargarFamilias();

    </script>
}
