@{
    ViewBag.Title = "Líderes";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var loggedInSedeID = ViewBag.sedeID ?? 0;
    var loggedInSedeNombre = ViewBag.nombre_sede?.ToString() ?? "Sede Desconocida";
}
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .autocomplete-dropdown {
        position: absolute;
        z-index: 1055;
        width: 100%;
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        border-radius: 0 0 .375rem .375rem;
        background: #fff;
        box-shadow: 0 4px 12px rgba(0,0,0,.1);
    }
    .autocomplete-wrapper { position: relative; }
    .col-obs {
        max-width: 150px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .badge-acceso    { background-color: #198754; }
    .badge-sinacceso { background-color: #6c757d; }
</style>

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="#">Resumen</a></li>
    <li class="breadcrumb-item active">Líderes</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-user-tie me-1"></i> Gestión de líderes
    </div>

    <div class="table-responsive p-3">
        <div class="row mb-2">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModal(null)">
                    <i class="fas fa-plus me-1"></i> Nuevo líder
                </button>
            </div>
        </div>
        <hr />
        <table id="tablaLideres" class="table table-bordered table-striped border-top" style="width:100%">
            <thead>
                <tr>
                    <th>Miembro</th>
                    <th>Zona</th>
                    <th>Grupo</th>
                    <th>Ministerio</th>
                    <th>Acceso app</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- MODAL LÍDER -->
<div class="modal fade" id="modalLider" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #1E3A8A;">
                <h5 class="modal-title" id="modalTitulo">Nuevo líder</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hiddenID" value="0" />
                <input type="hidden" id="hiddenIdMiembro" value="0" />

                <!-- MIEMBRO -->
                <h6 class="mb-3">Información del miembro</h6>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">Nombre del miembro <span class="text-danger">*</span></label>
                        <div class="autocomplete-wrapper">
                            <input type="text" class="form-control" id="txtNombreMiembro"
                                   autocomplete="off" placeholder="Buscar por nombre...">
                            <div id="dropdownNombreMiembro" class="autocomplete-dropdown list-group" style="display:none;"></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Apellidos</label>
                        <input type="text" class="form-control" id="txtApellidosMiembro"
                               autocomplete="off" placeholder="Se rellena al seleccionar..." readonly>
                    </div>
                </div>

                <hr />
                <!-- ZONA / GRUPO / MINISTERIO -->
                <h6 class="mb-3">Asignación pastoral</h6>
                <div class="row g-3">
                    <!-- ZONA -->
                    <div class="col-sm-4">
                        <label class="form-label">Zona</label>
                        <input type="hidden" id="hiddenIdZona" value="0" />
                        <div class="autocomplete-wrapper">
                            <input type="text" class="form-control" id="txtZona"
                                   autocomplete="off" placeholder="Buscar zona...">
                            <div id="dropdownZona" class="autocomplete-dropdown list-group" style="display:none;"></div>
                        </div>
                    </div>

                    <!-- GRUPO -->
                    <div class="col-sm-4">
                        <label class="form-label">Grupo</label>
                        <input type="hidden" id="hiddenIdGrupo" value="0" />
                        <div class="autocomplete-wrapper">
                            <input type="text" class="form-control" id="txtGrupo"
                                   autocomplete="off" placeholder="Buscar grupo...">
                            <div id="dropdownGrupo" class="autocomplete-dropdown list-group" style="display:none;"></div>
                        </div>
                    </div>

                    <!-- MINISTERIO -->
                    <div class="col-sm-4">
                        <label class="form-label">Ministerio</label>
                        <input type="hidden" id="hiddenIdMinisterio" value="0" />
                        <div class="autocomplete-wrapper">
                            <input type="text" class="form-control" id="txtMinisterio"
                                   autocomplete="off" placeholder="Buscar ministerio...">
                            <div id="dropdownMinisterio" class="autocomplete-dropdown list-group" style="display:none;"></div>
                        </div>
                    </div>

                    <!-- TIENE USUARIO -->
                    <div class="col-12">
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" id="chkTieneUsuario" role="switch">
                            <label class="form-check-label" for="chkTieneUsuario">
                                Tiene usuario en la aplicación
                            </label>
                        </div>
                        <small class="text-muted">Indica si este líder dispone de acceso al sistema.</small>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarLider()">
                    <i class="fas fa-save me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
    var tablaLideres;

    $(document).ready(function () {
        tablaLideres = $('#tablaLideres').DataTable({
            ajax: {
                url: '@Url.Action("ListarLideres", "Congregantes")',
                type: 'GET',
                dataSrc: 'data'
            },
            columns: [
                {
                    data: null,
                    render: function (data) {
                        return (data.nombre_miembro || '') + ' ' + (data.apellidos_miembro || '');
                    }
                },
                { data: 'nombre_zona', defaultContent: '—' },
                { data: 'descripcion_grupo', defaultContent: '—' },
                { data: 'descripcion_ministerio', defaultContent: '—' },
                {
                    data: 'tiene_usuario',
                    render: function (val) {
                        return val
                            ? '<span class="badge badge-acceso">Con acceso</span>'
                            : '<span class="badge badge-sinacceso">Sin acceso</span>';
                    }
                },
                {
                    data: null,
                    orderable: false,
                    render: function (data) {
                        return '<button class="btn btn-sm btn-warning me-1" onclick=\'abrirModal(' + JSON.stringify(data) + ')\'>' +
                               '<i class="fas fa-edit"></i></button>' +
                               '<button class="btn btn-sm btn-danger" onclick="eliminarLider(' + data.id + ')">' +
                               '<i class="fas fa-trash"></i></button>';
                    }
                }
            ],
            language: {
                url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
            },
            responsive: true
        });
    });

    // ─── MODAL ABRIR ──────────────────────────────────────────────
    function abrirModal(data) {
        limpiarModal();
        if (data) {
            $('#modalTitulo').text('Editar líder');
            $('#hiddenID').val(data.id);
            $('#hiddenIdMiembro').val(data.id_miembro);
            $('#txtNombreMiembro').val(data.nombre_miembro || '');
            $('#txtApellidosMiembro').val(data.apellidos_miembro || '');
            // Zona
            $('#hiddenIdZona').val(data.id_zona || 0);
            $('#txtZona').val(data.nombre_zona !== '—' ? data.nombre_zona : '');
            // Grupo
            $('#hiddenIdGrupo').val(data.id_grupo || 0);
            $('#txtGrupo').val(data.descripcion_grupo !== '—' ? data.descripcion_grupo : '');
            // Ministerio
            $('#hiddenIdMinisterio').val(data.id_ministerio || 0);
            $('#txtMinisterio').val(data.descripcion_ministerio !== '—' ? data.descripcion_ministerio : '');
            // Tiene usuario
            $('#chkTieneUsuario').prop('checked', data.tiene_usuario === true);
        } else {
            $('#modalTitulo').text('Nuevo líder');
        }
        $('#modalLider').modal('show');
    }

    function limpiarModal() {
        $('#hiddenID').val(0);
        $('#hiddenIdMiembro').val(0);
        $('#txtNombreMiembro').val('');
        $('#txtApellidosMiembro').val('');
        $('#hiddenIdZona').val(0);
        $('#txtZona').val('');
        $('#hiddenIdGrupo').val(0);
        $('#txtGrupo').val('');
        $('#hiddenIdMinisterio').val(0);
        $('#txtMinisterio').val('');
        $('#chkTieneUsuario').prop('checked', false);
        $('.autocomplete-dropdown').hide().empty();
    }

    // ─── GUARDAR ──────────────────────────────────────────────────
    function guardarLider() {
        var idMiembro = parseInt($('#hiddenIdMiembro').val());
        var nombre = $('#txtNombreMiembro').val().trim();
        var apellidos = $('#txtApellidosMiembro').val().trim();

        if (idMiembro <= 0 || nombre === '') {
            Swal.fire('Atención', 'Debes seleccionar un miembro de la lista.', 'warning');
            return;
        }

        var esEdicion = parseInt($('#hiddenID').val()) > 0;
        Swal.fire({
            title: '¿Confirmar?',
            text: esEdicion ? '¿Deseas guardar los cambios?' : '¿Deseas registrar este líder?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Sí, guardar',
            cancelButtonText: 'Cancelar'
        }).then(function (result) {
            if (!result.isConfirmed) return;

            var payload = {
                ID: parseInt($('#hiddenID').val()),
                ID_miembro: idMiembro,
                Nombre_miembro: nombre,
                Apellidos_miembro: apellidos,
                ID_zona: parseInt($('#hiddenIdZona').val()) || 0,
                ID_grupo: parseInt($('#hiddenIdGrupo').val()) || 0,
                ID_ministerio: parseInt($('#hiddenIdMinisterio').val()) || 0,
                Tiene_usuario: $('#chkTieneUsuario').is(':checked')
            };

            $.ajax({
                url: '@Url.Action("RegistrarLider", "Congregantes")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.resultado && res.resultado !== 0 && res.resultado !== false) {
                        Swal.fire('Éxito', res.mensaje, 'success');
                        $('#modalLider').modal('hide');
                        tablaLideres.ajax.reload();
                    } else {
                        Swal.fire('Error', res.mensaje || 'No se pudo guardar.', 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Error de conexión.', 'error');
                }
            });
        });
    }

    // ─── ELIMINAR ─────────────────────────────────────────────────
    function eliminarLider(id) {
        Swal.fire({
            title: '¿Estás seguro?',
            text: '¿Deseas eliminar este líder?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#d33'
        }).then(function (result) {
            if (!result.isConfirmed) return;
            $.ajax({
                url: '@Url.Action("EliminarLider", "Congregantes")',
                type: 'POST',
                data: { id: id },
                success: function (res) {
                    if (res.resultado) {
                        Swal.fire('Eliminado', res.mensaje, 'success');
                        tablaLideres.ajax.reload();
                    } else {
                        Swal.fire('Error', res.mensaje, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Error de conexión.', 'error');
                }
            });
        });
    }

    // ─── AUTOCOMPLETE: MIEMBRO ────────────────────────────────────
    var timerMiembro;
    $('#txtNombreMiembro').on('input', function () {
        var term = $(this).val().trim();
        $('#hiddenIdMiembro').val(0);
        $('#txtApellidosMiembro').val('');
        clearTimeout(timerMiembro);
        if (term.length < 2) { $('#dropdownNombreMiembro').hide().empty(); return; }
        timerMiembro = setTimeout(function () {
            $.ajax({
                url: '@Url.Action("BuscarMiembros", "Congregantes")',
                type: 'GET',
                data: { term: term },
                success: function (res) {
                    var dd = $('#dropdownNombreMiembro');
                    dd.empty();
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function (m) {
                            var nombreCompleto = ((m.nombre_miembro || '') + ' ' + (m.apellidos_miembro || '')).trim();
                            $('<button type="button">')
                                .addClass('list-group-item list-group-item-action')
                                .text(nombreCompleto)
                                .on('click', function () {
                                    $('#hiddenIdMiembro').val(m.id_miembro);
                                    $('#txtNombreMiembro').val(m.nombre_miembro || '');
                                    $('#txtApellidosMiembro').val(m.apellidos_miembro || '');
                                    dd.hide().empty();
                                })
                                .appendTo(dd);
                        });
                        dd.show();
                    } else {
                        dd.hide();
                    }
                }
            });
        }, 300);
    });

    // ─── AUTOCOMPLETE: ZONA ───────────────────────────────────────
    var timerZona;
    $('#txtZona').on('input', function () {
        var term = $(this).val().trim();
        $('#hiddenIdZona').val(0);
        clearTimeout(timerZona);
        if (term.length < 2) { $('#dropdownZona').hide().empty(); return; }
        timerZona = setTimeout(function () {
            $.ajax({
                url: '@Url.Action("ListarZonasPorNombre", "Congregantes")',
                type: 'GET',
                data: { nombre: term },
                success: function (res) {
                    var dd = $('#dropdownZona');
                    dd.empty();
                    var lista = Array.isArray(res) ? res : (res.data || []);
                    if (lista.length > 0) {
                        lista.forEach(function (z) {
                            $('<button type="button">')
                                .addClass('list-group-item list-group-item-action')
                                .text(z.nombre || '')
                                .on('click', function () {
                                    $('#hiddenIdZona').val(z.id);
                                    $('#txtZona').val(z.nombre || '');
                                    dd.hide().empty();
                                })
                                .appendTo(dd);
                        });
                        dd.show();
                    } else {
                        dd.hide();
                    }
                }
            });
        }, 300);
    });

    // Borrar zona al limpiar campo
    $('#txtZona').on('change', function () {
        if ($(this).val().trim() === '') $('#hiddenIdZona').val(0);
    });

    // ─── AUTOCOMPLETE: GRUPO ──────────────────────────────────────
    var timerGrupo;
    $('#txtGrupo').on('input', function () {
        var term = $(this).val().trim();
        $('#hiddenIdGrupo').val(0);
        clearTimeout(timerGrupo);
        if (term.length < 2) { $('#dropdownGrupo').hide().empty(); return; }
        timerGrupo = setTimeout(function () {
            $.ajax({
                url: '@Url.Action("ListarGruposPorNombre", "Congregantes")',
                type: 'GET',
                data: { nombre: term },
                success: function (res) {
                    var dd = $('#dropdownGrupo');
                    dd.empty();
                    var lista = Array.isArray(res) ? res : (res.data || []);
                    if (lista.length > 0) {
                        lista.forEach(function (g) {
                            $('<button type="button">')
                                .addClass('list-group-item list-group-item-action')
                                .text(g.nombre || '')
                                .on('click', function () {
                                    $('#hiddenIdGrupo').val(g.id);
                                    $('#txtGrupo').val(g.nombre || '');
                                    dd.hide().empty();
                                })
                                .appendTo(dd);
                        });
                        dd.show();
                    } else {
                        dd.hide();
                    }
                }
            });
        }, 300);
    });

    $('#txtGrupo').on('change', function () {
        if ($(this).val().trim() === '') $('#hiddenIdGrupo').val(0);
    });

    // ─── AUTOCOMPLETE: MINISTERIO ─────────────────────────────────
    var timerMinisterio;
    $('#txtMinisterio').on('input', function () {
        var term = $(this).val().trim();
        $('#hiddenIdMinisterio').val(0);
        clearTimeout(timerMinisterio);
        if (term.length < 2) { $('#dropdownMinisterio').hide().empty(); return; }
        timerMinisterio = setTimeout(function () {
            $.ajax({
                url: '@Url.Action("ListarMinisteriosPorNombre", "Congregantes")',
                type: 'GET',
                data: { nombre: term },
                success: function (res) {
                    var dd = $('#dropdownMinisterio');
                    dd.empty();
                    var lista = Array.isArray(res) ? res : (res.data || []);
                    if (lista.length > 0) {
                        lista.forEach(function (m) {
                            $('<button type="button">')
                                .addClass('list-group-item list-group-item-action')
                                .text(m.nombre || '')
                                .on('click', function () {
                                    $('#hiddenIdMinisterio').val(m.id);
                                    $('#txtMinisterio').val(m.nombre || '');
                                    dd.hide().empty();
                                })
                                .appendTo(dd);
                        });
                        dd.show();
                    } else {
                        dd.hide();
                    }
                }
            });
        }, 300);
    });

    $('#txtMinisterio').on('change', function () {
        if ($(this).val().trim() === '') $('#hiddenIdMinisterio').val(0);
    });

    // Cerrar dropdowns al hacer clic fuera
    $(document).on('click', function (e) {
        if (!$(e.target).closest('.autocomplete-wrapper').length) {
            $('.autocomplete-dropdown').hide().empty();
        }
    });
</script>
}
