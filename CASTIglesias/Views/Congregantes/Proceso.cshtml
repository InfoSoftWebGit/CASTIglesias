        // ✅ GUARDAR MIEMBRO
        function GuardarMiembro() {
            let miembroDTO = {
                iD_miembro: parseInt($("#txtid").val() || 0),
                numero_miembro: parseInt($("#txtNumeroMiembro").val() || 0),

                diezmo_individual: parseInt($("#txtDiezmoIndividual").val() || 0),
                diezmo_familiar: parseInt($("#txtDiezmoFamiliar").val() || 0),

                nombre_miembro: $("#txtNombres").val() || "",
                apellidos_miembro: $("#txtApellido").val() || "",
                correo_electronico: $("#txtCorreo_electronico").val() || "",

                edad: parseInt($("#txtEdad").val() || 0),

                iD_sede: parseInt($("#txtID_sede").val() || 0),

                telefono_movil: parseInt($("#txtTelefonoMovil").val() || 0),
                telefono_fijo: parseInt($("#txtTelefonoFijo").val() || 0),

                sexo: $("#cboSexo").val() || "",   // <--- STRING, NO BOOLEAN

                direccion: $("#txtDireccion").val() || "",

                codigo_Postal: parseInt($("#txtCP").val() || 0),
                idProvincia: parseInt($("#cboProvincia").val() || 0),
                idMunicipio: parseInt($("#cboMunicipio").val() || 0),

                pais_nacimiento: $("#txtPais_nacimiento").val() || "",
                lugar_bautismo: $("#txtLugarBautismo").val() || "",

                estado_Civil: $("#cboEstadoCivil").val() || "",
                estado: $("#cboEstado").val() || "",

                persona_cargo: $("#txtPersonaCargo").val() || "",

                observaciones: $("#txtObservaciones").val() || "",

                numero_hijos: parseInt($("#txtNumeroHijos").val() || 0),

                alumno_VyF: $("#checkAlumno_vyf").prop("checked"),
                curso_acabado: $("#checkCurso_acabado").prop("checked"),
                acepta_LOPD: $("#chkAceptaLOPD").prop("checked"),
                fallecido: $("#checkFallecido").prop("checked"),
                excluir_directorio: $("#checkExcluir_directorio").prop("checked"),
                bautizado: $("#checkBautizado").prop("checked"),



                fecha_llegada_iglesia: $("#txtFechaLlegada").val() || null,
                fecha_bautismo: $("#txtFechaBautismo").val() || null,
                fecha_cumpleanios: $("#txtFechaCumpleanos").val() || null,
                fecha_boda: $("#txtFechaBoda").val() || null,
                fecha_baja: $("#txtFechaBaja").val() || null,
                fecha_fallecido: $("#txtFechaFallecimiento").val() || null,
            };
            $.ajax({
                url: '@Url.Action("RegistrarMiembro", "Congregantes")',
                type: "POST",
                data: JSON.stringify(miembroDTO),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                beforeSend: function () {
                    $.LoadingOverlay("show");
                },
                success: function (res) {
                    $.LoadingOverlay("hide");
                    if (res.resultado) {
                        $("#FormModalMiembros").modal("hide");
                        tabladata.ajax.reload(null, false);
                        Swal.fire("Éxito", "Miembro guardado correctamente", "success");
                    } else {
                        $("#mensajeError").text(res.mensaje).show();
                    }
                },
                error: function (err) {
                    $.LoadingOverlay("hide");
                    console.error("Error en GuardarMiembro:", err);
                    Swal.fire("Error", "Ocurrió un problema al guardar el miembro.", "error");
                }
            });
            };



        // ✅ CARGAR MUNICIPIOS
        function cargarMunicipios(idProvincia, idMunicipioSeleccionado) {
            $("#cboMunicipio").prop('disabled', true).html('<option>Cargando...</option>');

            $.ajax({
                url: '@Url.Action("ListarMunicipiosPorProvincia", "Mantenedor")',
                type: "GET",
                data: { idProvincia: idProvincia },
                success: function (res) {
                    $("#cboMunicipio").empty().prop('disabled', false);
                    $("#cboMunicipio").append('<option disabled selected>Selecciona un municipio</option>');

                    if (res.data && res.data.length > 0) {
                        res.data.forEach(m => {
                            $("#cboMunicipio").append(`<option value="${m.idMunicipio}">${m.nombre_municipio}</option>`);
                        });
                    }

                    if (idMunicipioSeleccionado > 0) {
                        $("#cboMunicipio").val(idMunicipioSeleccionado.toString());
                    }
                }
            });
        }

        function abrirModalZonasGruposMinisterios(data) {

            $("#txtid").val(data.iD_miembro);

            // limpiar selección
            $("#zonaSeleccionadas").empty();
            $("#gruposSeleccionados").empty();
            $("#ministeriosSeleccionados").empty();

            $("#modalZonagrupoministerioMiembro").modal("show");
            cargarZonasGruposMinisterios(data.iD_miembro);
        }

        /***************************************************************
         ✅ CARGAR ZONAS, GRUPOS y MINISTERIOS DEL MIEMBRO
        ***************************************************************/

        function cargarZonasGruposMinisterios(iD_miembro) {
            $.ajax({
                url: '/Congregantes/ObtenerMiembrosZonasGruposMinisterios',
                type: 'GET',
                data: { idMiembro: iD_miembro },
                success: function (resp) {
                    $("#zonaSeleccionadas").empty();
                    $("#gruposSeleccionados").empty();
                    $("#ministeriosSeleccionados").empty();

                    if (!resp.zonas_grupos_ministerios || resp.zonas_grupos_ministerios.length === 0) return;

                    resp.zonas_grupos_ministerios.forEach(function (item) {

                        if (item.iD_zona && item.iD_zona !== 0) {
                            $("#zonaSeleccionadas").append(`
                                <span class="badge bg-primary me-2" data-id="${item.iD_zona}">
                                    ${item.nombre_zona || 'Zona ' + item.nombre_zona}
                                    <button type="button" class="btn-close btn-close-white ms-2"
                                            onclick="$(this).parent().remove()"></button>
                                </span>
                            `);
                        }

                        if (item.iD_grupo && item.iD_grupo !== 0) {
                            $("#gruposSeleccionados").append(`
                                <span class="badge bg-success me-2" data-id="${item.iD_grupo}">
                                    ${item.descripcion_grupo || 'Grupo ' + item.descripcion_grupo}
                                    <button type="button" class="btn-close btn-close-white ms-2"
                                            onclick="$(this).parent().remove()"></button>
                                </span>
                            `);
                        }

                        if (item.id_ministerio && item.id_ministerio !== 0) {
                            $("#ministeriosSeleccionados").append(`
                                <span class="badge bg-warning text-dark me-2" data-id="${item.id_ministerio}">
                                    ${item.descripcion_ministerio || 'Ministerio ' + item.descripcion_ministerio}
                                    <button type="button" class="btn-close btn-close-white ms-2"
                                            onclick="$(this).parent().remove()"></button>
                                </span>
                            `);
                        }

                    });

                    // Guardar el ID del miembro en el input hidden
                    $("#txtid").val(iD_miembro);
                },
                error: function (err) {
                    console.error("Error al cargar ZGM:", err);
                }
            });
        }
