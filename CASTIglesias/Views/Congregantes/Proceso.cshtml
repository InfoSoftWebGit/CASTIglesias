        function GuardarZGM() {
            const idMiembro = $("#txtid").val();
            let idZona = 0, idGrupo = 0, idMinisterio = 0;
            const listaZGM = [];

            // Suponiendo que solo seleccionas uno de cada tipo por miembro
            idZona = parseInt($("#zonaSeleccionadas span").attr("data-id")) || 0;
            idGrupo = parseInt($("#gruposSeleccionados span").attr("data-id")) || 0;
            idMinisterio = parseInt($("#ministeriosSeleccionados span").attr("data-id")) || 0;

            if (idZona === 0 && idGrupo === 0 && idMinisterio === 0) {
                Swal.fire("Atención", "No hay zonas, grupos ni ministerios seleccionados.", "warning");
                return;
            }

            listaZGM.push({
                ID_miembro: idMiembro,
                ID_zona: idZona,
                ID_grupo: idGrupo,
                ID_ministerio: idMinisterio,
                ID_sede: loggedInSedeID
            });

            console.log("JSON que se enviará:", JSON.stringify(listaZGM));

            $.ajax({
                url: "/Congregantes/GuardarZGM",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(listaZGM),
                success: function (resp) {
                    if (resp.resultado) {
                        Swal.fire("Guardado", "Cambios aplicados correctamente", "success");
                        $("#zonaSeleccionadas, #gruposSeleccionados, #ministeriosSeleccionados").empty();
                    } else {
                        Swal.fire("Error", resp.mensaje, "error");
                    }
                },
                error: function () {
                    Swal.fire("Error", "No se pudo guardar la información.", "error");
                }
            });
        };

        function configurarAutocomplete({
            inputSelector,
            listaSelector,
            contenedorSeleccionadas,
            urlBackend,
            claseBadge,
            asignarFuncion
        }) {
            $(inputSelector).on("keyup", function () {
                let filtro = $(this).val().trim();

                if (filtro.length < 2) {
                    $(listaSelector).empty();
                    return;
                }

                $.ajax({
                    url: urlBackend,
                    type: "GET",
                    data: { nombre: filtro },
                    success: function (resp) {
                        if (resp.error) {
                            console.error(resp.mensaje);
                            return;
                        }

                        $(listaSelector).empty();

                        resp.forEach(item => {
                            const nombreSeguro = $('<div>').text(item.nombre).html();
                            $(listaSelector).append(`
                                <button class="list-group-item list-group-item-action"
                                    onclick="${asignarFuncion}(${item.id}, '${nombreSeguro}')">
                                    ${nombreSeguro}
                                </button>
                            `);
                        });

                    }
                });
            });
        }

        // Función general para agregar un item evitando duplicados
        function agregarElementoSeleccionado(id, nombre, contenedor, claseBadge) {
            if (!id) return; // ignorar valores falsy
            if ($(`${contenedor} span[data-id="${id}"]`).length > 0) return;

            const nombreSeguro = $('<div>').text(nombre).html(); // evita problemas con comillas o caracteres especiales

            $(contenedor).append(`
                <span class="badge ${claseBadge} me-2" data-id="${id}">
                    ${nombreSeguro}
                    <button type="button" class="btn-close btn-close-white ms-2" onclick="$(this).parent().remove()"></button>
                </span>
            `);

            // Limpiar input y lista de sugerencias
            $(contenedor).siblings('input').val('');
            $(contenedor).siblings('.list-group').empty();
        }

        // Configuración para Zonas
        configurarAutocomplete({
            inputSelector: "#txtBuscarZona",
            listaSelector: "#listaZonas",
            contenedorSeleccionadas: "#zonaSeleccionadas",
            urlBackend: "/Mantenedor/ListarZonasPorNombre",
            claseBadge: "bg-primary",
            asignarFuncion: "asignarZona"
        });
        function asignarZona(id, nombre) {
            agregarElementoSeleccionado(id, nombre, "#zonaSeleccionadas", "bg-primary");
        }

        // Configuración para Grupos
        configurarAutocomplete({
