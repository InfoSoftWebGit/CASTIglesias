@using System.Text.Json
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // 🔑 Uso de los ViewBag del controlador
    var loggedInSedeID = ViewBag.sedeID ?? 0;
    var loggedInSedeNombre = ViewBag.nombre_sede?.ToString() ?? "Sede Desconocida";
}
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="index.html">Resumen</a></li>
    <li class="breadcrumb-item active">Miembros en proceso</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista de miembros en proceso
    </div>

    <div class="table-responsive">
        @* <div class="row">
            <div class="col-12 mb-2">
                <button type="button" class="btn btn-success" onclick="abrirModalMiembros(null)">Añadir nuevo miembro</button>
            </div>
        </div> *@

        <hr />
        <table id="tablaMiembros" class="table table-bordered table-striped border-top" style="width: 100%">
            <thead>
                <tr>
                    <th>Número Miembro</th>
                    <th>Nombre</th>
                    <th>Apellidos</th>
                    <th>Correo electrónico</th>
                    <th>Teléfono</th>
                    <th>Edad</th>
                    <th>Sexo</th>
                    <th>Sede</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="FormModalMiembros" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Datos del nuevo miembro</h1>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            @*--------------APARTADO DE INFORMACIÓN BÁSICA-------------------*@
            <div class="modal-body g-3">
                <input id="txtid" type="hidden" value="0" />
                <input id="txtID_sede" type="hidden" value="0" />
                <label for="txtNumeroMiembro" class="form-label">Número de Miembro</label>
                <input id="txtNumeroMiembro" type="number" class="form-control mb-2" placeholder="Número de miembro" />
                <label for="txtDiezmoIndividual" class="form-label">Diezmo individual</label>
                <input id="txtDiezmoIndividual" type="number" class="form-control mb-2" />
                <label for="txtDiezmoFamiliar" class="form-label">Diezmo familiar</label>
                <input id="txtDiezmoFamiliar" type="number" class="form-control mb-2" placeholder="Diezmo familiar" />

                <h5>Información principal</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtNombres" class="form-label">Nombres</label>
                        <input type="text" class="form-control" id="txtNombres" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtApellido" class="form-label">Apellido</label>
                        <input type="text" class="form-control" id="txtApellido" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtCorreo_electronico" class="form-label">Correo</label>
                        <input type="email" class="form-control" id="txtCorreo_electronico" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtTelefonoMovil" class="form-label">Teléfono móvil</label>
                        <input type="number" class="form-control" id="txtTelefonoMovil" autocomplete="off">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtTelefonoFijo" class="form-label">Teléfono fijo</label>
                        <input type="number" class="form-control" id="txtTelefonoFijo" autocomplete="off">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtEdad" class="form-label">Edad</label>
                        <input type="number" class="form-control" id="txtEdad" autocomplete="off">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboSexo" class="form-label">Sexo</label>
                        <select id="cboSexo" class="form-select">
                            <option value="" disabled selected>Selecciona un valor</option>
                            <option value="Hombre">Hombre</option>
                            <option value="Mujer">Mujer</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label"></label>
                        <input type="text" class="form-control" id="txtSede" hidden />
                    </div>
                </div>
                @*--------------FIN APARTADO DE INFORMACIÓN BÁSICA-------------------*@

                @*--------------APARTADO DE DIRECCIONES-------------------*@
                <hr />
                <h5>Dirección</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtDireccion" class="form-label">Dirección</label>
                        <input type="text" class="form-control" id="txtDireccion">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboProvincia" class="form-label">Provincia</label>
                        <select id="cboProvincia" class="form-select">
                            <option value="0" disabled selected>Selecciona una provincia</option>
                            @if (ViewBag.ListaProvincias != null)
                            {
                                foreach (var p in ViewBag.ListaProvincias)
                                {
                                    <option value="@p.idProvincia">@p.nombre_provincia</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboMunicipio" class="form-label">Municipio</label>
                        <select id="cboMunicipio" class="form-select">
                            <option value="" disabled selected>Selecciona un Municipio</option>
                            @* Las opciones se cargan dinámicamente por JS/AJAX *@
                        </select>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtCP" class="form-label">Código Postal</label>
                        <input type="number" class="form-control" id="txtCP">
                    </div>
                </div>
                <hr />
                @*--------------FIN APARTADO DE DIRECCIONES-------------------*@

                @*--------------APARTADO DE FECHAS-------------------*@

                <h5>Fechas Específicas</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtFechaLlegada" class="form-label">Fecha de Llegada a la Iglesia</label>
                        <input type="date" class="form-control" id="txtFechaLlegada">
                    </div>
                    <div class="col-sm-4 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="checkBautizado">
                            <label class="form-check-label" for="checkBautizado">¿Bautizado?</label>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtFechaBautismo" class="form-label">Fecha de Bautismo</label>
                        <input type="date" class="form-control" id="txtFechaBautismo">
                    </div>

                    <div class="col-sm-6 mb-3">
                        <label for="txtLugarBautismo" class="form-label">Lugar de bautismo</label>
                        <input type="text" class="form-control" id="txtLugarBautismo">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtFechaCumpleanos" class="form-label">Fecha de Cumpleaños</label>
                        <input type="date" class="form-control" id="txtFechaCumpleanos">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtFechaBoda" class="form-label">Fecha de Boda</label>
                        <input type="date" class="form-control" id="txtFechaBoda">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="txtFechaBaja" class="form-label">Fecha de Baja (Retiro)</label>
                        <input type="date" class="form-control" id="txtFechaBaja">
                    </div>
                </div>
                <hr />
                @*--------------FIN APARTADO DE FECHAS-------------------*@
                @*--------------APARTADO DE INFORMACIÓN ADICIONAL-------------------*@

                <h5>Información Adicional</h5>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label for="txtPais" class="form-label">País de nacimiento</label>
                        <input type="text" class="form-control" id="txtPais_nacimiento">
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboEstadoCivil" class="form-label">Estado civil</label>
                        <select id="cboEstadoCivil" class="form-select">
                            <option value="" disabled selected>Selecciona un valor</option>
                            <option value="Soltero/a">Soltero/a</option>
                            <option value="Casado/a">Casado/a</option>
                            <option value="Viudo/a">Viudo/a</option>
                            <option value="Divorciado/a">Divorciado/a</option>
                            <option value="Separado/a">Separado/a</option>
                            <option value="Unión de hecho/a">Unión de hecho/a</option>
                        </select>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label for="cboEstado" class="form-label">Estado</label>
                        <select id="cboEstado" class="form-select">
                            <option value="" disabled selected>Selecciona un valor</option>
                            <option value="Visitante">Visitante</option>
                            <option value="Simpatizante">Simpatizante</option>
                            <option value="Proceso">Proceso</option>
                            <option value="Miembro">Miembro</option>
                            <option value="Baja">Baja</option>
                        </select>
                    </div>
                    <div class="col-sm-4 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="checkAlumno_vyf">
                            <label class="form-check-label" for="checkAlumno_vyf">¿Alumno de VyF?</label>
                        </div>
                    </div>

                    <div class="col-sm-4 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="checkCurso_acabado">
                            <label class="form-check-label" for="checkCurso_acabado">¿Curso acabado?</label>
                        </div>
                    </div>
                    <div class="col-sm-4 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="checkExcluir_directorio">
                            <label class="form-check-label" for="checkExcluir_directorio">¿Excluir del directorio?</label>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtPersonaCargo" class="form-label">Persona a cargo</label>
                        <input type="text" class="form-control" id="txtPersonaCargo">
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtObservaciones" class="form-label">Observaciones</label>
                        <textarea class="form-control" id="txtObservaciones" rows="3" maxlength="200"></textarea>
                    </div>
                    <div class="col-sm-4 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="checkFallecido">
                            <label class="form-check-label" for="checkFallecido">¿Falleció?</label>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label for="txtFechaFallecimiento" class="form-label">Fecha de fallecimiento</label>
                        <input type="date" class="form-control" id="txtFechaFallecimiento">
                    </div>
                    <label for="txtNumeroHijos" class="form-label">Número de hijos </label>
                    <input id="txtNumeroHijos" type="number" class="form-control mb-2" placeholder="Número de hijos" />



                </div>
                @*--------------FIN APARTADO DE INFORMACIÓN ADICIONAL-------------------*@
                @*--------------APARTADO DE PRIVACIDAD-------------------*@
                <h5>Privacidad</h5>
                <div class="row">
                    <div class="col-12 mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="chkAceptaLOPD">
                            <label class="form-check-label" for="chkAceptaLOPD">
                                **Acepta la Ley Orgánica de Protección de Datos (LOPD)**
                            </label>
                        </div>
                    </div>
                </div>
                @*--------------FIN APARTADO DE PRIVACIDAD-------------------*@
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    <div id="mensajeError" class="alert alert-danger" role="alert" style="display:none;"></div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between w-100">

                <div>
                    <button type="button" class="btn btn-warning" id="btnRetrocederEstado">
                        ⬅️ Retroceder Estado
                    </button>

                    <button type="button" class="btn btn-info text-white" id="btnAvanzarEstado">
                        ➡️ Avanzar Estado
                    </button>
                </div>

                <div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" onclick="GuardarMiembro()">Guardar</button>
                </div>

            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalZonagrupoministerioMiembro" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Asignar Células / Grupos / Ministerios</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="idMiembroZGM">
                <input id="txtid" type="hidden" />

                <!-- ZONAS -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Zonas</label>

                    <div id="zonaSeleccionadas" class="mb-2 d-flex flex-wrap gap-2"></div>

                    <div class="input-group">
                        <input type="text" class="form-control" id="txtBuscarZona" placeholder="Buscar zona...">
                        <button class="btn btn-outline-primary" type="button" onclick="agregarZonaManual()">Añadir</button>
                    </div>

                    <div id="listaZonas" class="list-group position-absolute w-50 shadow" style="z-index:999;"></div>
                </div>

                <!-- CONTENEDOR ÚNICO -->
                <div id="contenedorZonasGruposMinisterios" class="mb-3"></div>

                <!-- GRUPOS -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Grupos</label>

                    <div id="gruposSeleccionados" class="mb-2 d-flex flex-wrap gap-2"></div>

                    <div class="input-group">
                        <input type="text" class="form-control" id="txtBuscarGrupo" placeholder="Buscar grupo...">
                        <button class="btn btn-outline-primary" type="button" onclick="agregarGrupoManual()">Añadir</button>
                    </div>

                    <div id="listaGrupos" class="list-group position-absolute w-50 shadow" style="z-index:999;"></div>
                </div>

                <!-- MINISTERIOS -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Ministerios</label>

                    <div id="ministeriosSeleccionados" class="mb-2 d-flex flex-wrap gap-2"></div>

                    <div class="input-group">
                        <input type="text" class="form-control" id="txtBuscarMinisterio" placeholder="Buscar ministerio...">
                        <button class="btn btn-outline-primary" type="button" onclick="agregarMinisterioManual()">Añadir</button>
                    </div>

                    <div id="listaMinisterios" class="list-group position-absolute w-50 shadow" style="z-index:999;"></div>
                </div>

            </div>

            <div class="modal-footer d-flex justify-content-between w-100">

                <div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" id="btnGuardarZGM" class="btn btn-primary" onclick="GuardarZGM()">Guardar</button>
                </div>

            </div>

        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>

    <script>
        var tabladata;
        var filaSeleccionada;

        const loggedInSedeNombre = "@ViewBag.nombre_sede";
        const loggedInSedeID = "@ViewBag.sedeID" ? parseInt("@ViewBag.sedeID") : 0;

        function formatearFecha(fechaString) {
            if (!fechaString) return "";
            try {
                let date;
                if (fechaString.indexOf("/Date(") === 0) {
                    const millis = parseInt(fechaString.replace(/\/Date\(([0-9]+)\)\//, "$1"));
                    date = new Date(millis);
                } else {
                    date = new Date(fechaString);
                }

                if (!isNaN(date.getTime())) {
                    const offset = date.getTimezoneOffset() * 60000;
                    const localDate = new Date(date.getTime() - offset);
                    return localDate.toISOString().substring(0, 10);
                }
                return "";
            } catch (e) {
                console.error("Error al formatear fecha:", e);
                return "";
            }
        }


        $(document).ready(function () {
            if (!$('link[href*="dataTables.bootstrap5.min.css"]').length) {
                $('head').append('<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />');
            }

            if ($.fn.DataTable.isDataTable("#tablaMiembros")) {
                $("#tablaMiembros").DataTable().destroy();
            }

            tabladata = $("#tablaMiembros").DataTable({
                responsive: true,
                ordering: false,
                ajax: {
                    url: '@Url.Action("ListarMiembrosProceso", "Congregantes")',
                    type: "GET",
                    dataType: "json",
                    dataSrc: "data"
                },
                columns: [
                    { data: "numero_miembro" },
                    { data: "nombre_miembro" },
                    { data: "apellidos_miembro" },
                    { data: "correo_electronico" },
                    { data: "telefono_movil" },
                    { data: "edad" },
                    {
                        data: "sexo",
                        render: function (valor) {
                            return valor
                                ? '<span class="badge bg-primary">Hombre</span>'
                                : '<span class="badge bg-warning text-dark">Mujer</span>';
                        }
                    },
                    { data: "nombre_sede" },
                    {
                            defaultContent: `
                            <div class="d-flex justify-content-center gap-2">
                                <button type="button" class="btn btn-primary btn-sm btn-editarMiembro">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button" class="btn btn-info btn-sm btn-abrirModalZonasGruposMinisterios">
                                    <i class="fas fa-sitemap"></i>
                                </button>
                                <button type="button" class="btn btn-danger btn-sm btn-eliminarMiembro">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>`,
                        orderable: false,
                        searchable: false,
                        width: "140px",
                        className: "text-center align-middle"
                    }
                ],
                language: { url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json" }
            });

                $("#tablaMiembros tbody").on("click", ".btn-abrirModalZonasGruposMinisterios", function () {
            const fila = $(this).closest("tr");
            const data = tabladata.row(fila).data();

            console.log("Miembro seleccionado:", data);

            abrirModalZonasGruposMinisterios(data);
        });

            $("#tablaMiembros tbody").on("click", ".btn-editarMiembro", function () {
                filaSeleccionada = $(this).closest("tr");
                var data = tabladata.row(filaSeleccionada).data();
                abrirModalMiembros(data);
            });

            $("#tablaMiembros tbody").on("click", ".btn-eliminarMiembro", function () {
                const fila = $(this).closest("tr");
                const data = tabladata.row(fila).data();

                Swal.fire({
                    title: "¿Estás seguro?",
                    text: `Desea eliminar al miembro ${data.nombre_miembro} ${data.apellidos_miembro}?`,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Sí, eliminar",
                    cancelButtonText: "No"
                }).then(result => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("EliminarMiembro", "Congregantes")',
                            type: "POST",
                            data: { id: data.iD_miembro },
                            success: function (res) {
                                if (res.resultado) {
                                    tabladata.row(fila).remove().draw();
                                    Swal.fire("Eliminado!", "El miembro ha sido eliminado.", "success");
                                } else {
                                    Swal.fire("Error", res.mensaje, "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error", "No se pudo eliminar al miembro", "error");
                            }
                        });
                    }
                });
            });

            $("#cboProvincia").change(function() {
                var provinciaSeleccionadaId = $(this).val();
                if (provinciaSeleccionadaId !== "0" && provinciaSeleccionadaId !== null) {
                    cargarMunicipios(provinciaSeleccionadaId, 0);
                } else {
                    $("#cboMunicipio").empty().append('<option value="0" disabled selected>Selecciona un municipio</option>').prop('disabled', true);
                }
            });
        });

        // ✅ ABRIR MODAL MIEMBRO
        function abrirModalMiembros(data) {
            $("#mensajeError").hide().text("");

            if (!data) {
                //IDENTIFICADORES
                $("#txtid").val(0);
                $("#txtDiezmoIndividual").val();
                $("#txtDiezmoFamiliar").val();
                $("#txtNumeroMiembro").val();
                //FIN IDENTIFICADORES
                //INFORMACIÓN BÁSICA
                $("#txtNombres").val("");
                $("#txtApellido").val("");
                $("#txtCorreo_electronico").val("");
                $("#txtTelefonoMovil").val("");
                $("#txtTelefonoFijo").val("");
                $("#txtEdad").val("");
                $("#cboSexo").val("");
                $("#txtID_sede").val(loggedInSedeID);
                $("#txtSede").val(loggedInSedeNombre);
                //FIN INFORMACIÓN BÁSICA
                //DIRECCIÓN
                $("#txtDireccion").val("");
                $("#cboProvincia").val("0").change();
                $("#txtCP").val("");
                //FIN DIRECCIÓN
                //FECHAS
                $("#txtFechaLlegada").val("");
                $("#txtFechaBautismo").val("");
                $("#txtFechaCumpleanos").val("");
                $("#txtFechaBoda").val("");
                $("#txtFechaBaja").val("");
                $("#txtFechaFallecimiento").val("");
                //FIN FECHAS
                //INFORMACIÓN ADICIONAL
                $("#txtPais_nacimiento").val("");
                $("#cboEstadoCivil").val("");
                $("#cboEstado").val("");
                $("#checkAlumno_vyf").prop("checked", false);
                $("#checkCurso_acabado").prop("checked", false);
                $("#checkExcluir_directorio").prop("checked", false);
                $("#chechFallecido").prop("checked", false);
                $("#checkBautizado").prop("checked", false);
                $("#txtLugarBautismo").val("");
                $("#txtPersonaCargo").val("");
