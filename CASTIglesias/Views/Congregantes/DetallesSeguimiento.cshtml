@{
    ViewBag.Title = "Detalle de seguimiento";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .autocomplete-dropdown {
        position: fixed;
        z-index: 9999;
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        border-radius: 0 0 .375rem .375rem;
        background: #fff;
        box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }
    .autocomplete-wrapper { position: relative; }
    .badge-visita     { background-color: #0d6efd; }
    .badge-llamada    { background-color: #198754; }
    .badge-consejeria { background-color: #fd7e14; }
</style>

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="#">Resumen</a></li>
    <li class="breadcrumb-item active">Detalle de seguimiento</li>
</ol>

<!-- PANEL FILTROS -->
<div class="card mb-3">
    <div class="card-header" style="background-color: #1E3A8A; color: white;">
        <i class="fas fa-search me-1"></i> Buscar miembro
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <!-- Miembro -->
            <div class="col-md-4">
                <label class="form-label fw-semibold">Nombre del miembro</label>
                <div class="autocomplete-wrapper">
                    <input type="text" class="form-control" id="txtBuscarMiembro"
                           autocomplete="off" placeholder="Escriba al menos 2 caracteres...">
                    <div id="dropdownBuscarMiembro" class="autocomplete-dropdown list-group" style="display:none;"></div>
                </div>
                <input type="hidden" id="hiddenFiltroIdMiembro" value="0" />
            </div>

            <!-- Tipo -->
            <div class="col-md-2">
                <label class="form-label fw-semibold">Tipo</label>
                <select class="form-select" id="selectTipo">
                    <option value="">Todos</option>
                    <option value="Visita">Visita</option>
                    <option value="Llamada">Llamada</option>
                    <option value="Consejeria">Consejería</option>
                </select>
            </div>

            <!-- Año -->
            <div class="col-md-2">
                <label class="form-label fw-semibold">Año</label>
                <select class="form-select" id="selectAnio"></select>
            </div>

            <!-- Fechas personalizadas (ocultas por defecto) -->
            <div class="col-md-3" id="panelFechasPersonalizadas" style="display:none;">
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Desde</label>
                        <input type="date" class="form-control" id="txtFiltroDesde">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Hasta</label>
                        <input type="date" class="form-control" id="txtFiltroHasta">
                    </div>
                </div>
            </div>

            <!-- Botón buscar -->
            <div class="col-md-1">
                <button class="btn btn-primary w-100" onclick="aplicarFiltros()" title="Buscar">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- TABLA DE DETALLES -->
<div class="card">
    <div class="card-header" style="background-color: #1E3A8A; color:white;">
        <i class="fas fa-user me-1"></i> <span id="lblMiembroSeleccionado">Ningún miembro seleccionado</span>
    </div>
    <div class="table-responsive p-3">
        <div id="mensajeSinMiembro" class="text-center text-muted py-4">
            <i class="fas fa-search fa-2x mb-2 d-block"></i>
            Busca un miembro para ver su historial de seguimiento.
        </div>
        <table id="tablaDetalles" class="table table-bordered table-striped border-top" style="width:100%; display:none;">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th>Fecha</th>
                    <th>Persona a cargo</th>
                    <th>Observaciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
    var tablaDetalles;
    var miembroActual = null;

    $(document).ready(function () {
        // ── Poblar selector de año ────────────────────────────────
        var anioActual = new Date().getFullYear();
        for (var y = anioActual; y >= anioActual - 6; y--) {
            var sel = (y === anioActual) ? ' selected' : '';
            $('#selectAnio').append('<option value="' + y + '"' + sel + '>' + y + '</option>');
        }
        $('#selectAnio').append('<option value="personalizado">Personalizado</option>');

        $('#selectAnio').on('change', function () {
            $('#panelFechasPersonalizadas').toggle($(this).val() === 'personalizado');
        });

        // ── Inicializar DataTable SIN ajax (datos vacíos) ─────────
        tablaDetalles = $('#tablaDetalles').DataTable({
            data: [],
            columns: [
                {
                    data: 'tipo_seguimiento',
                    render: function (val) {
                        var cls   = val === 'Visita'  ? 'badge-visita'
                                  : val === 'Llamada' ? 'badge-llamada'
                                  : 'badge-consejeria';
                        var label = val === 'Consejeria' ? 'Consejería' : (val || '');
                        return '<span class="badge ' + cls + '">' + label + '</span>';
                    }
                },
                {
                    data: 'fecha',
                    render: function (val) { return val ? val.substring(0, 10) : '—'; }
                },
                { data: 'persona_cargo', defaultContent: '' },
                { data: 'observaciones', defaultContent: '' }
            ],
            language: {
                url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json',
                emptyTable: 'No hay registros de seguimiento para este miembro.'
            },
            responsive: true,
            order: [[1, 'desc']]
        });
    });

    // ─── HELPER: POSICIONAR DROPDOWN FIXED ───────────────────────
    function posicionarDropdown(inputId, ddId) {
        var rect = document.getElementById(inputId).getBoundingClientRect();
        var dd = document.getElementById(ddId);
        dd.style.top   = (rect.bottom + window.scrollY) + 'px';
        dd.style.left  = rect.left + 'px';
        dd.style.width = rect.width + 'px';
    }

    // ─── AUTOCOMPLETE FILTRO PRINCIPAL ────────────────────────────
    var timerFiltro;
    $('#txtBuscarMiembro').on('input', function () {
        var term = $(this).val().trim();
        $('#hiddenFiltroIdMiembro').val(0);
        clearTimeout(timerFiltro);
        if (term.length < 2) { $('#dropdownBuscarMiembro').hide().empty(); return; }
        timerFiltro = setTimeout(function () {
            $.ajax({
                url: '@Url.Action("BuscarMiembros", "Congregantes")',
                type: 'GET',
                data: { term: term },
                success: function (res) {
                    var dd = $('#dropdownBuscarMiembro');
                    dd.empty();
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function (m) {
                            var nombre = ((m.nombre_miembro || '') + ' ' + (m.apellidos_miembro || '')).trim();
                            $('<button type="button">')
                                .addClass('list-group-item list-group-item-action')
                                .text(nombre)
                                .on('mousedown', function (e) {
                                    e.preventDefault();
                                    miembroActual = { id: m.id_miembro, nombre: m.nombre_miembro || '', apellidos: m.apellidos_miembro || '' };
                                    $('#hiddenFiltroIdMiembro').val(m.id_miembro);
                                    $('#txtBuscarMiembro').val(nombre);
                                    dd.hide().empty();
                                    cargarTabla();
                                })
                                .appendTo(dd);
                        });
                        posicionarDropdown('txtBuscarMiembro', 'dropdownBuscarMiembro');
                        dd.show();
                    } else {
                        dd.hide();
                    }
                }
            });
        }, 300);
    });

    // ─── CARGAR TABLA ─────────────────────────────────────────────
    function obtenerFechasFiltro() {
        var anio = $('#selectAnio').val();
        if (anio === 'personalizado') {
            return { desde: $('#txtFiltroDesde').val(), hasta: $('#txtFiltroHasta').val() };
        }
        return { desde: anio + '-01-01', hasta: anio + '-12-31' };
    }

    function cargarTabla() {
        var idMiembro = parseInt($('#hiddenFiltroIdMiembro').val());
        if (idMiembro <= 0) {
            Swal.fire('Atención', 'Primero selecciona un miembro de la lista.', 'warning');
            return;
        }

        var tipo   = $('#selectTipo').val();
        var fechas = obtenerFechasFiltro();

        var params = { idMiembro: idMiembro };
        if (tipo)          params.tipo       = tipo;
        if (fechas.desde)  params.fechaDesde = fechas.desde;
        if (fechas.hasta)  params.fechaHasta = fechas.hasta;

        var nombreCompleto = (miembroActual ? miembroActual.nombre + ' ' + miembroActual.apellidos : '').trim();
        $('#lblMiembroSeleccionado').text(nombreCompleto || 'Miembro seleccionado');
        $('#mensajeSinMiembro').hide();
        $('#tablaDetalles').show();

        $.ajax({
            url: '@Url.Action("ListarDetallesSeguimiento", "Congregantes")',
            type: 'GET',
            data: params,
            success: function (res) {
                tablaDetalles.clear().rows.add(res.data || []).draw();
            },
            error: function () {
                Swal.fire('Error', 'No se pudieron cargar los datos.', 'error');
            }
        });
    }

    function aplicarFiltros() {
        cargarTabla();
    }

    // Cerrar dropdowns al hacer clic fuera
    $(document).on('click', function (e) {
        if (!$(e.target).closest('.autocomplete-wrapper').length) {
            $('.autocomplete-dropdown').hide().empty();
        }
    });
</script>
}
