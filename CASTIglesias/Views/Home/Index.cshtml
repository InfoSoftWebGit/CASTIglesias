@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="mt-4">Dashboard</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active"></li>
</ol>

<div class="row">
    <div class="col-xl-3 col-md-6">
        <div class="card bg-primary text-white mb-4">
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-9">
                        <h6>Total de Miembros</h6>
                        <h6 id="totalmiembros"></h6>
                    </div>
                    <div class="col-sm-3">
                        <i class="fas fa-user fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row" id="contenedor-zonas">
</div>

<hr class="my-4" />

<div class="col-xl-3 col-md-6">
    <div class="card bg-success text-white mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-sm-9">
                    <h6>Diezmos totales</h6>
                    <h6 id="totalDiezmo"></h6>
                </div>
                <div class="col-sm-3">
                    <i class="fas fa-hand-holding-heart fa-2x"></i>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-tags me-1"></i>
        Historial de Diezmos
    </div>
    @* NOTA: Se ha quitado el atributo asp-action/asp-controller del form, ya que la exportación se maneja con JS. *@
    <form method="post">
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-sm-2">
                    <label class="form-label">Fecha de inicio</label>
                    <input class="form-control" type="text" id="txtFechaInicio" name="fechainicio" />
                </div>
                <div class="col-sm-2">
                    <label class="form-label">Fecha de fin</label>
                    <input class="form-control" type="text" id="txtFechaFin" name="fechafin" />
                </div>
                <div class="col-sm-2 d-grid">
                    <button class="btn btn-primary" id="btnbuscar" type="button">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                </div>
                <div class="col-sm-2 d-grid">
                    <button class="btn btn-success" type="button" id="btnExportar">
                        @* Cambiado a type="button" para manejar el submit con JS *@
                        <i class="fas fa-file-excel"></i> Exportar
                    </button>
                </div>
            </div>
        </div>
    </form>
    <hr />

    <div class="card-body">
        <div class="table-wrapper">
            <table id="tablaDashboard" class="table table-bordered table-striped border-top" style="width:100%">
                <thead>
                    <tr>
                        <td>Fecha de Diezmo</td>
                        <td>Miembro</td>
                        <td>Concepto</td>
                        <td>Cantidad</td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <script>
        var tabladata;

        // Función para convertir formato de fecha DD/MM/YYYY a YYYY-MM-DD
        function convertirDDMMYYYYaYYYYMMDD(fecha) {
            if (!fecha) return "";
            const partes = fecha.split("/");
            // Asegura el formato YYYY-MM-DD
            return `${partes[2]}-${partes[1]}-${partes[0]}`;
        }

        // Función para cargar y actualizar el total de diezmos
        function cargarTotalDiezmos() {
            const fechaInicio = $("#txtFechaInicio").val();
            const fechaFin = $("#txtFechaFin").val();

            if (!fechaInicio || !fechaFin) {
                $("#totalDiezmo").text('0.00 €');
                return;
            }

            const fechaInicioFormatted = convertirDDMMYYYYaYYYYMMDD(fechaInicio);
            const fechaFinFormatted = convertirDDMMYYYYaYYYYMMDD(fechaFin);

            $.get('@Url.Action("SumaDiezmosTotales", "Home")', { fechainicio: fechaInicioFormatted, fechafin: fechaFinFormatted }, function (data) {
                let total = data.total ?? 0;
                $("#totalDiezmo").text(
                    parseFloat(total).toLocaleString('es-ES', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 })
                );
            }).fail(function() {
                $("#totalDiezmo").text('Error');
            });
        }

        //Cargar y generar las tarjetas de zonas dinámicamente
                function cargarTarjetasZonas() {
            $.get('@Url.Action("ObtenerZonasConMiembros", "Home")', function (data) {
                console.log("📦 Datos recibidos:", data);
                const contenedorZonas = $('#contenedor-zonas');
                contenedorZonas.empty();

                if (Array.isArray(data) && data.length > 0) {
                    data.forEach(function (zona) {
                        const tarjetaHtml = `
                            <div class="col-xl-3 col-md-6">
                                <div class="card bg-warning text-white mb-4">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-sm-9">
                                                <h6>Total en zona ${zona.nombre_zona}</h6>
                                                <h6>${zona.total_miembros}</h6>
                                            </div>
                                            <div class="col-sm-3">
                                                <i class="fa-solid fa-users fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        contenedorZonas.append(tarjetaHtml);
                    });
                } else {
                    console.warn("⚠️ No se encontraron zonas o data vacío.");
                }
            }).fail(function (xhr) {
                console.error("❌ Error en la petición:", xhr.responseText);
            });
        }


        $(document).ready(function () {
                    $.get('@Url.Action("ContadorMiembros", "Congregantes")', function (data) {
            const total = data.resultado ?? 0;
            $("#totalmiembros").text(total);
        }).fail(function() {
            $("#totalmiembros").text('Error');
        });

            // Llamar a la función para generar las tarjetas de zonas
            cargarTarjetasZonas();

            // Lógica de inicialización de los datepickers
            var fechaActual = new Date();
            var primerDiaMes = new Date(fechaActual.getFullYear(), fechaActual.getMonth(), 1);
            $("#txtFechaInicio").datepicker({ dateFormat: 'dd/mm/yy' }).datepicker('setDate', primerDiaMes);
            $("#txtFechaFin").datepicker({ dateFormat: 'dd/mm/yy' }).datepicker('setDate', fechaActual);

            // Llamada inicial para cargar el total de diezmos
            cargarTotalDiezmos();

            // Lógica de URL para Datatable
            function obtenerUrlHistorial() {
                const fechaInicio = $("#txtFechaInicio").val();
                const fechaFin = $("#txtFechaFin").val();
                const fechaInicioFormatted = convertirDDMMYYYYaYYYYMMDD(fechaInicio);
                const fechaFinFormatted = convertirDDMMYYYYaYYYYMMDD(fechaFin);
                return `@Url.Action("ObtenerHistorialDiezmos", "Home")?fechainicio=${encodeURIComponent(fechaInicioFormatted)}&fechafin=${encodeURIComponent(fechaFinFormatted)}`;
            }

            // Lógica de DataTable
            tabladata = $("#tablaDashboard").DataTable({
                responsive: true,
                ordering: false,
                ajax: {
                    url: obtenerUrlHistorial(),
                    type: "GET",
                    dataSrc: function (json) {
                        return json;
                    }
                },
                columns: [
                    {
                        data: "fecha_diezmo",
                        render: function (data) {
                            var date = new Date(data);
                            return ("0" + date.getDate()).slice(-2) + "/" +
                                ("0" + (date.getMonth() + 1)).slice(-2) + "/" +
                                date.getFullYear();
                        }
                    },
                    { data: "nombre_miembro" },
                    { data: "nombre_concepto" },
                    {
                        data: "cantidad_diezmo",
                        render: function (data) {
                            return parseFloat(data).toLocaleString('es-ES', {
                                style: 'currency',
                                currency: 'EUR',
                                minimumFractionDigits: 2
                            });
                        }
                    }
                ],
                language: { url: "https://cdn.datatables.net/plug-ins/2.3.0/i18n/es-ES.json" }
            });

            // Evento para el botón Buscar y para los cambios de fecha
            $('#btnbuscar, #txtFechaInicio, #txtFechaFin').on('click change', function () {
                cargarTotalDiezmos();
                tabladata.ajax.url(obtenerUrlHistorial()).load();
            });

            // Lógica para el botón Exportar
            $('#btnExportar').click(function () {
                const fechaInicio = $("#txtFechaInicio").val(); // Ej: "01/05/2025"
                const fechaFin = $("#txtFechaFin").val();      // Ej: "26/09/2025"

                // ⭐ CAMBIO CLAVE: Transformar las fechas de DD/MM/YYYY a YYYY-MM-DD
                const fechaInicioExport = convertirDDMMYYYYaYYYYMMDD(fechaInicio);
                const fechaFinExport = convertirDDMMYYYYaYYYYMMDD(fechaFin);

                var form = $('<form></form>');
                form.attr("method", "POST");
                form.attr("action", '@Url.Action("ExportarHistorialDiezmo", "Home")');

                var inputFechaInicio = $("<input></input>");
                inputFechaInicio.attr("type", "hidden");
                inputFechaInicio.attr("name", "fechainicio");
                inputFechaInicio.attr("value", fechaInicioExport); // Usar fecha transformada
                form.append(inputFechaInicio);

                var inputFechaFin = $("<input></input>");
                inputFechaFin.attr("type", "hidden");
                inputFechaFin.attr("name", "fechafin");
                inputFechaFin.attr("value", fechaFinExport); // Usar fecha transformada
                form.append(inputFechaFin);

                form.appendTo('body').submit().remove();
            });

        }); // Fin de $(document).ready
    </script>
}