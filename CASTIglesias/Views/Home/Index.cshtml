@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="mt-4">Dashboard</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active"></li>
</ol>

<div class="row">
    <div class="col-xl-3 col-md-6">
        <div class="card text-white mb-4" style="background-color: #6B7280;">
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-9">
                        <h6>Total de Visitantes</h6>
                        <h6 id="totalvisitantes"></h6>
                    </div>
                    <div class="col-sm-3">
                        <i class="fas fa-user-clock fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card text-white mb-4" style="background-color: #00BFA5;">
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-9">
                        <h6>Total de Simpatizantes</h6>
                        <h6 id="totalsimpatizantes"></h6>
                    </div>
                    <div class="col-sm-3">
                        <i class="fas fa-user-tag fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card text-white mb-4" style="background-color: #1E3A8A;">
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-9">
                        <h6>Total En Proceso</h6>
                        <h6 id="totalenproceso"></h6>
                    </div>
                    <div class="col-sm-3">
                        <i class="fas fa-user-cog fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card text-white mb-4" style="background-color: #0D1B3D;">
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-9">
                        <h6>Total de Miembros</h6>
                        <h6 id="totalmiembros"></h6>
                    </div>
                    <div class="col-sm-3">
                        <i class="fas fa-user fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row" id="contenedor-zonas">
</div>

<hr class="my-4" />

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-chart-bar me-1"></i>
        Asistencia al Culto
    </div>
    <div class="card-body">
        <div class="row align-items-end mb-3 g-2">
            <div class="col-sm-3 col-md-2">
                <label class="form-label fw-semibold">Vista</label>
                <select class="form-select form-select-sm" id="modoGrafico">
                    <option value="anual">Año completo</option>
                    <option value="mensual">Mes completo</option>
                    <option value="diario">Día específico</option>
                </select>
            </div>
            <div class="col-sm-3 col-md-2">
                <label class="form-label fw-semibold">Turno</label>
                <select class="form-select form-select-sm" id="turnoGrafico">
                    <option value="todos">Todos</option>
                    <option value="mañana">Mañana</option>
                    <option value="tarde">Tarde</option>
                </select>
            </div>
            <div class="col-sm-2 col-md-1">
                <label class="form-label fw-semibold">Año</label>
                <input type="number" class="form-control form-control-sm" id="anioGrafico" min="2000" max="2099" />
            </div>
            <div class="col-sm-3 col-md-2" id="colMesGrafico" style="display:none">
                <label class="form-label fw-semibold">Mes</label>
                <select class="form-select form-select-sm" id="mesGrafico">
                    <option value="1">Enero</option>
                    <option value="2">Febrero</option>
                    <option value="3">Marzo</option>
                    <option value="4">Abril</option>
                    <option value="5">Mayo</option>
                    <option value="6">Junio</option>
                    <option value="7">Julio</option>
                    <option value="8">Agosto</option>
                    <option value="9">Septiembre</option>
                    <option value="10">Octubre</option>
                    <option value="11">Noviembre</option>
                    <option value="12">Diciembre</option>
                </select>
            </div>
            <div class="col-sm-2 col-md-1" id="colDiaGrafico" style="display:none">
                <label class="form-label fw-semibold">Día</label>
                <input type="number" class="form-control form-control-sm" id="diaGrafico" min="1" max="31" />
            </div>
            <div class="col-sm-2 col-md-1">
                <button class="btn btn-primary btn-sm w-100" id="btnActualizarGrafico">
                    <i class="fas fa-sync-alt"></i> Actualizar
                </button>
            </div>
        </div>
        <div style="position:relative; height:350px;">
            <canvas id="graficoAsistencia"></canvas>
        </div>
        <p class="text-muted text-center mt-2 mb-0" id="graficoSinDatos" style="display:none">
            <i class="fas fa-info-circle"></i> No hay registros de asistencia para el período seleccionado.
        </p>
    </div>
</div>

<hr class="my-4" />

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-hand-holding-usd me-1"></i>
        Diezmos por Concepto
    </div>
    <div class="card-body">
        <div class="row align-items-end mb-3 g-2">
            <div class="col-sm-3 col-md-2">
                <label class="form-label fw-semibold">Vista</label>
                <select class="form-select form-select-sm" id="modoDiezmo">
                    <option value="anual">Año completo</option>
                    <option value="mensual">Mes completo</option>
                </select>
            </div>
            <div class="col-sm-2 col-md-1">
                <label class="form-label fw-semibold">Año</label>
                <input type="number" class="form-control form-control-sm" id="anioDiezmo" min="2000" max="2099" />
            </div>
            <div class="col-sm-3 col-md-2" id="colMesDiezmo" style="display:none">
                <label class="form-label fw-semibold">Mes</label>
                <select class="form-select form-select-sm" id="mesDiezmo">
                    <option value="1">Enero</option>
                    <option value="2">Febrero</option>
                    <option value="3">Marzo</option>
                    <option value="4">Abril</option>
                    <option value="5">Mayo</option>
                    <option value="6">Junio</option>
                    <option value="7">Julio</option>
                    <option value="8">Agosto</option>
                    <option value="9">Septiembre</option>
                    <option value="10">Octubre</option>
                    <option value="11">Noviembre</option>
                    <option value="12">Diciembre</option>
                </select>
            </div>
            <div class="col-sm-2 col-md-1">
                <button class="btn btn-primary btn-sm w-100" id="btnActualizarDiezmo">
                    <i class="fas fa-sync-alt"></i> Actualizar
                </button>
            </div>
        </div>
        <div style="position:relative; height:350px;">
            <canvas id="graficoDiezmos"></canvas>
        </div>
        <p class="text-muted text-center mt-2 mb-0" id="diezmoSinDatos" style="display:none">
            <i class="fas fa-info-circle"></i> No hay registros de diezmos para el período seleccionado.
        </p>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    <script>
        function cargarTarjetasZonas() {
            $.get('@Url.Action("ObtenerZonasConMiembros", "Home")', function (data) {
                const contenedorZonas = $('#contenedor-zonas');
                contenedorZonas.empty();
                if (Array.isArray(data) && data.length > 0) {
                    data.forEach(function (zona) {
                        const tarjetaHtml = `
                            <div class="col-xl-3 col-md-6">
                                <div class="card text-white mb-4" style="background-color: #1E3A8A;">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-sm-9">
                                                <h6>Total en zona ${zona.nombre_zona}</h6>
                                                <h6>${zona.total_miembros}</h6>
                                            </div>
                                            <div class="col-sm-3">
                                                <i class="fa-solid fa-users fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        contenedorZonas.append(tarjetaHtml);
                    });
                }
            });
        }

        $(document).ready(function () {
            $.get('@Url.Action("ContadorMiembros", "Congregantes")', function (data) {
                $("#totalmiembros").text(data.resultado ?? 0);
            }).fail(function () { $("#totalmiembros").text('Error'); });

            $.get('@Url.Action("ContadorVisitantes", "Congregantes")', function (data) {
                $("#totalvisitantes").text(data.resultado ?? 0);
            }).fail(function () { $("#totalvisitantes").text('Error'); });

            $.get('@Url.Action("ContadorSimpatizantes", "Congregantes")', function (data) {
                $("#totalsimpatizantes").text(data.resultado ?? 0);
            }).fail(function () { $("#totalsimpatizantes").text('Error'); });

            $.get('@Url.Action("ContadorEnProceso", "Congregantes")', function (data) {
                $("#totalenproceso").text(data.resultado ?? 0);
            }).fail(function () { $("#totalenproceso").text('Error'); });

            cargarTarjetasZonas();
        });
    </script>

    <script>
        // ── Gráfico de Asistencia al Culto ──────────────────────────────
        let graficoAsistenciaInstance = null;

        const hoy = new Date();
        $('#anioGrafico').val(hoy.getFullYear());
        $('#mesGrafico').val(hoy.getMonth() + 1);
        $('#diaGrafico').val(hoy.getDate());

        function actualizarVisibilidadFiltros() {
            const modo = $('#modoGrafico').val();
            $('#colMesGrafico').toggle(modo === 'mensual' || modo === 'diario');
            $('#colDiaGrafico').toggle(modo === 'diario');
        }

        function cargarGraficoAsistencia() {
            const modo = $('#modoGrafico').val();
            const anio = $('#anioGrafico').val();
            const mes  = $('#mesGrafico').val();
            const dia  = $('#diaGrafico').val();

            const turno = $('#turnoGrafico').val();
            const params = { modo, anio, turno };
            if (modo === 'mensual' || modo === 'diario') params.mes = mes;
            if (modo === 'diario') params.dia = dia;

            $.get('@Url.Action("ObtenerGraficoAsistencia", "Home")', params, function (data) {
                $('#graficoSinDatos').toggle(!data || data.length === 0);

                const labels    = data.map(d => d.etiqueta);
                const adultos   = data.map(d => d.adultos);
                const ninos     = data.map(d => d.ninos);
                const invitados = data.map(d => d.invitados);

                if (graficoAsistenciaInstance) {
                    graficoAsistenciaInstance.destroy();
                    graficoAsistenciaInstance = null;
                }

                if (!data || data.length === 0) return;

                graficoAsistenciaInstance = new Chart(
                    document.getElementById('graficoAsistencia'),
                    {
                        type: 'bar',
                        data: {
                            labels,
                            datasets: [
                                {
                                    label: 'Adultos',
                                    data: adultos,
                                    backgroundColor: 'rgba(54, 162, 235, 0.75)',
                                    borderColor:     'rgba(54, 162, 235, 1)',
                                    borderWidth: 1
                                },
                                {
                                    label: 'Niños',
                                    data: ninos,
                                    backgroundColor: 'rgba(75, 192, 192, 0.75)',
                                    borderColor:     'rgba(75, 192, 192, 1)',
                                    borderWidth: 1
                                },
                                {
                                    label: 'Invitados / Visitantes',
                                    data: invitados,
                                    backgroundColor: 'rgba(255, 159, 64, 0.75)',
                                    borderColor:     'rgba(255, 159, 64, 1)',
                                    borderWidth: 1
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'top' },
                                tooltip: {
                                    callbacks: {
                                        footer: function (items) {
                                            const total = items.reduce((s, i) => s + i.parsed.y, 0);
                                            return 'Total: ' + total;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: { stacked: false },
                                y: {
                                    beginAtZero: true,
                                    ticks: { stepSize: 1, precision: 0 }
                                }
                            }
                        }
                    }
                );
            }).fail(function () {
                $('#graficoSinDatos').show();
            });
        }

        $('#modoGrafico').on('change', function () { actualizarVisibilidadFiltros(); });
        $('#btnActualizarGrafico').on('click', cargarGraficoAsistencia);

        $(document).ready(function () {
            actualizarVisibilidadFiltros();
            cargarGraficoAsistencia();
        });
    </script>

    <script>
        // ── Gráfico de Diezmos por Concepto ──────────────────────────────
        let graficoDiemosInstance = null;

        const coloresDiezmo = [
            { bg: 'rgba( 30,  58, 138, 0.8)', border: 'rgba( 30,  58, 138, 1)' },
            { bg: 'rgba(  0, 191, 165, 0.8)', border: 'rgba(  0, 191, 165, 1)' },
            { bg: 'rgba(245, 158,  11, 0.8)', border: 'rgba(245, 158,  11, 1)' },
            { bg: 'rgba(239,  68,  68, 0.8)', border: 'rgba(239,  68,  68, 1)' },
            { bg: 'rgba(139,  92, 246, 0.8)', border: 'rgba(139,  92, 246, 1)' },
            { bg: 'rgba(236,  72, 153, 0.8)', border: 'rgba(236,  72, 153, 1)' },
            { bg: 'rgba( 16, 185, 129, 0.8)', border: 'rgba( 16, 185, 129, 1)' },
            { bg: 'rgba(251, 146,  60, 0.8)', border: 'rgba(251, 146,  60, 1)' },
        ];

        const hoyDiezmo = new Date();
        $('#anioDiezmo').val(hoyDiezmo.getFullYear());
        $('#mesDiezmo').val(hoyDiezmo.getMonth() + 1);

        $('#modoDiezmo').on('change', function () {
            $('#colMesDiezmo').toggle($(this).val() === 'mensual');
        });

        function cargarGraficoDiezmos() {
            const modo = $('#modoDiezmo').val();
            const anio = $('#anioDiezmo').val();
            const mes  = $('#mesDiezmo').val();
            const params = { modo, anio };
            if (modo === 'mensual') params.mes = mes;

            $.get('@Url.Action("ObtenerGraficoDiezmos", "Home")', params, function (res) {
                const sinDatos = !res.series || res.series.length === 0 ||
                                 res.series.every(s => s.datos.every(v => v === 0));
                $('#diezmoSinDatos').toggle(sinDatos);

                if (graficoDiemosInstance) {
                    graficoDiemosInstance.destroy();
                    graficoDiemosInstance = null;
                }
                if (sinDatos) return;

                const datasets = res.series.map(function (s, i) {
                    const c = coloresDiezmo[i % coloresDiezmo.length];
                    return {
                        label: s.concepto,
                        data: s.datos,
                        backgroundColor: c.bg,
                        borderColor: c.border,
                        borderWidth: 1
                    };
                });

                graficoDiemosInstance = new Chart(document.getElementById('graficoDiezmos'), {
                    type: 'bar',
                    data: { labels: res.labels, datasets },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'top' },
                            tooltip: {
                                callbacks: {
                                    label: function (item) {
                                        return ` ${item.dataset.label}: ${parseFloat(item.parsed.y).toLocaleString('es-ES', { style: 'currency', currency: 'EUR' })}`;
                                    },
                                    footer: function (items) {
                                        const total = items.reduce((s, i) => s + i.parsed.y, 0);
                                        return 'Total: ' + parseFloat(total).toLocaleString('es-ES', { style: 'currency', currency: 'EUR' });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: { stacked: false },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function (val) {
                                        return parseFloat(val).toLocaleString('es-ES', {
                                            style: 'currency', currency: 'EUR',
                                            minimumFractionDigits: 0, maximumFractionDigits: 0
                                        });
                                    }
                                }
                            }
                        }
                    }
                });
            }).fail(function () {
                $('#diezmoSinDatos').show();
            });
        }

        $('#btnActualizarDiezmo').on('click', cargarGraficoDiezmos);

        $(document).ready(function () {
            cargarGraficoDiezmos();
        });
    </script>
}