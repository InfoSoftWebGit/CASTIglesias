    </style> *@
</head>

<body class="sb-nav-fixed">

    <!-- NAV SUPERIOR -->
    <nav class="sb-topnav navbar navbar-expand">
        <a class="navbar-brand ps-3" href="@Url.Action("Index", "Home")" style="font-weight: 700; font-size: 1.3rem; letter-spacing: 0.5px;">
            <span style="color: #00BFA5;">Congrega</span><span style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 400; margin-left: 4px;">CRM</span>
        </a>

        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle" style="color: rgba(255,255,255,0.7);">
            <i class="fas fa-bars"></i>
        </button>

        <ul class="navbar-nav ms-auto me-0 me-md-3 my-2 my-md-0">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" id="opcionesUsuario" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: rgba(255,255,255,0.7);">
                    <i class="fas fa-user fa-fw"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="opcionesUsuario">
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item" href="@Url.Action("CerrarSesion", "Acceso")">Cerrar sesión</a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-bar"></i></div>
                            Dashboard
                        </a>

                        @{
                            var tieneAccesoTotal = User.IsInRole("AdminGlobal") || User.IsInRole("PastorGeneral") || User.IsInRole("PastorSede");
                            var permisosMiembro = ViewBag.PermisosMiembro as Permisos ?? new Permisos();
                        }
                        <!-- BLOQUE ASISTENCIA -->
                        @if (tieneAccesoTotal || permisosMiembro.Miembros || permisosMiembro.Visitantes || permisosMiembro.Simpatizantes || permisosMiembro.Proceso || permisosMiembro.Familias || permisosMiembro.Matrimonios || permisosMiembro.Jovenes)
                        {
                            <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseCongregantes" aria-expanded="false">
                                <div class="sb-nav-link-icon"><i class="fas fa-check-square"></i></div>
                                Congregantes
                                <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down nav-link-collapse-icon"></i></div>
                            </a>
                            <div class="collapse" id="collapseCongregantes" data-bs-parent="#sidenavAccordion">
                                <nav class="sb-sidenav-menu-nested nav">
                                    @if (tieneAccesoTotal || permisosMiembro.Visitantes)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Visitantes", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-street-view">></i></div>
                                            Visitantes
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Simpatizantes)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Simpatizantes", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-handshake"></i></div>
                                            Simpatizantes
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Proceso)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Proceso", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-forward"></i></div>
                                            En proceso
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Miembros)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Miembros", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-user-check"></i></div>
                                            Miembros
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Familias)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Familias", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fa fa-heart"></i></div>
                                            Familias
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Matrimonios)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Matrimonios", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-ring"></i></div>
                                            Matrimonios
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Jovenes)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Jovenes", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-user-friends"></i></div>
                                            Jóvenes
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Miembros)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Lideres", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-user-tie"></i></div>
                                            Líderes
                                        </a>
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Seguimiento", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-clipboard-list"></i></div>
                                            Seguimiento
                                        </a>
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("DetallesSeguimiento", "Congregantes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-search"></i></div>
                                            Detalle de seguimiento
                                        </a>
                                    }
                                </nav>
                            </div>
                        }
                        <!-- BLOQUE MANTENIMIENTO -->
                        @if (tieneAccesoTotal || permisosMiembro.Zonas || permisosMiembro.Grupos || permisosMiembro.Ministerio)
                        {
                            <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseMantenimiento" aria-expanded="false">
                                <div class="sb-nav-link-icon"><i class="fas fa-cogs"></i></div>
                                Organización Pastoral
                                <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down nav-link-collapse-icon"></i></div>
                            </a>
                            <div class="collapse" id="collapseMantenimiento" data-bs-parent="#sidenavAccordion">
                                <nav class="sb-sidenav-menu-nested nav">
                                    @if (tieneAccesoTotal || permisosMiembro.Zonas)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Zonas", "Mantenedor")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-map-marker-alt"></i></div>
                                            Zonas
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Grupos)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Grupos", "Mantenedor")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-users-cog"></i></div>
                                            Grupos
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Ministerio)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Ministerios", "Mantenedor")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-users-cog"></i></div>
                                            Ministerios
                                        </a>
                                        <a class="nav-link collapsed-sub-item collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseServicios" aria-expanded="false">
                                            <div class="sb-nav-link-icon"><i class="fas fa-hands-helping"></i></div>
                                            Servicios
                                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down nav-link-collapse-icon"></i></div>
                                        </a>
                                        <div class="collapse" id="collapseServicios">
                                            <nav class="sb-sidenav-menu-nested nav" id="serviciosSubmenu" data-url-servicios="@Url.Action("Servicios", "Mantenedor")" data-url-listar="@Url.Action("ListarMinisterios", "Mantenedor")">
                                                <span class="nav-link collapsed-sub-item text-white-50" id="serviciosCargando" style="font-size: 0.85rem;">Cargando…</span>
                                            </nav>
                                        </div>
                                    }
                                </nav>
                            </div>
                        }

                        <!-- BLOQUE ECONOMÍA -->
                        @if (tieneAccesoTotal || permisosMiembro.Diezmos || permisosMiembro.Conceptos || permisosMiembro.Gastos)
                        {
                            <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseEconomia" aria-expanded="false">
                                <div class="sb-nav-link-icon"><i class="fas fa-hand-holding-usd"></i></div>
                                Finanzas
                                <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down nav-link-collapse-icon"></i></div>
                            </a>
                            <div class="collapse" id="collapseEconomia" data-bs-parent="#sidenavAccordion">
                                <nav class="sb-sidenav-menu-nested nav">
                                    @if (tieneAccesoTotal || permisosMiembro.Diezmos)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Diezmos", "Economia")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-coins"></i></div>
                                            Diezmos
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Conceptos)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Conceptos", "Economia")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-tags"></i></div>
                                            Conceptos
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Gastos)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Gastos", "Economia")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                                            Gastos
                                        </a>
                                    }
                                </nav>
                            </div>
                        }

                        <!-- BLOQUE ASISTENCIA -->
                        @if (tieneAccesoTotal || permisosMiembro.Asistencia)
                        {
                            <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseAsistencia" aria-expanded="false">
                                <div class="sb-nav-link-icon"><i class="fas fa-check-square"></i></div>
                                Control
                                <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down nav-link-collapse-icon"></i></div>
                            </a>
                            <div class="collapse" id="collapseAsistencia" data-bs-parent="#sidenavAccordion">
                                <nav class="sb-sidenav-menu-nested nav">
                                    @if (tieneAccesoTotal || permisosMiembro.Asistencia)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Asistencia", "Asistencia")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-tasks"></i></div>
                                            Asistencia
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Ajustes)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Cultos", "Mantenedor")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-church"></i></div>
                                            Cultos y Servicios
                                        </a>
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Calendarios", "Calendario")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-calendar-alt"></i></div>
                                            Calendarios
                                        </a>
                                    }
                                </nav>
                            </div>
                        }
                        @if (tieneAccesoTotal || permisosMiembro.Ajustes)
                        {
                            <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseAjustes" aria-expanded="false">
                                <div class="sb-nav-link-icon"><i class="fas fa-check-square"></i></div>
                                Ajustes
                                <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down nav-link-collapse-icon"></i></div>
                            </a>
                            <div class="collapse" id="collapseAjustes" data-bs-parent="#sidenavAccordion">
                                <nav class="sb-sidenav-menu-nested nav">
                                    @if (tieneAccesoTotal || permisosMiembro.Usuarios)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Usuarios", "Mantenedor")">
                                            <div class="sb-nav-link-icon"><i class="fa-solid fa-handshake"></i></div>
                                            Usuarios
                                        </a>
                                    }
                                    @if (tieneAccesoTotal || permisosMiembro.Ajustes)
                                    {
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Diezmos", "Ajustes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-hashtag"></i></div>
                                            Diezmos
                                        </a>
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Jovenes", "Ajustes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-user-friends"></i></div>
                                            Jóvenes
                                        </a>
                                        <a class="nav-link collapsed-sub-item" href="@Url.Action("Servicios", "Ajustes")">
                                            <div class="sb-nav-link-icon"><i class="fas fa-church"></i></div>
                                            Servicios
                                        </a>
                                    }
                                </nav>
                            </div>
                        }
                    </div>
                    
                </div>
                <div class="sb-sidenav-footer">
                    <div class="small">Logged in as:</div>
                    <div class="fw-bold">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>

                    @if (User.HasClaim("Multisede", "true") || User.IsInRole("AdminGlobal") || User.IsInRole("PastorGeneral"))
                    {
                        <div class="dropup mt-2">
                            <button class="btn btn-link dropdown-toggle text-decoration-none text-white btn-sede-custom"
                                    id="dropdownSede"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="padding-left: 0; padding-right: 0;">
                                <i class="fas fa-church fa-fw me-1 text-white-50"></i>
                                Sede: @ViewBag.NombreSedeActual
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="dropdownSede">
                                @if (ViewBag.ListaSedes != null)
                                {
                                    @foreach (var sede in ViewBag.ListaSedes)
                                    {
                                        <li>
                                            <a class="dropdown-item @(sede.ID == ViewBag.SedeIDActual ? "active" : "")"
                                               href="#"
                                               onclick="cambiarSedeYRecargar(@sede.ID)">
                                                @sede.nombre_sede
                                            </a>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li><span class="dropdown-item disabled">No hay sedes disponibles.</span></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content" class="d-flex flex-column">
            <main class="flex-grow-1">
                <div class="container-fluid px-4">
                    @RenderBody()
                </div>
            </main>

            <footer class="py-4 bg-light mt-auto">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">© Desarrollado por Tiago y Ruben Lezcano. Todos los derechos reservados.</div>
                        <div>Soporte: <a href="mailto:soporte@congrega.es">soporte@congrega.es</a></div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Sidebar toggle
            const sidebarToggle = document.getElementById('sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', e => {
                    e.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                });
            }

            // Expandir menú activo
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.sb-sidenav-menu-nested a.nav-link').forEach(link => {
                const linkUrl = new URL(link.href).pathname.toLowerCase();
                if (currentPath === linkUrl || (linkUrl.endsWith('/') && currentPath.startsWith(linkUrl))) {
                    const collapseDiv = link.closest('.collapse');
                    if (collapseDiv) {
                        const collapseTargetId = '#' + collapseDiv.id;
                        $(collapseTargetId).collapse('show');
                        const parentLink = document.querySelector('[data-bs-target="' + collapseTargetId + '"]');
                        if (parentLink) {
                            parentLink.classList.remove('collapsed');
                            parentLink.setAttribute('aria-expanded', 'true');
                        }
                    }
                }
            });

            // Submenú dinámico de Servicios (lista los ministerios de la sede)
            const serviciosSubmenu = document.getElementById('serviciosSubmenu');
            if (serviciosSubmenu) {
                const urlBaseServicios = serviciosSubmenu.dataset.urlServicios;
                const urlListar = serviciosSubmenu.dataset.urlListar;
                const cargando = document.getElementById('serviciosCargando');

                $.get(urlListar, function (res) {
                    const ministerios = (res && res.data) ? res.data : [];
                    if (cargando) cargando.remove();

                    if (ministerios.length === 0) {
                        serviciosSubmenu.insertAdjacentHTML('beforeend',
                            '<span class="nav-link collapsed-sub-item text-white-50" style="font-size: 0.85rem;">Sin ministerios</span>');
                        return;
                    }

                    const currentPath = window.location.pathname.toLowerCase();
                    const currentId = new URLSearchParams(window.location.search).get('id');

                    function iconoMinisterio(nombre) {
                        if (!nombre) return 'fas fa-users-cog';
                        var n = nombre.toLowerCase();
                        if (n.includes('alabanza') || n.includes('sonido'))  return 'fas fa-music';
                        if (n.includes('emisi') || n.includes('cámara') || n.includes('camara')) return 'fas fa-video';
                        if (n.includes('bienvenida') || n.includes('seguridad') || n.includes('ugier')) return 'fas fa-handshake';
                        if (n.includes('proyecci'))  return 'fas fa-desktop';
                        if (n.includes('pastoral'))  return 'fas fa-book-open';
                        if (n.includes('misiones'))  return 'fas fa-route';
                        if (n.includes('redes'))     return 'fas fa-share-nodes';
                        return 'fas fa-users-cog';
                    }

                    ministerios.forEach(function (m) {
                        const link = document.createElement('a');
                        link.className = 'nav-link collapsed-sub-item';
                        link.href = urlBaseServicios + '?id=' + m.id;
                        link.innerHTML = '<div class="sb-nav-link-icon"><i class="' + iconoMinisterio(m.descripcion) + '"></i></div>' +
                            $('<div>').text(m.descripcion || '').html();
                        serviciosSubmenu.appendChild(link);

                        // Mantener abierto y marcar activo si estamos en esta vista de servicio
                        if (currentPath === urlBaseServicios.toLowerCase() && String(m.id) === currentId) {
                            link.classList.add('active');
                            $('#collapseServicios').collapse('show');
                            $('#collapseMantenimiento').collapse('show');
                            const parentLink = document.querySelector('[data-bs-target="#collapseMantenimiento"]');
                            if (parentLink) { parentLink.classList.remove('collapsed'); parentLink.setAttribute('aria-expanded', 'true'); }
                            const serviciosLink = document.querySelector('[data-bs-target="#collapseServicios"]');
                            if (serviciosLink) { serviciosLink.classList.remove('collapsed'); serviciosLink.setAttribute('aria-expanded', 'true'); }
                        }
                    });
                });
            }

            // Dropdown sede estable
            const sedeBtn = document.getElementById('dropdownSede');
            if (sedeBtn) {
                new bootstrap.Dropdown(sedeBtn, {
                    popperConfig: { strategy: 'fixed' }
                });
            }
        });

        // Cambiar sede
        function cambiarSedeYRecargar(nuevoSedeID) {
            const returnUrl = window.location.pathname + window.location.search;
            $.ajax({
                type: "POST",
                url: "/Home/CambiarSede",
                data: { nuevoSedeID, returnUrl },
                success: function (response) {
                    if (response.success && response.redirectUrl)
                        window.location.href = response.redirectUrl;
                    else
                        alert("Error al cambiar de sede: " + (response.message || "Desconocido"));
                },
                error: function () {
                    alert("Error de conexión al cambiar de sede. Inténtalo de nuevo.");
                }
            });
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
