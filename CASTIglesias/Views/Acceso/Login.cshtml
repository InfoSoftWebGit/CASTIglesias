@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión - Congrega</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: url('/img/login-bg.jpg') center center / cover no-repeat fixed;
        }

        .login-overlay {
            position: fixed;
            inset: 0;
            background: rgba(13, 27, 61, 0.72);
            z-index: 0;
        }

        #layoutAuthentication {
            position: relative;
            z-index: 1;
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: rgba(255, 255, 255, 0.97);
            border-radius: 16px;
            box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
            overflow: hidden;
        }

        .login-card-header {
            background-color: #1E3A8A;
            padding: 2rem 2rem 1.5rem;
            text-align: center;
            border-bottom: 3px solid #00BFA5;
        }

        .login-logo {
            font-size: 2.1rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            line-height: 1;
        }

        .login-logo .brand { color: #00BFA5; }
        .login-logo .sub {
            color: rgba(255, 255, 255, 0.45);
            font-size: 0.75rem;
            font-weight: 400;
            margin-left: 5px;
            vertical-align: middle;
        }

        .login-subtitle {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.875rem;
            margin-top: 0.5rem;
            font-style: italic;
        }

        .login-card-body {
            padding: 2rem;
        }

        .form-floating .form-control:focus {
            border-color: #1E3A8A;
            box-shadow: 0 0 0 0.15rem rgba(30, 58, 138, 0.18);
        }

        .form-floating > label { color: #6B7280; font-size: 0.9rem; }

        .btn-login {
            background-color: #1E3A8A;
            border-color: #1E3A8A;
            color: #fff;
            padding: 0.55rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            transition: background-color 0.2s, transform 0.15s;
        }

        .btn-login:hover {
            background-color: #162d6e;
            border-color: #162d6e;
            color: #fff;
            transform: translateY(-1px);
        }

        .link-forgot {
            color: #1E3A8A;
            font-size: 0.85rem;
            text-decoration: none;
        }

        .link-forgot:hover { color: #00BFA5; text-decoration: underline; }

        footer {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 1rem;
            color: rgba(255, 255, 255, 0.45);
            font-size: 0.78rem;
        }

        footer a { color: rgba(255, 255, 255, 0.55); text-decoration: none; }
        footer a:hover { color: #00BFA5; }
    </style>
</head>
<body>
    <div class="login-overlay"></div>

    <div id="layoutAuthentication">
        <div class="login-card">
            <div class="login-card-header">
                <div class="login-logo">
                    <span class="brand">Congrega</span><span class="sub">CRM</span>
                </div>
                <div class="login-subtitle">Gestión para tu congregación</div>
            </div>
            <div class="login-card-body">
                <form asp-controller="Acceso" asp-action="Login" method="post">
                    <div class="form-floating mb-3">
                        <input class="form-control" id="inputEmail" name="correo" type="email" placeholder=" " required />
                        <label for="inputEmail">Correo electrónico</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input class="form-control" id="inputPassword" name="clave" type="password" placeholder=" " required />
                        <label for="inputPassword">Contraseña</label>
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                    {
                        <div class="alert alert-danger py-2 small" role="alert">
                            <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.Error
                        </div>
                    }

                    <div class="d-flex align-items-center justify-content-between mt-4">
                        <a class="link-forgot" asp-controller="Acceso" asp-action="ReestablecerClave">
                            ¿Has olvidado tu contraseña?
                        </a>
                        <button type="submit" class="btn btn-login">
                            <i class="fas fa-sign-in-alt me-1"></i> Iniciar sesión
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <footer>
        &copy; @DateTime.Now.Year Congrega &nbsp;&middot;&nbsp;
        <a href="#">Política de privacidad</a>&nbsp;&middot;&nbsp;<a href="#">Términos y condiciones</a>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
