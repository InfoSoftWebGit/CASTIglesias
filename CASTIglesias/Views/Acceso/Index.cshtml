@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - CASTIglesias</title>

    <!-- Bootstrap CSS -->
    <link href="~/css/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Tu CSS propio -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
</head>
<body class="bg-primary d-flex flex-column min-vh-100">
    <div id="layoutAuthentication" class="flex-grow-1">
        <div id="layoutAuthentication_content">
            <main>
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-lg-5">
                            <div class="card shadow-lg border-0 rounded-lg mt-5">
                                <div class="card-header">
                                    <h3 class="text-center my-4">Iniciar sesión</h3>
                                </div>
                                <div class="card-body">
                                    <form asp-controller="Acceso" asp-action="Index" method="post">
                                        <!-- INPUT EMAIL -->
                                        <div class="form-floating mb-3">
                                            <input class="form-control" id="inputEmail" name="correo" type="email" placeholder=" " required />
                                            <label for="inputEmail">Correo electrónico</label>
                                        </div>

                                        <!-- INPUT CONTRASEÑA -->
                                        <div class="form-floating mb-3">
                                            <input class="form-control" id="inputPassword" name="clave" type="password" placeholder=" " required />
                                            <label for="inputPassword">Contraseña</label>
                                        </div>

                                        <!-- CONTROL DE ERRORES -->
                                        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                                        {
                                            <div class="alert alert-danger" role="alert">
                                                @ViewBag.Error
                                            </div>
                                        }

                                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                                            <a class="small" asp-controller="Acceso" asp-action="ReestablecerClave">
                                                ¿Has olvidado tu contraseña?
                                            </a>
                                            <button type="submit" class="btn btn-primary">Iniciar sesión</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Footer separado -->
    <footer class="py-4 bg-light mt-auto">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between small">
                <div class="text-muted">&copy; @DateTime.Now.Year - CASTIglesias</div>
                <div>
                    <a href="#">Política de privacidad</a>
                    &middot;
                    <a href="#">Términos y condiciones</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>
